        typ = "X256"
        cap = "Pre-Disaster"
      }
      spawnflags: =
      {
        txt = "&"
        hint = "The spawned monster won't drop items upon death."
        typ = "X1024"
        cap = "Don't Drop Gun"
      }
      spawnflags: =
