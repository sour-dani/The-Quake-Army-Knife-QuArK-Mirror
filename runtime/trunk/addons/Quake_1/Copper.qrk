          count = "-1"
          strength = "1"
        }
        target_items:e =
        {
          origin = "0 0 0"
          ;desc = "Target: Give. Adds weapons, ammo, items, health, armor, and"
           "/or runes to the activating player when triggered."$0A"Spawnflag U"
