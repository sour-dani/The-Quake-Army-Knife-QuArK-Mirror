        }
        item_rockets:e =
        {
          origin = "0 0 0"
          ;desc = "Rockets, 4/8"
        }
        item_shells:e =
        {
          origin = "0 0 0"
          ;desc = "Shells, 20/40"
        }
        item_sigil:e =
        {
          origin = "0 0 0"
          ;desc = "End of episode rune.  Can be customized through keyvalue ma"
