          origin = "0 0 0"
          ;desc = "Wildcard entity"
        }
        info_null:e =
        {
          origin = "0 0 0"
          ;desc = "info_null (spotlight target)"$0A"Not present in game."
        }
        info_player_coop:e =
        {
          origin = "0 0 0"
          ;desc = "Player cooperative start"
        }
        info_player_deathmatch:e =
        {
          origin = "0 0 0"
          ;desc = "Deathmatch start"
        }
        info_player_start:e =
        {
          origin = "0 0 0"
          ;desc = "Player 1 start. Fires targets when a player spawns here."
        }
        info_player_start2:e =
        {
          origin = "0 0 0"
          ;desc = "Player episode return point. Fires targets when a player sp"
           "awns here."
          style = "0"
        }
        info_player_start_test:e =
        {
          origin = "0 0 0"
          ;desc = "Developer-only spawn point"
        }
        info_teleport_destination:e =
        {
          origin = "0 0 0"
          ;desc = "Teleporter destination"
        }
        info_teleport_target:e =
        {
          origin = "0 0 0"
          ;desc = "Triggerable Teleporter destination"$0A"This is a usable des"
           "tination marker that acts as its own teleporter.  When triggered, "
           "the activator is teleported to this spot."$0A"If 'Act On Targets' "
           "is set, teleports its targets intead of firing them and ignores th"
           "e activator."$0A"If 'Player only' or 'Monsters only' is checked, t"
           "his can only be activated by players or monsters respectively."$0A
           "Set 'Push forward' if you want the teleport-exit forward velocity "
           "effect, or 'No teleflash' to plop an entity here silently."$0A"PLA"
           "YER_ONLY"$0909"only players will teleport"$0A"PUSH"$090909"chuck t"
           "he player forward like a trigger_teleport does"$0A"TRIGGER_FIRST"$09
           "first use turns it on, and every subsequent use teleports"$0A"NOFL"
           "ASH"$090909"don't spawn telefog or make noise"$0A"MONSTER_ONLY"$09
           "only monsters will teleport"
        }
      }
      item_* entities.qtxfolder =
      {
        item_armor1:e =
        {
          origin = "0 0 0"
          ;desc = "Green armor (100pts, 30%)"
        }
        item_armor2:e =
        {
          origin = "0 0 0"
          ;desc = "Yellow armor (150pts, 50%)"
        }
        item_armorInv:e =
        {
          origin = "0 0 0"
          ;desc = "Red armor (200pts, 70%)"
        }
        item_artifact_envirosuit:e =
        {
          origin = "0 0 0"
          ;desc = "Envirosuit. Player takes no damage from water or slime for "
           "30 seconds. Lava damage is reduced by one height step, enabling wa"
           "ding in foot-deep lava."
        }
        item_artifact_invisibility:e =
        {
          origin = "0 0 0"
          ;desc = "Ring of Shadows. Player is invisible for 30 seconds. Monste"
           "rs will not awaken on sight, but they will on hearing sound (like "
           "gunfire). Awakened monsters will try to attack an invisible player"
           " and do an inaccurate job, possibly starting infights."$0A"monster"
           "_dog can still smell an invisible player, but monster_tarbaby can'"
           "t find the player at all."
        }
        item_artifact_invulnerability:e =
        {
          origin = "0 0 0"
          ;desc = "Pentagram of Protection. Player is invulnerable for 30 seco"
           "nds (both health and armor)."
        }
        item_artifact_super_damage:e =
        {
          origin = "0 0 0"
          ;desc = "Quad Damage. Player's attacks do 4x damage and they stop pa"
           "ying attention to anything else."
        }
        item_backpack:e =
        {
          origin = "0 0 0"
          ;desc = "A forgotten explorer's backpack. Grants a paltry sum of she"
           "lls and nails (about half a small pack of each). Grants armor inst"
           "ead of any ammo the player already has maxed."
        }
        item_cells:e =
        {
          origin = "0 0 0"
          ;desc = "Thunderbolt Ammo, 6/12 cells"
        }
        item_health:e =
        {
          origin = "0 0 0"
          ;desc = "Health pack, +25"
        }
        item_key1:e =
        {
          origin = "0 0 0"
          ;desc = "Silver Key. Player can carry up to 15. Remember to set worl"
