          spawnflags = "1"
        }
        item_spikes:e =
        {
          origin = "0 0 0"
          ;desc = "Nailgun/Perforator ammo, 25/50"
        }
      }
      light_* entities.qtxfolder =
      {
        light_candle:e =
        {
          origin = "0 0 0"
          ;desc = "Animated candle. Trigger to turn on or off."$0A"If triggere"
           "d to turn on and off, all candles with a matching targetname will "
           "ignite or go out as well."$0A"Choose size with 'width' and 'height"
           "' (leave either at 0 for random selection)."
          width = "0"
          height = "0"
        }
        light_flame_large_yellow:e =
        {
          origin = "0 0 0"
          ;desc = "Large yellow flame"
        }
        light_flame_small_white:e =
