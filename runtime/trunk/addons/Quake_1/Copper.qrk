        target_secret:e =
        {
          origin = "0 0 0"
          ;desc = "Secret counter trigger.  Player gets a secret credit when t"
           "riggered.  Note when using a target_secret: if triggered by touchi"
           "ng an item, and the item can't be picked up (because of health/arm"
           "or/ammo limits already being met, etc), it won't fire its targets "
           "and thus the target_secret won't give credit. Use a trigger in tha"
           "t case."$0A"Set the 'supersecret' spawnflag to hide its existence "
           "in the total until it's found. Think very carefully if you actuall"
           "y want to use this."
        }
        target_setskill:e =
        {
          origin = "0 0 0"
          ;desc = "Target: Set Skill"
