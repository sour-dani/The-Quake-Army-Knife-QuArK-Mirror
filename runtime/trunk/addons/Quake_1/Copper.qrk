           "rget4 on exit distance range"
          alpha = "1.0"
          alpha2 = "0.0"
        }
        target_fogblend:e =
        {
          origin = "0 0 0"
          ;desc = "Target: Fog Blend"$0A"Activator's fog will be blended over "
           "time from start to end values."$0A"- will 'stuffcmd' up to 20 time"
           "s per frame so try not to make this take too long, but as an optim"
           "ization, Copper will avoid sending the stuffcmd if it determines t"
           "hat the fog difference frame over frame is not visually significan"
           "t."$0A"- a bug in most quake engine ports will reset the eye posit"
           "ion smoothing that happens when climbing stairs or riding a plat o"
           "n every frame that a 'stuffcmd' is sent, so fog transitions during"
           " upwards motion will cause noticeable stuttering."
        }
        target_heal:e =
        {
          origin = "0 0 0"
          ;desc = "Target : Heal."$0A"Heals activator for 'healamount' when tr"
           "iggered. Use for healing pools, first aid dispensers, etc."$0A"If "
           "it has any targets, it heals them instead, even doors and buttons."
           " This will not reset 'dead' doors or buttons with a wait of -1."$0A
           "If 'trigger first' and 'auto set count' are set, will choose 'coun"
           "t' based on how much health the activator needs when first trigger"
           "ed, for dirty lazy automatic game balance. Use 'lip' and 'max_heal"
           "th' to constrain this."
