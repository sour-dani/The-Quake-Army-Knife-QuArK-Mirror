QQRKSRC1

{
  QuArKProtected = "1"
  Description = "Add-on for Copper"

  Copper directory infos.qctx =
  {
    Game = "Quake 1"
    SourceDir = "copper"
    GameDir = "copper"
  }

  Toolbox Folders.qtx =
  {
    Toolbox = "New map items..."
    Root = "Entities for copper.qtxfolder"
    Entities for copper.qtxfolder =
    {
      ;desc = "Created from copper.fgd"
      air_* entities.qtxfolder =
      {
        air_bubbles:e =
        {
          origin = "0 0 0"
          ;desc = "Air bubble emitter."
          wait = "1"
          rand = "1"
          size = "0 0 0"
          count = "1"
        }
      }
      ambient_* entities.qtxfolder =
      {
        ambient_comp_hum:e =
        {
          origin = "0 0 0"
          ;desc = "Computer background sounds"
          volume = "1"
        }
        ambient_drip:e =
        {
          origin = "0 0 0"
          ;desc = "Dripping sound"
          volume = "0.75"
        }
        ambient_drone:e =
        {
          origin = "0 0 0"
          ;desc = "Engine/machinery sound"
          volume = "0.55"
        }
        ambient_flouro_buzz:e =
        {
          origin = "0 0 0"
          ;desc = "Fluorescent buzzing sound"
          volume = "1"
        }
        ambient_light_buzz:e =
        {
          origin = "0 0 0"
          ;desc = "Buzzing sound from light"
          volume = "0.85"
        }
        ambient_sound:e =
        {
          origin = "0 0 0"
          ;desc = "Custom ambient sound"
          volume = "1"
        }
        ambient_suck_wind:e =
        {
          origin = "0 0 0"
          ;desc = "Wind sound"
          volume = "1"
        }
        ambient_swamp1:e =
        {
          origin = "0 0 0"
          ;desc = "Frogs croaking"
          volume = "0.75"
        }
        ambient_swamp2:e =
        {
          origin = "0 0 0"
          ;desc = "Frogs croaking B"
          volume = "0.5"
        }
        ambient_thunder:e =
        {
          origin = "0 0 0"
          ;desc = "Thunder sound"
          volume = "0.5"
        }
      }
      event_* entities.qtxfolder =
      {
        event_lightning:e =
        {
          origin = "0 0 0"
          ;desc = "Chthon lightning. Fires targets on a successful zap."$0A"Se"
           "tup is weird and special: it must find two func_doors each with a "
           "'target' (not targetname) of 'lightning', and it will branch the l"
           "ightning between the bottom center of each door. If both doors are"
           " closed it won't hurt Ch'thon, but if both are open, it will, and "
           "otherwise lightning won't happen at all. Lightning doesn't actuall"
           "y have to go through Ch'thon."
        }
      }
      func_* entities.qtxfolder =
      {
        func_bobbing:b =
        {
          ;incl = "defpoly"
          ;desc = "Bobbing platform."$0A"Moves in a smooth sine wave. Build at"
           " the center of motion, specify 'wait' for the wavelength in second"
           "s and 'distance' for the amplitude (distance from end to end) in u"
           "nits. Use 'delay' to set a phase offset (0-1)."$0A"Trigger to free"
           "ze in place or reactivate. If any 'don't stop until' spawnflags ar"
           "e checked, the bobber will keep oscillating until it reaches one o"
           "f the designated positions and stop there."$0A"Set both 'pos1' & '"
           "pos2' to override the two apex positions (ends of the bob) to buil"
           "d and light your plat wherever."
        }
        func_bobbing_point:e =
        {
          origin = "0 0 0"
          ;desc = "Bobbing platform."$0A"Moves in a smooth sine wave. Build at"
           " the center of motion, specify 'wait' for the wavelength in second"
           "s and 'distance' for the amplitude (distance from end to end) in u"
           "nits. Use 'delay' to set a phase offset (0-1)."$0A"Trigger to free"
           "ze in place or reactivate. If any 'don't stop until' spawnflags ar"
           "e checked, the bobber will keep oscillating until it reaches one o"
           "f the designated positions and stop there."$0A"Set both 'pos1' & '"
           "pos2' to override the two apex positions (ends of the bob) to buil"
           "d and light your plat wherever."
        }
        func_bossgate:b =
        {
          ;incl = "defpoly"
          ;desc = "Boss Gate."$0A"If players have NOT completed all episodes, "
           "it fires its targets."$0A"If players have completed all episodes, "
           "it self-removes."
        }
        func_button:b =
        {
          ;incl = "defpoly"
          ;desc = "Button. When a button is touched, it moves some distance in"
           " the direction of its angle, triggers all of its targets, waits so"
           "me time, then returns to its original position where it can be tri"
           "ggered again."$0A"Acts as if touched when triggered. Depresses its"
           "elf when locked by a target_lock to look inactive."$0A"Alt Target "
           "Pattern: 'target' when touched, 'target2' when fully depressed, 't"
           "arget3' when returning, 'target4' when fully out."
          speed = "40"
          lip = "4"
          distance = "0.0"
          wait = "1"
        }
        func_button_skill:b =
        {
          ;incl = "defpoly"
          ;desc = "Special button for selecting skill level. Will always be pr"
           "essed when the skill corresponding to the chosen spawnflag is set."
           " Changes its state automatically when other skill buttons are pres"
           "sed, when trigger_setskills are touched, or when skill is changed "
           "live at the console."$0A"Alt Target Pattern: 'target' when touched"
           ", 'target2' when fully depressed, 'target3' when returning, 'targe"
           "t4' when fully out."
          spawnflags = "2"
          speed = "40"
          lip = "4"
          distance = "0.0"
        }
        func_detail:b =
        {
          ;incl = "defpoly"
          ;desc = "Group of brushes which aren't abusive to bsp"
        }
        func_detail_fence:b =
        {
          ;incl = "defpoly"
          ;desc = "Group of brushes which aren't solid, or abusive to bsp or g"
           "eometry, and are two-sided"
        }
        func_detail_illusionary:b =
        {
          ;incl = "defpoly"
          ;desc = "Group of brushes which aren't solid, or abusive to bsp or g"
           "eometry"
        }
        func_detail_wall:b =
        {
          ;incl = "defpoly"
          ;desc = "Group of brushes which aren't abusive to bsp or geometry"
        }
        func_door:b =
        {
          ;incl = "defpoly"
          ;desc = "Door. Opens; closes."$0A"If two doors touch, they are assum"
           "ed to be connected and operate as a unit. Targets, targetnames, an"
           "d the Crusher and Toggle spawnflags are safely shared between link"
           "ed doors automatically."$0A"Doors will not link if either has the "
           "'don't link' spawnflag, if they have different targetnames, or dif"
           "ferent key requirements."$0A"Alt Target Pattern: 'target' when sta"
           "rting to open, 'target2' when opened, 'target3' when starting to c"
           "lose, 'target4' when closed."
          speed = "100"
          speed2 = "0"
          sounds = "0"
          wait = "3"
          lip = "8"
          distance = "0.0"
          dmg = "2"
          health = "0"
        }
        func_door_secret:b =
        {
          ;incl = "defpoly"
          ;desc = "Secret door. Slides back, then to the side."$0A"There are t"
           "hree ways to configure how this door moves:"$0A"1) Set 'Angle'. Th"
           "e secret door will first move to the right of that angle by t_widt"
           "h units, then in the direction of that angle by t_length units. t_"
           "width and t_length default to the size of the door on those axes i"
           "f left blank. The first move can be altered with the 'move left fi"
           "rst' or 'move down first' spawnflags."$0A"2) Set 'dest1' and 'dest"
           "2'. These are (x y z) vectors in worldspace corresponding to the f"
           "irst and second move, which will be scaled to the size of t_width "
           "and t_length."$0A"3) Target a path_corner which targets a second p"
           "ath_corner. The door will move by its minimum corner like a func_t"
           "rain."$0A"Activating this door with a trigger while it is opening "
           "will have no effect. Activating it while it is waiting open will r"
           "eset its wait time (holding it open). Activating it while it is cl"
           "osing will cause it to reverse direction and open again. This lets"
           " you put a trigger_multiple in a secret room behind a func_door_se"
           "cret to hold it open as long as a player is inside."
          dmg = "2"
          speed = "50"
          speed2 = "50"
          wait = "2"
          sounds = "3"
        }
        func_episodegate:b =
        {
          ;incl = "defpoly"
          ;desc = "Episode Gate."$0A"If players have completed the episode, it"
           " fires its targets."$0A"If players have NOT completed the episode,"
           " it self-removes."$0A"Match svflags to the svflags of an item_sigi"
           "l to respond to that rune instead."$0A"If multiple svflags or epis"
           "ode spawnflags are set, gate will spawn if the player has ANY of t"
           "hose runes. To require them all, check 'Require All Specified'."
          spawnflags = "1"
        }
        func_explobox:b =
        {
          ;incl = "defpoly"
          ;desc = "Customizable exploding container."$0A"Explodes when trigger"
           "ed or shot. Fires targets when it explodes."
          dmg = "150"
        }
        func_flytrain:b =
        {
          ;incl = "defpoly"
          ;desc = "Acts as a func_train with PATH_SPEED and SMOOTH_SPEED set, "
           "with additional random motion and and gentle smoothing at stops, s"
           "tarts, and hard corners. Will fire all targets of a pathcorner on "
           "arrival, but does not normally fire its own targets."$0A"Alt Targe"
           "t Pattern: 'target' selects path start, 'target2' on each pathcorn"
           "er arrival, 'target3' on each departure, 'target4' on termination"
          width = "8"
          height = "8"
        }
        func_flytrain_point:e =
        {
          origin = "0 0 0"
          ;desc = "Acts as a func_train with PATH_SPEED and SMOOTH_SPEED set, "
           "with additional random motion and and gentle smoothing at stops, s"
           "tarts, and hard corners. Will fire all targets of a pathcorner on "
           "arrival, but does not normally fire its own targets."$0A"Alt Targe"
           "t Pattern: 'target' selects path start, 'target2' on each pathcorn"
           "er arrival, 'target3' on each departure, 'target4' on termination"
        }
        func_group:b =
        {
          ;incl = "defpoly"
          ;desc = "Group of brushes for in-editor use"
        }
        func_illusionary:b =
        {
          ;incl = "defpoly"
          ;desc = "Nonsolid, untriggerable static wall"
          alpha = "1"
        }
        func_plat:b =
        {
          ;incl = "defpoly"
          ;desc = "Elevator platform."$0A"Plats are always drawn in the extend"
           "ed position, so they will light correctly."$0A"If the plat is the "
           "target of another trigger or button, it will start out disabled in"
           " the top position until it is triggered, when it will lower and be"
           "come a normal plat."$0A"If the plat targets a trigger once/multipl"
           "e/multiple_box, it will override the plat's default activation zon"
           "e (consuming the trigger)."$0A"Movement distance can be defined wi"
           "th 'height' or 'lip'. By instead setting 'pos1' & 'pos2' you can d"
           "irectly override the top and bottom positions, allowing the plat t"
           "o be built anywhere else in the map. This is useful for building a"
           " plat where it will be lit the best."$0A"The 'low trigger volume' "
           "spawnflag will put the activation zone only at the bottom of the m"
           "ovement course, instead of the whole vertical."$0A"Alt Target Patt"
           "ern: 'target' upon rising, 'target2' upon reaching top, 'target3' "
           "upon descending, 'target4' upon reaching bottom."
          speed = "150"
          height = "0"
          lip = "8"
          dmg = "1"
          wait = "3"
          sounds = "2"
        }
        func_train:b =
        {
          ;incl = "defpoly"
          ;desc = "Moving platform that players can ride."$0A"Its origin is th"
           "e min corner of the train."$0A"The train spawns at the first targe"
           "t it is pointing at. If the train is the target of a button or tri"
           "gger, it will not begin moving until activated."$0A"Will fire all "
           "targets of a pathcorner on arrival, but does not normally fire its"
           " own targets."$0A"If 'Speed from path' is set, the train will inhe"
           "rit the 'speed' value from path_corners as it reaches them. If 'bl"
           "end speed smoothly' is also set, the train will instead smoothly b"
           "lend to its destination's 'speed' as it travels to it."$0A"If a pa"
           "th_corner's speed is -1, the func_train's move when LEAVING that c"
           "orner will be to snap instantly to the next corner."$0A"The 'Toggl"
           "e' spawnflag allows starting and stopping the motion anywhere on t"
           "he train's path (default is to ignore triggerings when in motion)."
           $0A"Setting 'health' will allow the train to be shot to trigger it "
           "whenever it could normally be triggered (toggle spawnflag applies)"
           "."$0A"Alt Target Pattern: 'target' selects path start, 'target2' o"
           "n each pathcorner arrival, 'target3' on each departure, 'target4' "
           "on termination"
        }
        func_train_point:e =
        {
          origin = "0 0 0"
          ;desc = "Moving platform that players can ride."$0A"The point entity"
           " is the origin, even if a model is specified."$0A"The train spawns"
           " at the first target it is pointing at. If the train is the target"
           " of a button or trigger, it will not begin moving until activated."
           $0A"Will fire all targets of a pathcorner on arrival, but does not "
           "normally fire its own targets."$0A"If 'Speed from path' is set, th"
           "e train will inherit the 'speed' value from path_corners as it rea"
           "ches them. If 'blend speed smoothly' is also set, the train will i"
           "nstead smoothly blend to its destination's 'speed' as it travels t"
           "o it."$0A"If a path_corner's speed is -1, the func_train's move wh"
           "en LEAVING that corner will be to snap instantly to the next corne"
           "r."$0A"The 'Toggle' spawnflag allows starting and stopping the mot"
           "ion anywhere on the train's path (default is to ignore triggerings"
           " when in motion)."$0A"Alt Target Pattern: 'target' selects path st"
           "art, 'target2' on each pathcorner arrival, 'target3' on each depar"
           "ture, 'target4' on termination"
        }
        func_void:b =
        {
          ;incl = "defpoly"
          ;desc = "for holes into which one should not fall"$0A"Texture this w"
           "ith black (or sky?) and cover the bottom of the pit with it.  Auto"
           "matically offsets its own visual model upward, to hide pesky heads"
           " and scrag corpses underneath.  Also automatically spawns a start-"
           "of-plunge trigger of the same size 'height' units above itself tha"
           "t plays a yell sound and fades out the view of clients as they sta"
           "rt to fall in."$0A"The player's view will have faded completely by"
           " the time they touch the bottom, so we hold them in stasis for a l"
           "ittle while longer there before splatting them, to imply the pit i"
           "s deeper than it really is. The player can therefore feel like the"
           "y fall for a long time before crash landing in darkness without yo"
           "u having to build a pit that deep."$0A"Fires all targets when a cl"
           "ient touches the plunge trigger (ie the yell, not the splat)."$0A"I"
           "f the func_void's first target is an info_teleport_destination, it"
           " will hurt the player and teleport him to the destination. If the "
           "damage is enough to kill the player, it continues with the fade an"
           "d splat as normal without teleporting."
          delay = "3"
          height = "128"
          lip = "32"
          dmg = "60"
          fadecolor = "0 0 0"
          noise = "player/q3fall.wav"
          noise2 = "player/splat1.wav"
        }
        func_wall:b =
        {
          ;incl = "defpoly"
          ;desc = "Wall. Changes its texture(s) to alternate ones (e.g. basebt"
           "n), if triggered."$0A"Not static: Use a func_static for inconseque"
           "ntial bmodels."$0A"If 'Illusionary' is set, wall will always be no"
           "nsolid."$0A"If 'Toggle Visibility' is set, will disappear and reap"
           "pear when triggered instead of flipping texture."
        }
        func_wall_point:e =
        {
          origin = "0 0 0"
          ;desc = "Wall. Changes its texture(s) to alternate ones (e.g. basebt"
           "n), if triggered."$0A"Not static: Use a func_static for inconseque"
           "ntial bmodels."$0A"Select a .bsp or .mdl to show with 'model'."$0A
           "If 'Illusionary' is set, wall will always be nonsolid. If you use "
           "a .mdl you MUST set this flag (or consider a misc_model instead?)"$0A
           "If 'Toggle Visibility' is set, will disappear and reappear when tr"
           "iggered instead of flipping texture."
        }
      }
      info_* entities.qtxfolder =
      {
        info_intermission:e =
        {
          origin = "0 0 0"
          ;desc = "Intermission camera"
        }
        info_notnull:e =
