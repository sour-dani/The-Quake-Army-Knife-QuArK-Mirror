      misc_* entities.qtxfolder =
      {
        misc_explobox:e =
        {
          origin = "0 0 0"
          ;desc = "Large exploding container, 150 damage."$0A"Explodes when tr"
           "iggered or shot. Fires targets when it explodes."$0A"will do enoug"
           "h damage to set off other barrels at up to ~172u distance (center "
           "to center)."
        }
        misc_explobox2:e =
        {
          origin = "0 0 0"
          ;desc = "Small exploding container, 100 damage."$0A"Explodes when tr"
           "iggered or shot. Fires targets when it explodes."$0A"will do enoug"
           "h damage to set off other barrels at up to ~128u distance (center "
           "to center)."
        }
        misc_external_map:e =
        {
          origin = "0 0 0"
          ;desc = "Put another map in your map"
        }
        misc_fireball:e =
        {
          origin = "0 0 0"
          ;desc = "Lavaball Launcher."$0A"Fires randomly. Trigger to toggle on"
           "/off."
          delay = "0"
