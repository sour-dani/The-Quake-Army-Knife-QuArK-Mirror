          ;desc = "Custom triggered sound. Will play one sound every time it i"
           "s triggered."$0A"You can set up to five sounds on this entity to c"
           "ycle through in order (or shuffle, with the 'random' spawnflag). T"
           "hey will not cut each other off, so triggering this entity more fr"
           "equently than the length of the sounds will overlap them."
          volume = "1"
          delay = "1"
          count = "0"
          wait = "0"
          rand = "0"
          style = "0"
        }
        target_state:e =
        {
          origin = "0 0 0"
          ;desc = "Target : State."$0A"Holds a numeric variable, or tests othe"
           "r entities for theirs before firing targets."$0A"Set 'state' to in"
           "itial value. triggering this will cycle the value (swapping 0 and "
           "1)."$0A"If 'Relay' spawnflag is checked, it acts as a relay instea"
           "d of holding state. It fires its targets based on the value of the"
           " 'state' member of another entity, specified by setting 'state' to"
           " the value it has to match and 'include' to that entity's targetna"
           "me. This can be another target_state, or any other entity which ha"
           "s a 'state', such as doors or plats."$0A"0: off (lights/etc)/top ("
           "plats)/open (doors)/pushed (buttons)"$0A"1: on (lights/etc)/bottom"
           " (plats)/closed (doors)/unpushed (buttons)"$0A"2: going up (plats)"
           "/opening (doors)/pushing (buttons)"$0A"3: going down (plats)/closi"
           "ng (doors)/unpushing (buttons)"$0A"A trigger_counter's 'state' is "
           "its current trigger count."$0A"If 'Inverse' spawnflag is set, will"
           " decrement when triggered instead of increment. If both 'Relay' an"
           "d 'Inverse', will fire targets if the state of 'include' is anythi"
           "ng other than a match."
          count = "1"
        }
