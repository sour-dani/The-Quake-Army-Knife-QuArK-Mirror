    info_player_intermission:form =
    {
      help = "===========DESCRIPTION============================"$0D"The inter"
       "mission will be viewed from this point.  Target an info_notnull for th"
       "e view direction."$0D"===========SPAWNFLAGS==========================="
       "=="$0D"RED - The intermission will happen here if the Red (attacking) "
       "team wins."$0D"BLUE - The intermission will happen here if the Blue (d"
       "efending) team wins."$0D"===========KEYS&VALUES======================="
       "====="$0D"'target' - Entity to look at."$0D"'target2' - Entities to us"
       "e when this intermission point is chosen."$0D"==============NOTES====="
       "=========================="$0D"When time limit is reached you wait for"
       " game to end looking from here. This when used at the end of game (tim"
       "e limit) can cause things to happen. (Target2 key) In other words a sc"
       "ripted event or any entity could be used."
      bbox = '-16 -16 -24 16 16 32'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "RED"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "BLUE"
      }
    }
    info_player_intermission_red:form =
    {
      help = "===========DESCRIPTION============================"$0D"In a Sieg"
       "e game, the intermission will happen here if the Red (attacking) team "
       "wins."$0D"The intermission will be viewed from this point.  Target an "
       "info_notnull for the view direction."$0D"===========KEYS&VALUES======="
       "====================="$0D"'target' - Entity to look at."$0D"'target2' "
       "- Entities to use when this intermission point is chosen."$0D"========"
       "======NOTES==============================="$0D"When time limit is reac"
       "hed you wait for game to end looking from here. This when used at the "
       "end of game (time limit) can cause things to happen. (Target2 key) In "
       "other words a scripted event or any entity could be used."
      bbox = '-16 -16 -24 16 16 32'
    }
    info_player_intermission_blue:form =
    {
      help = "===========DESCRIPTION============================"$0D"In a Sieg"
       "e game, the intermission will happen here if the Blue (defending) team"
       " wins."$0D"The intermission will be viewed from this point.  Target an"
       " info_notnull for the view direction."$0D"===========KEYS&VALUES======"
