    _skybox:form =
    {
      help = "===========DESCRIPTION============================"$0D"Compiler-"
       "only entity that specifies the origin of a skybox (a wholly contained,"
       " seperate area of the map), similar to some games' portal skies. When "
       "compiled with Q3Map2, the skybox surfaces will be visible from any pla"
       "ce where sky is normally visible. It will cast shadows on the normal p"
       "arts of the map, and can be used with cloud layers and other effects."$0D
       "===========KEYS&VALUES============================"$0D"'angle' - rotat"
       "ion angle of the sky surfaces."$0D"'angles' - Individual control of PI"
       "TCH, YAW, and ROLL (default 0 0 0)."$0D"'_scale' - scaling factor (def"
       "ault 64), good values are between 50 and 300, depending on the map."$0D
       "===========NOTES=================================="$0D"This entity MUS"
       "T be recreated if moved after saving the map, otherwise it won't work."
      bbox = '-8 -8 -8 8 8 8'
    }
    misc_tutorial_checkpoint:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"The misc_tutorial_ch"
       "eckpoint entity "$22"listens"$22" for an event in the menu files, spec"
       "ifically the (uiScript tutCheckpoint "$22"eventnamehere"$22") command."
       $0D"OR"$0D"It listens for a specific key event if the entity has the KE"
       "YPRESS_MODE spawnflag."$0D"===========SPAWNFLAGS======================"
       "======="$0D"START_ON - Will start listening on round begin (It is reco"
       "mmended to activate it through a target_activate after round begin ins"
       "tead)."$0D"KEYPRESS_MODE - Instead of listening for uiScript tutCheckp"
       "oint calls, it will listen for the specified keypress in listenEvent."$0D
       "===========KEYS&VALUES============================"$0D"'listenEvent' -"
       " Name of the uiScript tutCheckpoint parameter OR name of the key funct"
       "ion to detect (if KEYPRESS_MODE is on)."$0D"===========KEYPRESS VALUES"
       "========================"$0D"KEY_RELOAD"$0D"KEY_WEAPONMODE"$0D"KEY_PRI"
       "MFIRE"$0D"KEY_ALTFIRE"$0D"===========NOTES============================"
       "======"$0D"Designed to be used for tutorial levels in MBII."
      bbox = '-8 -8 -8 8 8 8'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "START_ON"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "KEYPRESS_MODE"
      }
    }
    misc_uipopup:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"An entity that cause"
       "s a popup UI for tooltips, useful information, or tutorial specific de"
       "scriptions."$0D"===========KEYS&VALUES============================"$0D
       "'duration' - Time in milliseconds for the popup to remain visible."$0D
       "'message' - The message to display on the popup. The first line is alw"
       "ays the title. Use \n to make new lines. If there is no title just sta"
       "rt with \n. To display a keybind put a + symbol before the name of the"
       " action, even if it does not contain one in-game."$0D"===========NOTES"
       "=================================="$0D"Designed to be used for tutoria"
       "l levels in MBII."
      bbox = '-12 -12 -12 12 12 12'
    }
    misc_updateforcecfg:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"Entity used to chang"
       "e the class of a player using an open mode force config string."$0D"=="
       "=========SPAWNFLAGS============================="$0D"FIREONSPECTATOR -"
       " Make the entity trigger on spectators."$0D"===========KEYS&VALUES===="
       "========================"$0D"'team' - Team the class is a part of."$0D
       "TEAM_SPECTATOR"$0D"TEAM_BLUE"$0D"TEAM_RED"$0D"'class' - Player class t"
       "o use."$0D"MB_CLASS_NOCLASS"$0D"MB_CLASS_SOLDIER"$0D"MB_CLASS_JEDI"$0D
       "MB_CLASS_HERO"$0D"MB_CLASS_MANDALORIAN"$0D"MB_CLASS_WOOKIE"$0D"MB_CLAS"
       "S_DROIDEKA"$0D"MB_CLASS_CLONETROOPER"$0D"MB_CLASS_ELITETROOPER"$0D"MB_"
       "CLASS_SBD"$0D"MB_CLASS_ARCTROOPER"$0D"MB_CLASS_BOUNTY_HUNTER"$0D"MB_CL"
       "ASS_OBSERVER"$0D"'config' - Open mode config string for the chosen cla"
       "ss. Grab this by making a config from open mode and opening the .fcf t"
       "xt file."$0D"'count' - Number of times that the entity will trigger."$0D
       "===========NOTES=================================="$0D"Designed to be "
       "used for tutorial levels in MBII."
      bbox = '-12 -12 -12 12 12 12'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "FIREONSPECTATOR"
      }
    }
    target_command:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"The target_command e"
       "ntity allows you to run certain commands or cvars changes through the "
       "map itself."$0D"===========KEYS&VALUES============================"$0D
       "'cmd' - Console command to run (see valid commands)."$0D"'cmdParam1' -"
       " First param (if needed)"$0D"'cmdParam2' - Second param (if needed)"$0D
       "'cmdParam3' - Third param (if needed)"$0D"===========VALID COMMANDS==="
       "======================"$0D"disconnect"$0D"s_musicvolume <param1>"$0D"="
       "==========NOTES=================================="$0D"Designed to be u"
       "sed for tutorial levels in MBII."
      bbox = '-8 -8 -8 8 8 8'
    }
    target_extend_time:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"Will try to add seco"
       "nds to timer. The total time added through multiple entities cannot be"
       " more than 15 minutes."$0D"The entity will free itself after use."$0D"="
       "==========KEYS&VALUES============================"$0D"'timeToAdd' - Se"
       "conds to add to timer."$0D"'message' - What will be printed on the pla"
       "yers' screens."$0D"===========NOTES=================================="$0D
       "You can add up to a total of 15 minutes (900000 ms) per round."$0D"If "
       "no message is supplied by the mapper, a default one will be used."
      bbox = '-8 -8 -8 8 8 8'
    }
    target_logic_progression:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"The target_logic_pro"
       "gression sets or gets the sv_progression cvar."$0D"===========KEYS&VAL"
       "UES============================"$0D"'get' - Number from 1 to 6, entity"
       " will fire its targets if 'get' value is the same as current value of "
       "sv_progression_test cvar."$0D"'set' - Number from 1 to 6, entity will "
       "set sv_progression_test cvar to this value."$0D"===========NOTES======"
       "============================"$0D"Only one of the keys may be used per "
       "entity."
      bbox = '-8 -8 -8 8 8 8'
    }
    target_tutorial_checklevel:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"Tutorial entity that"
       " fires its targets if and only if the specified tutorial has been comp"
       "leted."$0D"===========KEYS&VALUES============================"$0D"'tut"
       "orial' - Number of the tutorial that this entity will check against."$0D
       "===========NOTES=================================="$0D"Designed to be "
       "used for tutorial levels in MBII."
      bbox = '-8 -8 -8 8 8 8'
    }
    target_tutorial_completelevel:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"Tutorial entity that"
       " marks completion of a set tutorial level."$0D"===========KEYS&VALUES="
       "==========================="$0D"'tutorial' - Number of the tutorial th"
       "at this entity will set to completed."$0D"==============NOTES========="
       "======================"$0D"Designed to be used for tutorial levels in "
       "MBII."
      bbox = '-8 -8 -8 8 8 8'
    }
    _decal:form =
    {
      help = "===========DESCRIPTION============================"$0D"Creates a"
       " projectable decal from a patch mesh."$0D"===========KEYS&VALUES======"
       "======================"$0D"'target' - The name of the entity targeted "
       "at for projection."$0D"==============NOTES============================"
       "==="$0D"Compiler-only entity that specifies a decal to be projected. T"
       "he distance between the center of the _decal entity and the target is "
       "the axis and distance of projection. Should contain one or more patch "
       "meshes and target an info_null entity. The targeting line drawn betwee"
       "n the center of the _decal entity and the targeted info_null is the ax"
       "is and distance of projection. It helps to think of the _decal mesh as"
       " if it were a light gel, the info_null were the target of a spotlight,"
       " and that you were 'shining' this decal onto map geometry."$0D"Note to"
       " user: the surface of the info_null that would first be hit should be "
       "the closest to the surface to project on. In other words put the info_"
       "null in the wall or geometry."
    }
    target_ambient:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"Randomly plays back "
       "sounds from a soundSet, or a single sound, at intervals."$0D"========="
       "==SPAWNFLAGS============================="$0D"LOOPED-ON - Loops the so"
       "und but starts on."$0D"LOOPED-OFF - Loops the sound but starts off."$0D
       "GLOBAL - A global sound will play full volume throughout the level. Ig"
       "nored if a soundSet is defined."$0D"ACTIVATOR -  Sounds will play on t"
       "he player that activated the target. Ignored if a soundSet is defined."
       $0D"===========KEYS&VALUES============================"$0D"'wait' 0 (fl"
       "oat) - Minimum wait time between sound plays."$0D"'random' 0 (float) -"
       " Randomized extra wait time between plays (0 to value)."$0D"'soundSet'"
       " "$2222" (string) - Name of a bModelSet in sound.txt. Examples under n"
       "otes. Ignored if either of the LOOPED spawnflags are set."$0D"'soundSe"
       "tMin' 0 (int) - Lower range for sounds that may be used from the sound"
       "set. Leave blank to use all."$0D"'soundSetMax' 7 (int) - Upper range f"
       "or sounds that may be used from the soundset. Leave blank to use all."$0D
       "'noise' "$2222" (string) - Sound file to play (directory/location of f"
       "ile). Should work with wait + random timer. Setting both timers to 0 w"
       "ill make it so nothing plays unless targeted and fired. Ignored if a s"
       "oundSet is defined."$0D"'volume' - Allows variance of the volume of th"
       "e speaker, default is 255 (limit is 65535, but digital distortion will"
       " cut in long before then)."$0D"'volRange' - a low number and a high nu"
       "mber to set when you are at the farthest from it the min volume that i"
       "t will come to the player at. The high is for when your closest to it "
       "how loud it would be."$0D"'radius' - Radius of attenuation. In map uni"
       "ts."$0D"==============NOTES==============================="$0D"Wait an"
       "d random store data as float, but will be converted to int * 1000."$0D
       "soundSetMin/Max defines the range of sounds to use within the sound se"
       "t. Leave as is and all sounds should be played, but if you only 1 or 2"
       " sounds, setting max lower will improve client performance (less likel"
       "y to try an invalid sound). These settings are mostly intended to allo"
       "w use of a subset of sounds for more variety in different areas, witho"
       "ut needing to define duplicate soundSets."$0D"soundSet is a defined se"
       "t from sound.txt, and should be in func_door format:"$0D"bmodelSet kas"
       "hyyyk_dist_creeps"$0D"subWaves ambience/kashyyyk DistCreeps01 DistCree"
       "ps02 DistCreeps03 DistCreeps04 DistCreeps05"$0D"bmodelSet kashyyyk_woo"
       "d_creak"$0D"subWaves ambience/kashyyyk WoodCreak01 WoodCreak02 WoodCre"
       "ak03 WoodCreak04 WoodCreak05"
      bbox = '-8 -8 -8 8 8 8'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "LOOPED-ON"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "LOOPED-OFF"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "GLOBAL"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "ACTIVATOR"
      }
    }
  }
}
