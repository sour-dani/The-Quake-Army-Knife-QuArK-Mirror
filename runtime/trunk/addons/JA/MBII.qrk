    info_siege_objective:form =
    {
      help = "===========DESCRIPTION============================"$0D"When used"
       ", will complete a specified objective."$0D"===========SPAWNFLAGS======"
       "======================="$0D"STARTOFFRADAR - Start not displaying on ra"
       "dar, don't display until used."$0D"===========KEYS&VALUES============="
       "==============="$0D"'objective' - Specifies the objective to complete "
       "upon activation."$0D"'side' - Set to 1 to specify an imperial goal, 2 "
       "to specify rebels."$0D"'icon' - Icon that represents the objective on "
       "the radar."$0D"===========MOVIE BATTLES II SPECIFIC KEYS&VALUES======="
       "===="$0D"'radarteam' - Only show radar icon for team 1 or 2, default i"
       "s 0 (all)."$0D"'helpiconindex' - Index in .siege file of a dynamic Hel"
       "pIconX block, or default -1 to not have a help icon."$0D"============="
       "=NOTES==============================="$0D"The "$22"objective"$22" valu"
       "e specifies the objective number to complete. (Directly corresponding "
       "to the objective groups for the team in the .siege file.)"
      bbox = '-16 -16 -24 16 16 32'
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "STARTOFFRADAR"
      }
    }
    info_siege_radaricon:form =
    {
      help = "===========DESCRIPTION============================"$0D"Used to a"
       "rbitrarily display radar icons at placed location. Can be used to togg"
       "le on and off."$0D"===========KEYS&VALUES============================"$0D
       "'icon' - Icon that represents the objective on the radar."$0D"'startof"
       "f' - If 1 start off."$0D"===========MOVIE BATTLES II SPECIFIC KEYS&VAL"
       "UES==========="$0D"'radarteam' - Only show radar icon for team 1 or 2,"
       " default is 0 (all)."$0D"'helpiconindex' - Index in .siege file of a d"
       "ynamic HelpIconX block, or default -1 to not have a help icon. Note: I"
       "f startoff is 1, help icon will only show within PVS and radius will n"
       "ot work."
      bbox = '-16 -16 -24 16 16 32'
    }
    info_siege_decomplete:form =
    {
      help = "===========DESCRIPTION============================"$0D"Works sim"
       "ilar to info_siege_objective and has the same fields. But it actually "
       "sets an objective as no longer completed when used instead of completi"
       "ng it."$0D"===========KEYS&VALUES============================"$0D"'obj"
       "ective' - Specifies the objective to decomplete upon activation."$0D"'"
       "side' - Set to 1 to specify an imperial (team1) goal, 2 to specify reb"
       "els (team2)."$0D"==============NOTES==============================="$0D
       "If the objective specified is already completed when it is activated, "
       "it will just do nothing."
      bbox = '-16 -16 -24 16 16 32'
    }
    target_siege_end:form =
    {
      help = "===========DESCRIPTION============================"$0D"Do a loge"
       "xit for siege when used. You can target this entity to end the round i"
       "mmediately."$0D"==============NOTES==============================="$0D
       "You will only want to use this as the "$22"roundover_target"$22" in yo"
       "ur .siege file."$0D"Note that you do not have to target this directly,"
       " however."$0D"You can trigger an in-game cinematic-like sequence which"
       " plays out when one team wins, and then targets this once it finishes,"
       " for example."$0D"You can target this entity to end the round immediat"
       "ely. You will only want to use this as the "$22"roundover_target"$22" "
       "in your .siege file. Note that you do not have to target this directly"
       ", however. You can trigger an in-game cinematic-like sequence which pl"
       "ays out when one team wins, and then targets this once it finishes, fo"
       "r example."
      bbox = '-16 -16 -24 16 16 32'
    }
    misc_siege_item:form =
    {
      help = "===========DESCRIPTION============================"$0D"========="
       "==SPAWNFLAGS============================="$0D"STARTOFFRADAR - Start no"
       "t displaying on radar, don't display until used."$0D"ALLOWJETPACK (MOV"
       "IE BATTLES II SPECIFIC) - Can use jetpack while carrying the item."$0D
       "===========KEYS&VALUES============================"$0D"'model' - Name "
       "of model to use for the object."$0D"'mins' - Actual mins of the object"
       ". Careful not to place it into a solid, as these new mins will not be "
       "reflected visually in the editor. Default value is '-16 -16 -24'."$0D"'"
       "maxs' - Same as above for maxs. Default value is '16 16 32'."$0D"'targ"
       "etname' - If it has a targetname, it will only spawn upon being used."$0D
       "'target2' - Target to fire upon pickup. If none, nothing will happen."$0D
       "'pickuponlyonce' - If non-0, target2 will only be fired on the first p"
       "ickup. If the item is dropped and picked up again later, the target wi"
       "ll not be fired off on the sequential pickup. Default value is 1."$0D"'"
       "target3' - Target to fire upon delivery of the item to the goal point."
       " If none, nothing will happen (but you should always want something to"
       " happen)."$0D"'health' - If > 0, object can be damaged and will die on"
       "ce health reaches 0. Default is 0."$0D"'showhealth' - if health > 0, w"
       "ill show a health meter for this item."$0D"'teamowner' - Which team ow"
       "ns this item, used only for deciding what color to make health meter."$0D
       "'target4' - Target to fire upon death, if damageable. Default is none."
       $0D"'deathfx' - Effect to play on death, if damageable. Default is none"
       "."$0D"'canpickup' - If non-0, item can be picked up. Otherwise it will"
       " just be solid and sit on the ground. Default is 1."$0D"'pickupsound' "
       "- Sound to play on pickup, if any."$0D"'goaltarget' - Must be the targ"
       "etname of a trigger_multi/trigger_once. Once a player carrying this ob"
       "ject is brought inside the specified trigger, then that trigger will b"
       "e allowed to fire. Ideally it will target a siege objective or somethi"
       "ng like that."$0D"'usephysics' - If non-0, run standard physics on the"
       " object. Default is 1."$0D"'mass' - If usephysics, this will be the fa"
       "ctored object mass. Default is 0.09."$0D"'gravity' - If usephysics, th"
       "is will be the factored gravitational pull. Default is 3.0."$0D"'bounc"
       "e' - If usephysics, this will be the factored bounce amount. Default i"
       "s 1.3."$0D"'teamnotouch' - If 1 don't let team 1 pickup, if 2 don't le"
       "t team 2. By default both teams can pick this object up and carry it a"
       "round until death."$0D"'teamnocomplete' - Same values as above, but co"
       "ntrols if this object can be taken into the objective area by said tea"
       "m."$0D"'respawn' (MOVIE BATTLES II SPECIFIC) - If dropped, how long in"
       " milliseconds before the siege item should respawn (default is effecti"
       "vely infinite)."$0D"'respawnfx' - Plays this effect when respawning (e"
       ".g. it is left in an unknown area too long and goes back to the origin"
       "al spot). If this is not specified there will be no effect (expected f"
       "ormat is .efx file)."$0D"'paintarget' - Plop self on top of this guy's"
       " origin when we are used (only applies if the siege item has a targetn"
       "ame)."$0D"'noradar' - If non-0 this thing will not show up on radar."$0D
       "'forcelimit' - If non-0, while carrying this item, the carrier's force"
       " powers will be crippled."$0D"'target5' - Target to fire when respawni"
       "ng."$0D"'target6' - Target to fire when dropped by someone carrying th"
       "is item."$0D"'icon' - Icon that represents the gametype item on the ra"
       "dar."$0D"'helpiconindex' (MOVIE BATTLES II SPECIFIC) - Index in .siege"
       " file of a dynamic HelpIconX block, or default -1 to not have a help i"
       "con."$0D"=================================================="$0D"Health"
       " charge things only work with showhealth 1 on siege items that take da"
       "mage."$0D"'health_chargeamt' - If non-0 will recharge this much health"
       " every..."$0D"'health_chargerate' -     ...this many milliseconds. (10"
       "00 milliseconds = 1 second.)"$0D"==============NOTES=================="
       "============="$0D"This is used as a generic "$22"objective"$22" entity"
       ". It is pretty much fully customizable, and can be set up for numerous"
       " things like be a flag-type capture item objective, or a destroyable i"
       "tem objective."
      bbox = '-16 -16 -24 16 16 32'
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "STARTOFFRADAR"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "ALLOWJETPACK"
      }
    }
    worldspawn:form =
    {
      help = "===========DESCRIPTION============================"$0D"Every map"
       " should have exactly one worldspawn."$0D"===========KEYS&VALUES======="
       "====================="$0D"'music' - Music wav file. To play over the w"
       "orld."$0D"'gravity' - 800 is default gravity."$0D"'message' - Text to "
       "print during connection process. (usually the map name and who you are"
       ")"$0D"'_color' - Sets an ambient color for the world. (Press K to brin"
       "g up color picker.)"$0D"'_minLight' - Sets the minimum light value tha"
       "t the world architecture will have."$0D"'_minVertexLight' - Sets the m"
       "inimum light value that entities will have."$0D"'_minGridLight' - Key "
       "to set minimum grid lighting."$0D"'_lightmapscale' - Floating point va"
       "lue scaling the resolution of lightmaps on brushes/patches in this ent"
       "ity (default 1.0)."$0D"'_celshader' - Sets the cel shader used for thi"
       "s geometry. Note: omit the 'textures/' prefix."$0D"BSP Options:"$0D"'g"
       "ridsize' - Size of lighting grid to 'X Y Z'. default='64 64 128'."$0D"'"
       "_blocksize' - q3map always splits the BSP tree along the planes X=bloc"
       "ksize*n and Y=_blocksize*n. Default _blocksize value is 1024. Increase"
       " the _blocksize using larger powers of 2 to reduce compile times on ve"
       "ry large maps with low structural brush density."$0D"'ambient' - Scale"
       " of global light (from _color)."$0D"'fog' - Shader name of the global "
       "fog texture - must include the full path, such as 'textures/rj/fog1'."$0D
       "'distancecull' - Value for vis for the maximum viewing distance."$0D"'"
       "chopsize' - Value for bsp on the maximum polygon / portal size."$0D"'l"
       "s_Xr' - Override lightstyle X with this pattern for Red."$0D"'ls_Xg' -"
       " Green (valid patterns are 'a-z')."$0D"'ls_Xb' - Blue (a is OFF, z is "
       "ON)."$0D"'fogstart' - Override fog start distance and force linear."$0D
       "'radarrange' - For Siege/Vehicle radar - default range is 2500."$0D"=="
       "=========MOVIE BATTLES II SPECIFIC KEYS&VALUES==========="$0D"'outside"
       "Bias' - This must be set to 1 if your map has weather effects in it."$0D
       "'coldWorld' - Defaults to 0. If you set this to 1, all areas of your m"
       "ap, inside or outside, will be treated as if they're atmospherically c"
       "old."$0D"-------- tintLiquid --------"$0D"==Description=="$0D"'Custom'"
       " - Set to 1 in order to use the rest of the variables for the liquid t"
       "ype in question. If you use this. all of the variables need to be set,"
       " or will default to 0.0. The defaults listed below are for when Custom"
       " is 0, or the natural tint of each liquid."$0D"'Amplitude' - Liquid ti"
       "nts waver back and forth between levels of transparency. Amplitude con"
       "trols by how much. (The wavelength is hardcoded at 0.4 seconds and cor"
       "responds to the wavelength of the view-distortion that also occurs whe"
       "n looking through a liquid.)"$0D"'Offset' - This allows the center or "
       "baseline of the wave(Which maxes out at 1.0 and bottoms out at 0.0) to"
       " be adjusted higher or lower, weighting the amplitude of the wave towa"
       "rds one end or the other of the scale."$0D"'R' - The red component of "
       "the liquid's tint. Between 0.0 and 1.0."$0D"'G' - The green component "
       "of the liquid's tint. Between 0.0 and 1.0."$0D"'B' - The blue componen"
       "t of the liquid's tint. Between 0.0 and 1.0."$0D"==Complete List=="$0D
       "Lava"$0D"'tintLavaCustom' - Default 0"$0D"'tintLavaAmplitude' - Defaul"
       "t 0.15"$0D"'tintLavaOffset' - Default 0.5"$0D"'tintLavaR' - Default 0."
       "7"$0D"'tintLavaG' - Default 0.0"$0D"'tintLavaB' - Default 0.0"$0D"Slim"
       "e"$0D"'tintSlimeCustom' - Default 0"$0D"'tintSlimeAmplitude' - Default"
       " 0.1"$0D"'tintSlimeOffset' - Default 0.4"$0D"'tintSlimeR' - Default 0."
       "0"$0D"'tintSlimeG' - Default 0.7"$0D"'tintSlimeB' - Default 0.0"$0D"Wa"
       "ter"$0D"'tintWaterCustom' - Default 0"$0D"'tintWaterAmplitude' - Defau"
       "lt 0.05"$0D"'tintWaterOffset' - Default 0.3"$0D"'tintWaterR' - Default"
       " 0.0"$0D"'tintWaterG' - Default 0.2"$0D"'tintWaterB' - Default 0.8"$0D
       "-------- customLiquid --------"$0D"==Description=="$0D"'Splash' - Play"
       "ed when someone jumps into a liquid."$0D"'MissileSplash' - Played when"
       " gunfire hits a liquid's surface."$0D"'Boil' - Played when something h"
       "ot strikes a liquid's surface."$0D"'BoilBubble' - Played when somethin"
       "g hot lingers inside liquid, below the surface."$0D"'Drown' - Played w"
       "hen someone starts drowning in a liquid, or otherwise breathes while i"
       "n liquid."$0D"==Complete List=="$0D"Lava"$0D"'customLavaSplash' - Defa"
       "ult "$22"env/acid_splash"$220D"'customLavaMissileSplash' - Default "$22
       "env/acid_splash_missile"$220D"'customLavaBoil' - Default "$22"saber/la"
       "va_boil_nosnd.efx"$220D"'customLavaBoilBubble' - Default "$22"saber/la"
       "va_boilbubble_nosnd.efx"$220D"'customLavaDrown' - Default "$22"misc/la"
       "vabreath.efx"$220D"Slime"$0D"'customSlimeSplash' - Default "$22"env/la"
       "va_splash"$220D"'customSlimeMissileSplash' - Default "$22"env/lava_spl"
       "ash_missile"$220D"'customSlimeBoil' - Default "$22"saber/acid_boil_nos"
       "nd.efx"$220D"'customSlimeBoilBubble' - Default "$22"saber/acid_boilbub"
       "ble_nosnd.efx"$220D"'customSlimeDrown' - Default "$22"misc/acidbreath."
       "efx"$220D"Water"$0D"'customWaterSplash' - Default "$22"env/water_impac"
       "t"$220D"'customWaterMissileSplash' - Default "$22"env/water_splash_mis"
       "sile"$220D"'customWaterBoil' - Default "$22"saber/water_boil_nosnd.efx"
       $220D"'customWaterBoilBubble' - Default "$22"saber/water_boilbubble_nos"
       "nd.efx"$220D"'customWaterDrown' - Default "$22"misc/waterbreath.efx"$22
       $0D"==============NOTES==============================="$0D"This is what"
       " ever brush made becomes when made. Any key applied to one effects all"
       " others unless you make them a func_group."$0D"As far as I know, _minV"
       "ertexLight and _minGridLight should be paired in your worldspawn. If y"
       "ou use one you should use the other."$0D"For the music key, make sure "
       "you include the music folder in the value, such as"$0D"key: music"$0D"v"
       "alue: music/mp/mp_action3.mp3"
      sep: =
      {
        txt = "-------- customLiquid --------"
        typ = "S"
      }
      key: =
      {
        txt = "&"
        hint = "music"
      }
      value: =
      {
        txt = "&"
        hint = "music/mp/mp_action3.mp3"
      }
    }
    target_give:form =
    {
      help = "===========DESCRIPTION============================"$0D"Gives the"
       " activator all the items pointed to."$0D"===========KEYS&VALUES======="
       "====================="$0D"'target' - Entity to be given."$0D"'targetna"
       "me' - Entity to give items to."
      bbox = '-8 -8 -8 8 8 8'
    }
    target_remove_powerups:form =
    {
      help = "===========DESCRIPTION============================"$0D"Takes awa"
       "y all the activators powerups."$0D"Used to drop flight powerups into d"
       "eath pits."
      bbox = '-8 -8 -8 8 8 8'
    }
    target_conquest:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"Represents the conqu"
       "est objective type."$0D"===========KEYS&VALUES========================"
       "===="$0D"'delay' - The delay before firing of this entitie's targets."$0D
       "'target' - The target to fire upon completion of all of team1's object"
       "ives."$0D"'num1' - The number of team1's objectives to complete before"
       " firing target."$0D"'target2' - The target to fire upon completion of "
       "all of team2's objectives."$0D"'num2' - The number of team2's objectiv"
       "es to complete before firing target2."$0D"==============NOTES========="
       "======================"$0D"At most one target_conquest may be defined "
       "per map. The existance of a target_conquest draws a special hud on the"
       " players' screen to track the progress of the conquest objective. At m"
       "ost 15 triggers may affect each team's conquest display."
      bbox = '-8 -8 -8 8 8 8'
    }
    target_delay:form =
    {
      help = "===========DESCRIPTION============================"$0D"Entity us"
       "ed to cause a delay between a trigger and a target. (Something sends a"
       " signal, it gets to this, and it waits this amount of time, then fires"
       " its target.)"$0D"===========SPAWNFLAGS============================="$0D
       "NO_RETRIGGER - Keeps the delay from resetting the time if it is activa"
       "ted again while it is counting down to an event."$0D"===========MOVIE "
       "BATTLES II SPECIFIC SPAWNFLAGS==========="$0D"USE_TEAM_DELAY_WIN - For"
       " use in conjunction (targeted at) info_siege_Objective. When Team A (o"
       "r B Depending on the siege obj) there is a delay on ending the round. "
       "With this flag, even if one or the other team dies, the team that does"
       " their objective wins."$0D"UI_COUNTDOWN - Displays a count down and me"
       "ssage on the clients' hud. A Maximum of two can be running in a single"
       " instance."$0D"===========KEYS&VALUES============================"$0D"'"
       "wait' - Seconds to pause before firing targets."$0D"'random' - Delay v"
       "ariance, total delay = delay +/- random seconds."$0D"'message' (MOVIE "
       "BATTLES II SPECIFIC) - the message to display if UI_COUNTDOWN is true."
      bbox = '-8 -8 -8 8 8 8'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "NO_RETRIGGER"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "USE_TEAM_DELAY_WIN"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "UI_COUNTDOWN"
      }
    }
    target_score:form =
    {
      help = "===========DESCRIPTION============================"$0D"The activ"
       "ator is given this many points."$0D"===========KEYS&VALUES============"
       "================"$0D"'count' - Number of points to add, default 1."
      bbox = '-8 -8 -8 8 8 8'
    }
    target_print:form =
    {
      help = "===========DESCRIPTION============================"$0D"Creates a"
       " center screen message."$0D"===========SPAWNFLAGS====================="
       "========"$0D"REDTEAM - Red team only receives this message."$0D"BLUETE"
       "AM - Blue team only receives this message."$0D"PRIVATE - Only the acti"
       "vator gets the message."$0D"===========KEYS&VALUES===================="
       "========"$0D"'message' - Text to print"$0D"'wait' - Don't fire off aga"
       "in if triggered within this many milliseconds ago. (1000 milliseconds "
       "= 1 second.)"$0D"==============NOTES==============================="$0D
       "If no spawnflags are used, all clients get the message."$0D"Color can "
       "also be used in text."$0D"Example:"$0D"Key:message"$0D"Value:^4Hi"$0D"W"
       "ould show message:"$0D"Hi (in blue tho)"
      bbox = '-8 -8 -8 8 8 8'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "REDTEAM"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "BLUETEAM"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "PRIVATE"
      }
    }
    target_speaker:form =
    {
      help = "===========DESCRIPTION============================"$0D"A sound p"
       "roducing entity."$0D"===========SPAWNFLAGS============================"
       "="$0D"LOOPED-ON - Loops the sound but starts on."$0D"LOOPED-OFF - Loop"
       "s the sound but starts off."$0D"GLOBAL - A global sound will play full"
       " volume throughout the level."$0D"ACTIVATOR -  Sounds will play on the"
       " player that activated the target."$0D"===========KEYS&VALUES========="
       "==================="$0D"'noise' - Sound file to play. (Directory/locat"
       "ion of file.)"$0D"'wait' - Seconds between auto triggerings, 0 = don't"
       " auto trigger."$0D"'random' - Wait variance, default is 0."$0D"'volume"
       "' - Allows variance of the volume of the speaker, default is 255 (limi"
       "t is 65535, but digital distortion will cut in long before then)."$0D"'"
       "volRange' - a low number and a high number to set when you are at the "
       "farthest from it the min volume that it will come to the player at. Th"
       "e high is for when your closest to it how loud it would be."$0D"'radiu"
       "s' - Radius of attenuation. In map units."$0D"==============NOTES====="
       "=========================="$0D"Global and activator sounds can't be co"
       "mbined with looping."$0D"Looped sounds will be toggled by use function"
       "s."$0D"Multiple identical looping sounds will just increase volume wit"
       "hout any speed cost. (The more target_speaker you have set the same th"
       "e louder the volume will be.)"
      bbox = '-8 -8 -8 8 8 8'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "LOOPED-ON"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "LOOPED-OFF"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "GLOBAL"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "ACTIVATOR"
      }
    }
    target_flash:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"Using this entity wi"
       "ll generate a flash that covers all players' screens."$0D"===========S"
       "PAWNFLAGS============================="$0D"REVERSED - the end colour i"
       "s opaque and the start colour is transparent."$0D"===========KEYS&VALU"
       "ES============================"$0D"'startC' - Starting colour (RR GG B"
       "B ex. 255 0 0 = red, 0 255 255 = yelow)."$0D"'endC' - Ending colour (R"
       "R GG BB)."$0D"'radius' - Radius of effect (ex. 100.4)."$0D"'wait' - Du"
       "ration of the flash (in milliseconds)."
      bbox = '-8 -8 -8 8 8 8'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "REVERSED"
      }
    }
    target_gravity:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"The target_gravity e"
       "ntity allows for changes to the gravity of a map."$0D"===========KEYS&"
       "VALUES============================"$0D"'gravity' - value of gravity (d"
       "efault is 800)"$0D"===========NOTES=================================="$0D
       "Try to avoid using target_gravity very often:"$0D"There's a built-in r"
       "ate limit of one change per second; a large number of changes in a sho"
       "rt period of time can create an extensive amount of lag, and possibly "
       "cause crashes. Mappers should avoid situations where two or more targe"
       "t_gravity entities are "$22"fighting"$22" over what the gravity should"
       " be set to in a map."$0D"target_gravity only activates its targets if "
       "an actual gravity change has occurred: repeatedly activating the same "
       "target_gravity will not keep activating targets, gravity needs to actu"
       "ally change before it will be activated."
      bbox = '-8 -8 -8 8 8 8'
    }
    target_screenshake:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"Using this entity wi"
       "ll shake the camera."$0D"===========KEYS&VALUES======================="
       "====="$0D"'globalshake' - Set this to 1 to make the shake happen to ev"
       "ery client equally, not to whoever's close to it."$0D"'duration' - The"
       " duration of the shake in milliseconds."$0D"'intensity' - A low value "
       "like 3 will cause a gentle rumble. A value of 40 or greater will produ"
       "ce an earthquake."
      bbox = '-4 -4 -4 4 4 4'
    }
    target_laser:form =
    {
      help = "===========DESCRIPTION============================"$0D"When trig"
       "gered, fires a laser.  You can either set a target or a direction."$0D
       "===========SPAWNFLAGS============================="$0D"START_ON - Spaw"
       "ns with world shooting."$0D"==============NOTES======================="
       "========"$0D"Aim at a target_position or something like that."
      bbox = '-8 -8 -8 8 8 8'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "START_ON"
      }
    }
    target_teleporter:form =
    {
      help = "===========DESCRIPTION============================"$0D"The activ"
       "ator will be teleported away."$0D"==============NOTES================="
       "=============="$0D"Use misc_teleporter_dest instead of this because di"
       "rection activator faces can be specified when destination is reached."
      bbox = '-8 -8 -8 8 8 8'
    }
    target_relay:form =
    {
      help = "===========DESCRIPTION============================"$0D"This does"
       "n't perform any actions except fire its targets."$0D"===========SPAWNF"
       "LAGS============================="$0D"RED_ONLY - Forced by red team on"
       "ly."$0D"BLUE_ONLY - Forced by blue team only."$0D"RANDOM - Only one of"
       " the targets will be fired, not all of them. (When pointing at several"
       " targets.)"$0D"INACTIVE - Can't be used until activated. (Must use a t"
       "arget_activate entity.)"$0D"===========KEYS&VALUES===================="
       "========"$0D"'wait' - Number of seconds to wait before it can be fired"
       " again. Set to -1 to use it only once."$0D"==============NOTES========"
       "======================="$0D"This entity is especially handy in trigger"
       "ing something that may need another target name to prevent an entity f"
       "rom using its self or allowing to distance targetname and target value"
       "s. Basically allow for more complex entity linking and chains."
      bbox = '-8 -8 -8 8 8 8'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "RED_ONLY"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "BLUE_ONLY"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "RANDOM"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
    }
    target_kill:form =
    {
      help = "===========DESCRIPTION============================"$0D"Kills the"
       " activator."
      bbox = '-8 -8 -8 8 8 8'
    }
    target_position:form =
    {
      help = "===========DESCRIPTION============================"$0D"Used as a"
       " positional target for in-game calculation, like jumppad targets."
      bbox = '-4 -4 -4 4 4 4'
    }
    target_location:form =
    {
      help = "===========DESCRIPTION============================"$0D"Closest t"
       "arget_location in sight used for the location, if none in sight, close"
       "st in distance."$0D"===========KEYS&VALUES============================"
       $0D"'message' - To the name of this location."$0D"'count' - Use 0-7 for"
       " color."$0D"0:white 1:red 2:green 3:yellow 4:blue 5:cyan 6:magenta 7:w"
       "hite"
      bbox = '-8 -8 -8 8 8 8'
    }
    target_counter:form =
    {
      help = "===========DESCRIPTION============================"$0D"Acts as a"
       "n intermediary for an action that takes multiple inputs."$0D"========="
       "==SPAWNFLAGS============================="$0D"INACTIVE - Can't be used"
       " until activated. (Must use a target_activate entity.)"$0D"==========="
       "KEYS&VALUES============================"$0D"'count' - After the counte"
       "r has been triggered 'count' times (default 2), it will fire all of it"
       "'s targets and remove itself."$0D"'target2' - What the counter should "
       "fire each time it's incremented and does NOT reach it's count."$0D"'bo"
       "unceCount' - Number of times the counter should reset to it's full cou"
       "nt when it's done."
      bbox = '-4 -4 -4 4 4 4'
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
    }
    target_random:form =
    {
      help = "===========DESCRIPTION============================"$0D"Randomly "
       "fires off only one of it's targets each time used."$0D"===========SPAW"
       "NFLAGS============================="$0D"USEONCE - If set will never fi"
       "re again."
      bbox = '-4 -4 -4 4 4 4'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "USEONCE"
      }
    }
    target_scriptrunner:form =
    {
      help = "===========DESCRIPTION============================"$0D"Triggers "
       "a script to run."$0D"===========SPAWNFLAGS============================"
       "="$0D"RUNONACTIVATOR - Will run the script on the entity that used thi"
       "s or tripped the trigger that used this"$0D"INACTIVE - Start off"$0D"="
       "==========KEYS&VALUES============================"$0D"'usescript' - Sc"
       "ript to run when used."$0D"'count' - How many times to run, -1 = infin"
       "ite.  Default is once. (Dont forget this one .. it has caused me many "
       "a quizzical look.)"$0D"'wait' - Can't be used again in this amount of "
       "seconds. (Default is 1 second if it's multiple-use.)"$0D"'delay' - How"
       " long to wait after use to run script."$0D"==============NOTES========"
       "======================="$0D"Default script location is the "$22"script"
       "s"$22" folder, so type scriptname or subfolder of script folder then s"
       "criptname."$0D"Example:"$0D"If your script is in the folder "$22"scrip"
       "ts\chamber"$22", then you would use:"$0D"Key: usescript"$0D"Value: cha"
       "mber/scriptname"
      bbox = '-4 -4 -4 4 4 4'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "RUNONACTIVATOR"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
    }
    target_activate:form =
    {
      help = "===========DESCRIPTION============================"$0D"Will set "
       "the target(s) to be usable/triggerable."
      bbox = '-4 -4 -4 4 4 4'
    }
    target_deactivate:form =
    {
      help = "===========DESCRIPTION==========================="$0D"Will set t"
       "he target(s) to be non-usable/triggerable."
      bbox = '-4 -4 -4 4 4 4'
    }
    target_level_change:form =
    {
      help = "===========DESCRIPTION============================"$0D"Causes ma"
       "p to change to another."$0D"===========KEYS&VALUES===================="
       "========"$0D"'mapname' - Name of map to change to."
      bbox = '-4 -4 -4 4 4 4'
    }
    target_play_music:form =
    {
      help = "===========DESCRIPTION============================"$0D"Plays the"
       " requested music files when this target is used."$0D"===========KEYS&V"
       "ALUES============================"$0D"'music'    - music WAV or MP3 fi"
       "le ( music/introfile.mp3 [optional]  music/loopfile.mp3 )"$0D"========"
       "======NOTES==============================="$0D"If an intro file and lo"
       "op file are specified, the intro plays first, then the looping portion"
       " will start and loop indefinitely.  If no introfile is entered, only t"
       "he loopfile will play."
      bbox = '-4 -4 -4 4 4 4'
    }
    target_weather:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"CURRE"
       "NTLY DISABLED IN MBII (NOT YET COMPLETE)"$0D"===========DESCRIPTION==="
       "========================="$0D"The target_weather entity allows for cha"
       "nges to the weather of a map."$0D"===========SPAWNFLAGS==============="
       "=============="$0D"CLEAR - Will pass WFX_CLEAR before attempting to se"
       "t weather. This avoids the need to trigger target_weather twice in ord"
       "er to change to completely different weather. Triggering target_weathe"
       "r without this spawnflag will add the new weather to any existing weat"
       "her."$0D"===========KEYS&VALUES============================"$0D"'weath"
       "erFX' - See reference for fx_weather"$0D"'repeatFX' - See reference fo"
       "r fx_weather"$0D"'count' - See reference for fx_weather"$0D"'dmg' - Se"
       "e reference for fx_weather"$0D"==============NOTES===================="
       "==========="$0D"After weather has been set, target_weather will activa"
       "te its targets. Whether or not any weather has actually changed."
      bbox = '-16 -16 -16 16 16 16'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "CLEAR"
      }
    }
    team_CTF_redplayer:form =
    {
      help = "===========DESCRIPTION============================"$0D"Only in C"
       "TF games.  Red players spawn here at game start."
      bbox = '-16 -16 -16 16 16 32'
    }
    team_CTF_blueplayer:form =
    {
      help = "===========DESCRIPTION============================"$0D"Only in C"
       "TF games.  Blue players spawn here at game start."
      bbox = '-16 -16 -16 16 16 32'
    }
    team_CTF_redspawn:form =
    {
      help = "===========DESCRIPTION============================"$0D"Potential"
       " spawning position for red team in CTF games."$0D"===========KEYS&VALU"
       "ES============================"$0D"'target' - Will be fired when someo"
       "ne spawns in on them."
      bbox = '-16 -16 -24 16 16 32'
    }
    team_CTF_bluespawn:form =
    {
      help = "===========DESCRIPTION============================"$0D"Potential"
       " spawning position for blue team in CTF games."$0D"===========KEYS&VAL"
       "UES============================"$0D"'target' - Will be fired when some"
       "one spawns in on them."
      bbox = '-16 -16 -24 16 16 32'
    }
    trigger_capture:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"Variable sized singl"
       "e use trigger."$0D"===========SPAWNFLAGS============================="$0D
       "FORGETFULL - If every member of a team that is currently capturing thi"
       "s trigger dies/leaves, the trigger resets to 0 at 1/2 the timeframe va"
       "lue of the usetime capture time."$0D"FORGETFULL_INSTANT - If every mem"
       "ber of a team that is currently capturing this trigger dies/leaves, th"
       "e trigger resets to 0 instantly"$0D"START_TEAM_1 - Automatically start"
       "s as captured by team 1"$0D"START_TEAM_2 - Automatically starts as cap"
       "tured by team 1"$0D"NO_BLOCKING - A single player cannot completely bl"
       "ock capture by the other team"$0D"RATE_LINEAR - Capture rate scales li"
       "nearly based on #players - #enemies"$0D"RATE_FIXED - Capture rate is i"
       "ndependent of #players"$0D"INACTIVE - Start off, has to be activated t"
       "o be touchable/usable"$0D"NO_NEUTRAL - Skips neutral capture stage and"
       " only toggles between team 1 and team 2"$0D"MULTIPLE - multiple entiti"
       "es can touch this trigger in a single frame *and* if needed, the trigg"
       "er can have a wait of > 0"$0D"===========KEYS&VALUES=================="
       "=========="$0D"'wait' - Seconds between triggerings, 0 default, number"
       " < 0 means one time only."$0D"'random' - Wait variance, default is 0."$0D
       "'delay' - How many seconds to wait to fire targets after tripped."$0D"'"
       "target2' - Target at associated misc_hologram to indicate capture stat"
       "e."$0D"'speed' - How many seconds to wait to fire the target2, default"
       " is 1."$0D"'noise' - Sound to play when the trigger fires (plays at ac"
       "tivator's origin)."$0D"'NPC_targetname' - Only the NPC with this NPC_t"
       "argetname fires this trigger."$0D"'min_num' - If non-0, a team must ha"
       "ve at least min_num of players in the trigger to capture it."$0D"'team"
       "' - If set, only this team can trip this trigger."$0D"0 - any"$0D"1 - "
       "red"$0D"2 - blue"$0D"'soundSet' - Ambient sound set to play when this "
       "trigger is activated."$0D"'usetime' - The total capture time in ms for"
       " a single client in range to capture the trigger and cause it to fire."
       $0D"'teamuser' - If 1, team 2 can't use this. If 2, team 1 can't use th"
       "is."$0D"'siegetrig' - If non-0, can only be activated by players carry"
       "ing a misc_siege_item which is associated with this trigger by the ite"
       "m's goaltarget value."$0D"'idealclass' - Can only be used by this clas"
       "s/these classes. You can specify use by multiple classes with the use "
       "of, e.g.: 'Imperial Medic|Imperial Assassin|Imperial Demolitionist'"$0D
       "'teambalance' - If non-0, is "$22"owned"$22" by the last team that act"
       "ivated. Can only be activated by the other team if the number of playe"
       "rs on the other team inside the trigger outnumber the number of player"
       "s on the owning team inside the trigger."$0D"'target3' - Fire when act"
       "ivated by team 1."$0D"'target4' - Fire when activated by team 2."$0D"'"
       "min_players' - Minimum player count required in-round for this trigger"
       " to be useable."$0D"'max_players' - Maximum player count in-round for "
       "this trigger to be useable."
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "FORGETFULL"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "FORGETFULL_INSTANT"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "START_TEAM_1"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "START_TEAM_2"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "NO_BLOCKING"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X32"
        cap = "RATE_LINEAR"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "RATE_FIXED"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X256"
        cap = "NO_NEUTRAL"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X512"
        cap = "MULTIPLE"
      }
    }
    trigger_multiple:form =
    {
      help = "===========DESCRIPTION============================"$0D"Variable "
       "sized repeatable trigger."$0D"===========SPAWNFLAGS==================="
       "=========="$0D"CLIENTONLY - Only a player can trigger this by touch."$0D
       "FACING - Won't fire unless triggering entity's view angles are within "
       "45 degrees of trigger's angles (in addition to any other conditions)."$0D
       "USE_BUTTON - Won't fire unless player is in it and pressing use button"
       " (in addition to any other conditions)."$0D"FIRE_BUTTON - Won't fire u"
       "nless player/NPC is in it and pressing fire button (in addition to any"
       " other conditions)."$0D"NPCONLY - Only non-player NPCs can trigger thi"
       "s by touch (including vehicles / droidekas)."$0D"INACTIVE - Start off,"
       " has to be activated to be touchable/usable."$0D"MULTIPLE - Multiple e"
       "ntities can touch this trigger in a single frame *and* if needed, the "
       "trigger can have a wait of > 0."$0D"===========KEYS&VALUES============"
       "================"$0D"'wait' - Seconds between triggering, 0 default, n"
       "umber < 0 means one time only."$0D"'random' - Wait variance, default i"
       "s 0."$0D"'delay' - How many seconds to wait to fire targets after trip"
       "ped."$0D"'hiderange' - As long as NPC's head is in this trigger, NPCs "
       "out of this hiderange cannot see him.  If you set an angle on the trig"
       "ger, they're only hidden from enemies looking in that direction. The p"
       "layer's crouch viewheight is 36, his standing viewheight is 54. So a t"
       "rigger that should hide you when crouched but not standing should be 4"
       "8 tall."$0D"'target2' - The trigger will fire this only when the trigg"
       "er has been activated and subsequently 'cleared'( once any of the cond"
       "itions on the trigger have not been satisfied).  This will not fire th"
       "e 'target' more than once until the 'target2' is fired (trigger field "
       "is 'cleared')."$0D"'speed' - How many seconds to wait to fire the targ"
       "et2, default is 1."$0D"'noise' - Sound to play when the trigger fires "
       "(plays at activator's origin)."$0D"'NPC_targetname' - Only the NPC wit"
       "h this NPC_targetname fires this trigger."$0D"'team' - If set, only th"
       "is team can trip this trigger."$0D"0 - any"$0D"1 - red"$0D"2 - blue"$0D
       "'soundSet' - Ambient sound set to play when this trigger is activated"$0D
       "'usetime' - If specified (in milliseconds) along with the USE_BUTTON f"
       "lag, will require a client to hold the use key for x amount of ms befo"
       "re firing."$0D"'script_targetname' - Referred to by script as the reci"
       "pient of set of instructions. Most entities can use this key."$0D"===="
       "=======MOVIE BATTLES II SPECIFIC KEYS&VALUES==========="$0D"'min_playe"
       "rs' - Minimum player count required in-round for this trigger to be us"
       "eable."$0D"'max_players' - Maximum player count in-round for this trig"
       "ger to be useable."$0D"'nopush' - How many seconds activator of trigge"
       "r should be immune to force push and pull."$0D"'doorTrigger' - Set to "
       "1 to allow spectators to teleport to the other side of a closed door. "
       "Trigger must directly target func_door and should exist on both sides "
       "of the door, the same as automatic door triggers."$0D"================"
       "=================================="$0D"Applicable only during Siege ga"
       "metype:"$0D"'teamuser' - If 1, team 2 can't use this. If 2, team 1 can"
       "'t use this."$0D"'siegetrig' - If non-0, can only be activated by play"
       "ers carrying a misc_siege_item which is associated with this trigger b"
       "y the item's goaltarget value."$0D"'teambalance' - If non-0, is 'owned"
       "' by the last team that activated. Can only be activated by the other "
       "team if the number of players on the other team inside the trigger out"
       "number the number of players on the owning team inside the trigger."$0D
       "'target3' - Fire when activated by team1."$0D"'target4' - Fire when ac"
       "tivated by team2."$0D"'idealclass' - Can only be used by this class/th"
       "ese classes. You can specify use by multiple classes with the use of, "
       "e.g.: 'Imperial Medic|Imperial Assassin|Imperial Demolitionist'"$0D"=="
       "============NOTES==============================="$0D"Must be targeted "
       "at one or more entities."$0D"The basic time between firing is a random"
       " time between (wait - random) and (wait + random)"
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "CLIENTONLY"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "FACING"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "USE_BUTTON"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "FIRE_BUTTON"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "NPCONLY"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X256"
        cap = "MULTIPLE"
      }
    }
    trigger_once:form =
    {
      help = "===========DESCRIPTION============================"$0D"Variable "
       "sized single use trigger."$0D"===========SPAWNFLAGS==================="
       "=========="$0D"CLIENTONLY - only a player can trigger this by touch"$0D
       "FACING - Won't fire unless triggering entity's view angles are within "
       "45 degrees of trigger's angles (in addition to any other conditions)"$0D
       "USE_BUTTON - Won't fire unless player is in it and pressing use button"
       " (in addition to any other conditions)"$0D"FIRE_BUTTON - Won't fire un"
       "less player/NPC is in it and pressing fire button (in addition to any "
       "other conditions)"$0D"NPCONLY - Only non-player NPCs can trigger this "
       "by touch (including vehicles / droidekas)."$0D"INACTIVE - Start off, h"
       "as to be activated to be touchable/usable."$0D"MULTIPLE - multiple ent"
       "ities can touch this trigger in a single frame *and* if needed, the tr"
       "igger can have a wait of > 0"$0D"===========KEYS&VALUES==============="
       "============="$0D"'random' - Wait variance, default is 0."$0D"'delay' "
       "- How many seconds to wait to fire targets after tripped."$0D"'noise' "
       "- Sound to play when the trigger fires (plays at activator's origin)."$0D
       "'NPC_targetname' - Only the NPC with this NPC_targetname fires this tr"
       "igger."$0D"'team' - If set, only this team can trip this trigger."$0D"0"
       " - any"$0D"1 - red"$0D"2 - blue"$0D"'soundSet' - Ambient sound set to "
       "play when this trigger is activated"$0D"'usetime' - If specified (in m"
       "illiseconds) along with the USE_BUTTON flag, will require a client to "
       "hold the use key for x amount of ms before firing."$0D"===========MOVI"
       "E BATTLES II SPECIFIC KEYS&VALUES==========="$0D"'min_players' - Minim"
       "um player count required in-round for this trigger to be useable."$0D"'"
       "max_players' - Maximum player count in-round for this trigger to be us"
       "eable."$0D"=================================================="$0D"Appl"
       "icable only during Siege gametype:"$0D"'teamuser' - If 1, team 2 can't"
       " use this. If 2, team 1 can't use this."$0D"'siegetrig' - If non-0, ca"
       "n only be activated by players carrying a misc_siege_item which is ass"
       "ociated with this trigger by the item's goaltarget value."$0D"'idealcl"
       "ass' - Can only be used by this class/these classes. You can specify u"
       "se by multiple classes with the use of, e.g.: 'Imperial Medic|Imperial"
       " Assassin|Imperial Demolitionist'"$0D"==============NOTES============="
       "=================="$0D"Must be targeted at one or more entities."$0D"B"
       "asic time between firing is a random time between (wait - random) and "
       "(wait + random)"
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "CLIENTONLY"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "FACING"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "USE_BUTTON"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "FIRE_BUTTON"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "NPCONLY"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X256"
        cap = "MULTIPLE"
      }
    }
    trigger_lightningstrike:form =
    {
      help = "===========DESCRIPTION============================"$0D"Calls a s"
       "trike of lightining."$0D"===========SPAWNFLAGS========================"
       "====="$0D"START_OFF - start trigger disabled use to toggle on and off"$0D
       "===========KEYS&VALUES============================"$0D"'lightningfx' -"
       " Effect to use for lightning, MUST be specified"$0D"'wait' - Seconds b"
       "etween strikes, 1000 default"$0D"'random' - Wait variance, default is "
       "2000 (milliseconds)"$0D"'dmg' - Damage on strike (default 50)"$0D"'rad"
       "ius' - If non-0, does a radius damage at the lightning strike impact p"
       "oint (using this value as the radius). otherwise will only do line tra"
       "ce damage. default 0."$0D"==============NOTES========================="
       "======"$0D"Cover the entire area you want lightning to rain down from "
       "in a trigger brush, then make it into a trigger_lightningstrike. Use k"
       "ey :lightningfx and value :effects/env/huge_lightning.efx (as an examp"
       "le ) add a wait value ( in milliseconds ) and a random value."
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "START_OFF"
      }
    }
    trigger_always:form =
    {
      help = "===========DESCRIPTION============================"$0D"This trig"
       "ger will always fire.  It is activated by the world. (When the map sta"
       "rts this fires.)"
      bbox = '-8 -8 -8 8 8 8'
    }
    trigger_push:form =
    {
      help = "===========DESCRIPTION============================"$0D"Forces th"
       "e player in predetermined direction. This will be client side predicte"
       "d, unlike target_push."$0D"===========SPAWNFLAGS======================"
       "======="$0D"LINEAR - Instead of tossing the client at the target_posit"
       "ion, it will push them towards it. NOT predicted by clients."$0D"RELAT"
       "IVE - Instead of pushing you in a direction that is always from the ce"
       "nter of the trigger to the target_position, it pushes *you* toward the"
       " target position, relative to your current location (can use with 'spe"
       "ed'... if don't set a speed, it will use the distance from you to the "
       "target_position)."$0D"INACTIVE - Not active until targeted by a target"
       "_activate."$0D"MULTIPLE - Multiple entities can touch this trigger in "
       "a single frame *and* if needed, the trigger can have a wait of > 0."$0D
       "===========KEYS&VALUES============================"$0D"'wait' - How lo"
       "ng to wait between pushes: -1 = push only once."$0D"'speed' - Pushes t"
       "he client toward the position at this speed (default is 1000)."$0D"'te"
       "am' - If set, only this team can trip this trigger."$0D"0 - any"$0D"1 "
       "- red"$0D"2 - blue"$0D"==============NOTES============================"
       "==="$0D"Must point at a target_position, which will be the apex of the"
       " leap."$0D"When using this as a bouncepad, do NOT check either the LIN"
       "EAR or RELATIVE spawnflags."
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "LINEAR"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "RELATIVE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X256"
        cap = "MULTIPLE"
      }
    }
    target_push:form =
    {
      help = "===========DESCRIPTION============================"$0D"Pushes th"
       "e activator in the direction of angle, or towards a target apex."$0D"="
       "==========SPAWNFLAGS============================="$0D"BOUNCEPAD -  Pla"
       "ys bounce noise instead of none."$0D"CONSTANT _ Will push activator in"
       " direction of 'target' at constant 'speed'."$0D"===========KEYS&VALUES"
       "============================"$0D"'speed' - Defaults to 1000."$0D"'targ"
       "et' - Entity to aim at. (target_position, target_location)"$0D"'target"
       "name' - Entities with matching target will fire it."$0D"=============="
       "NOTES==============================="$0D"Needs to be linked from a tri"
       "gger_multiple to a target_position or target_location."
      bbox = '-8 -8 -8 8 8 8'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "BOUNCEPAD"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "CONSTANT"
      }
    }
    trigger_teleport:form =
    {
      help = "===========DESCRIPTION============================"$0D"Allows cl"
       "ient side prediction of teleportation events."$0D"===========SPAWNFLAG"
       "S============================="$0D"SPECTATOR - If spectator is set, on"
       "ly spectators can use this teleport Spectator teleporters are not norm"
       "ally placed in the editor, but are created automatically near doors to"
       " allow spectators to move through them."$0D"==============NOTES======="
       "========================"$0D"Must point at a target_position or misc_t"
       "eleporter_dest, which will be the teleport destination."$0D"Best to us"
       "e misc_teleporter_dest because direction activator faces can be specif"
       "ied when destination is reached."
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "SPECTATOR"
      }
    }
    trigger_heal:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"Any entity that touc"
       "hes this will be healed."$0D"===========SPAWNFLAGS===================="
       "========="$0D"START_OFF - Starts off. Does not injure until triggered."
       $0D"CAN_TARGET - If you target it, it will toggle on and off."$0D"SILEN"
       "T - Suppresses playing the sound."$0D"SLOW - Changes the damage rate t"
       "o once per second."$0D"===========KEYS&VALUES========================="
       "==="$0D"'team' - Team (1 or 2) to allow healing (if none then heal any"
       "one) only applicable for siege."$0D"'dmg' - Default 5 (whole numbers o"
       "nly). This is used for the amount of healing to do. If set to a negati"
       "ve number, trigger_heal will not function."$0D"==============NOTES===="
       "==========================="$0D"It does dmg points of healing each ser"
       "ver frame."$0D"Targeting the trigger will toggle its on / off state."
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "START_OFF"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "CAN_TARGET"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "SILENT"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "X"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "SLOW"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X32"
        cap = "X"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "X"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
    }
    trigger_hurt:form =
    {
      help = "===========DESCRIPTION============================"$0D"Any entit"
       "y that touches this will be hurt."$0D"===========SPAWNFLAGS==========="
       "=================="$0D"START_OFF - Starts off. Does not injure until t"
       "riggered."$0D"CAN_TARGET - If you target it, it will toggle on and off"
       "."$0D"SILENT - Suppresses playing the sound."$0D"SLOW - Changes the da"
       "mage rate to once per second."$0D"NO_PROTECTION - *Nothing* stops the "
       "damage."$0D"===========MOVIE BATTLES II SPECIFIC SPAWNFLAGS==========="
       $0D"ELECTRICAL - Electricity will arc over anyone caught in this trigge"
       "r_hurt. More damage underwater."$0D"FLAME - Entities caught in this tr"
       "igger_hurt will be lit on fire after a short time."$0D"PLASMAFLAME - E"
       "ntities caught in this will be light on fire with blue flame after a s"
       "hort time. Does more damage than regular flame."$0D"WFlame - Boosts th"
       "e damage of Flame or Plasma Flame. Must be used with one of those."$0D
       "INSTANT - Allows the entity to Instantly Ignite any entity within it, "
       "rather than after a few seconds of being exposed."$0D"Note: you can us"
       "e it without using the actual flame spawnflags, and it'll make people "
       $22"easy"$22" to light on fire with flamers."$0D"FREEZE - Instantly fre"
       "ezes anyone within this trigger_hurt."$0D"POISON - Instantly poisons a"
       "ny player or NPC that touches this trigger_hurt."$0D"===========KEYS&V"
       "ALUES============================"$0D"'team' - Team (1 or 2) to allow "
       "hurting (if none then hurt anyone) only applicable for siege."$0D"'dmg"
       "' - Default 5 (whole numbers only). If dmg is set to -1 this brush wil"
       "l use the fade-kill method."$0D"==============NOTES==================="
       "============"$0D"It does dmg points of damage each server frame."$0D"T"
       "argeting the trigger will toggle its on / off state."
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "START_OFF"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "CAN_TARGET"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "SILENT"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "NO_PROTECTION"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "SLOW"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X32"
        cap = "X"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "ELECTRICAL"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X256"
        cap = "FLAME"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X512"
        cap = "PLASMAFLAME"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X1024"
        cap = "WFLAME"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2048"
        cap = "X"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4096"
        cap = "INSTANT"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X8192"
        cap = "FREEZE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16384"
        cap = "POISON"
      }
    }
    trigger_playercount:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"Trigger will count h"
       "ow many players are inside its bounding box and check that amount agai"
       "nst logic set by 'mode' and 'count', and fire its targets if true."$0D
       "===========SPAWNFLAGS============================="$0D"INACTIVE - Star"
       "ts off, needs to be activated to work."$0D"===========KEYS&VALUES====="
       "======================="$0D"'mode' - Set to -1 for LESSTHAN mode, set "
       "to 0 for EQUALS mode, set to 1 for GREATERTHAN mode"$0D"'count' - Amou"
       "nt to check in condition set by 'mode'. Needs to be greater than or eq"
       "ual to 0."$0D"================NOTES================"$0D"If 'mode' is s"
       "et to 1 (GREATHERTHAN) and 'count' is set to 4, the game will check th"
       "e following condition:"$0D"foundPlayers > 4"$0D"If the trigger contain"
       "s more than 4 players, it will fire its targets."
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
    }
    trigger_space:form =
    {
      help = "===========DESCRIPTION============================"$0D"Causes hu"
       "man clients to suffocate and have no gravity."$0D"===========KEYS&VALU"
       "ES============================"$0D"'script_targetname' - To recieve in"
       "structions from a script."$0D"==============NOTES====================="
       "=========="$0D"I couldn't get this thing to turn off and on. I couldn'"
       "t get it to activate or deactivate. So I scripted it's movement to whe"
       "re I needed it instantaneously."$0D"Example:"$0D"affect ( "$22"vac_01"$22
       ", FLUSH )"$0D"{"$0D"move ( $tag( "$22"vac_01"$22", ORIGIN)$, < 0.000 0"
       ".000 0.000 >, 0.000 );"$0D"}"$0D"Basicaly I mapped it on one side and "
       "the script tells it to move to my ref_tag."$0D"That got it to sorta ac"
       "t like it is triggered on and off."
    }
    trigger_shipboundary:form =
    {
      help = "===========DESCRIPTION============================"$0D"Causes ve"
       "hicle to turn toward target and travel in that direction for a set tim"
       "e when hit."$0D"===========KEYS&VALUES============================"$0D
       "'target' - Name of entity to turn toward (can be info_notnull, or what"
       "ever)."$0D"'traveltime' - Time to travel in this direction."
    }
    trigger_hyperspace:form =
    {
      help = "===========DESCRIPTION============================"$0D"Ship will"
       " turn to face the angles of the first target_position then fly forward"
       ", playing the hyperspace effect, then pop out at a relative point arou"
       "nd the target."$0D"===========KEYS&VALUES============================"$0D
       "'target' - Whatever position the ship teleports from in relation to th"
       "e target_position specified here, that's the relative position the shi"
       "p will spawn at around the target2 target_position."$0D"'target2' - Na"
       "me of target_position to teleport the ship to (will be relative to it'"
       "s origin)."
    }
    func_timer:form =
    {
      help = "===========DESCRIPTION============================"$0D"Repeatedl"
       "y fires its targets. Can be turned on or off by using."$0D"==========="
       "SPAWNFLAGS============================="$0D"START_ON"$0D"===========KE"
       "YS&VALUES============================"$0D"'wait' - Base time between t"
       "riggering all targets, default is 1."$0D"'random' - Wait variance, def"
       "ault is 0."$0D"==============NOTES==============================="$0D"B"
       "asic time between firing is a random time between (wait - random) and "
       "(wait + random)."
      bbox = '-8 -8 -8 8 8 8'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "START_ON"
      }
    }
    trigger_asteroid_field:form =
    {
      help = "===========DESCRIPTION============================"$0D"Generates"
       " an asteroid field within the trigger volume."$0D"===========KEYS&VALU"
       "ES============================"$0D"'speed' - How fast, on average, the"
       " asteroid moves."$0D"'count' - How many asteroids, max, to have at one"
       " time."$0D"'target' - Target this at func_rotating asteroids"$0D"====="
       "=========NOTES==============================="
    }
    misc_turret:form =
    {
      help = "===========DESCRIPTION============================"$0D"Large 2-p"
       "iece turbolaser turret."$0D"===========SPAWNFLAGS====================="
       "========"$0D"START_OFF - Starts off."$0D"===========KEYS&VALUES======="
       "====================="$0D"'radius' - How far away an enemy can be for "
       "it to pick it up (default 1024)."$0D"'wait' - Time between shots (defa"
       "ult 300 ms)."$0D"'dmg' - How much damage each shot does (default 100)."
       $0D"'health' - How much damage it can take before exploding (default 30"
       "00)."$0D"'speed' - how fast it turns (default 10)."$0D"'splashDamage' "
       "- How much damage the explosion does (300)."$0D"'splashRadius' - The r"
       "adius of the explosion (128)."$0D"'shotspeed' - speed at which project"
       "iles will move."$0D"'targetname' - Toggles it on/off."$0D"'target' - W"
       "hat to use when destroyed."$0D"'target2' - What to use when it decides"
       " to start shooting at an enemy."$0D"'showhealth' - set to 1 to show he"
       "alth bar on this entity when crosshair is over it."$0D"'teamowner' - c"
       "rosshair shows green for this team, red for opposite team."$0D"0 - non"
       "e"$0D"1 - red"$0D"2 - blue"$0D"'alliedTeam' - team that this turret wo"
       "n't target."$0D"0 - none"$0D"1 - red"$0D"2 - blue"$0D"'teamnodmg' - te"
       "am that turret does not take damage from."$0D"0 - none"$0D"1 - red"$0D
       "2 - blue"$0D"'icon' - icon that represents the objective on the radar."
      bbox = '-48 -48 0 48 48 144'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "START_OFF"
      }
    }
    misc_turretG2:form =
    {
      help = "===========DESCRIPTION============================"$0D"Turret th"
       "at hangs from the ceiling, will aim and shoot at enemies."$0D"========"
       "===SPAWNFLAGS============================="$0D"START_OFF - Starts off."
       " (Needs to be triggered.)"$0D"UPSIDE_DOWN - Make it rest on a surface/"
       "floor instead of hanging from the ceiling."$0D"CANRESPAWN - Will respa"
       "wn after being killed (use count)."$0D"TURBO - Big-ass, Boxy Death Sta"
       "r Turbo Laser version."$0D"LEAD - Turret will aim ahead of moving targ"
       "ets ('lead' them)."$0D"SHOWRADAR - Show on radar."$0D"===========KEYS&"
       "VALUES============================"$0D"'radius' - How far away an enem"
       "y can be for it to pick it up (default 512)."$0D"'wait'    - Time betw"
       "een shots (default 150 ms)."$0D"'dmg'    - How much damage each shot d"
       "oes (default 5)."$0D"'health' - How much damage it can take before exp"
       "loding (default 100)."$0D"'count' - If CANRESPAWN spawnflag, decides h"
       "ow long it is before gun respawns (in ms) - defaults to 20000 (20 seco"
       "nds)."$0D"'paintarget' - Target to fire off upon being hurt."$0D"'pain"
       "wait' - Milliseconds to wait between firing off pain targets."$0D"'ran"
       "dom' - Random error (in degrees) of projectile direction when it comes"
       " out of the muzzle (default is 2)."$0D"'shotspeed' - The speed of the "
       "missile it fires travels at (default is 1100 for regular turrets, 2000"
       "0 for TURBOLASERS)."$0D"'splashDamage' - How much damage the explosion"
       " does."$0D"'splashRadius' - The radius of the explosion."$0D"'targetna"
       "me' - Toggles it on/off."$0D"'target' - What to use when destroyed."$0D
       "'target2' - What to use when it decides to start shooting at an enemy."
       $0D"'showhealth' - Set to 1 to show health bar on this entity when cros"
       "shair is over it."$0D"'teamowner' - Crosshair shows green for this tea"
       "m, red for opposite team."$0D"0 - none"$0D"1 - red"$0D"2 - blue"$0D"'a"
       "lliedTeam' - Team that this turret won't target."$0D"0 - none"$0D"1 - "
       "red"$0D"2 - blue"$0D"'teamnodmg' - Team that turret does not take dama"
       "ge from."$0D"0 - none"$0D"1 - red"$0D"2 - blue"$0D"'customscale' - Cus"
       "tom scaling size. 100 is normal size, 1024 is the max scaling. this wi"
       "ll change the bounding box size, so be careful of starting in solid!"$0D
       "'icon' - Icon that represents the objective on the radar."$0D"'script_"
       "targetname' - Referred to by script as the recipient of set of instruc"
       "tions. Most entities can use this key."$0D"===========MOVIE BATTLES II"
       " SPECIFIC KEYS&VALUES==========="$0D"'shotefx' - Changes the Effect fi"
       "le of the shot (EX: effects/demp2/lvl3_shot.efx)"$0D"'muzzleflash' - C"
       "hanges the Muzzleflash Effect for the turret. (EX: effects/demp2/muzzl"
       "e_flash.efx)"$0D"'impactefx' - Changes the Impact Effect for the turre"
       "t."$0D"'model' - Changes the model of the turret (Piece 1)"$0D"'model2"
       "' - Changes the model of the turret (Piece 2)"$0D"'dyingmodel' - Chang"
       "es the Dead/dying part of the model (Piece 1)"$0D"'dyingmodel2' - Chan"
       "ges the dead/dying part of the model (piece 2)"$0D"==============NOTES"
       "==============================="$0D"For some reason this must have at "
       "least 1 unit of space between it and the surface where you intend to p"
       "lace it."
      bbox = '-8 -8 -22 8 8 0'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "START_OFF"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "UPSIDE_DOWN"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "CANRESPAWN"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "TURBO"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "LEAD"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X32"
        cap = "SHOWRADAR"
      }
    }
    emplaced_gun:form =
    {
      help = "===========DESCRIPTION============================"$0D"========="
       "==SPAWNFLAGS============================="$0D"CANRESPAWN - Will respaw"
       "n after being killed (use count)."$0D"===========KEYS&VALUES=========="
       "=================="$0D"'count' - If CANRESPAWN spawnflag, decides how "
       "long it is before gun respawns (in ms)"$0D"'constraint' - Number of de"
       "grees gun is constrained from base angles on each side (default 60.0)"$0D
       "'showhealth' - Set to 1 to show health bar on this entity when crossha"
       "ir is over it"$0D"'teamowner' - Crosshair shows green for this team, r"
       "ed for opposite team"$0D"0 - none"$0D"1 - red"$0D"2 - blue"$0D"'allied"
       "Team' - Team that can use this"$0D"0 - any"$0D"1 - red"$0D"2 - blue"$0D
       "'teamnodmg' - Team that turret does not take damage from or do damage "
       "to"$0D"0 - none"$0D"1 - red"$0D"2 - blue"$0D"==============NOTES======"
       "========================="
      bbox = '-30 -20 8 30 20 60'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "CANRESPAWN"
      }
    }
    point_combat:form =
    {
      help = "===========DESCRIPTION============================"$0D"NPCs in b"
       "State BS_COMBAT_POINT will find their closest empty combat_point."$0D"="
       "==========SPAWNFLAGS============================="$0D"DUCK - NPC will "
       "duck and fire from this point, NOT IMPLEMENTED?"$0D"FLEE - Will choose"
       " this point when running"$0D"INVESTIGATE - Will look here if a sound i"
       "s heard near it."$0D"SQUAD - NOT IMPLEMENTED."$0D"LEAN - Lean-type cov"
       "er, NOT IMPLEMENTED."$0D"SNIPE - Snipers look for these first, NOT IMP"
       "LEMENTED."$0D"==============NOTES==============================="$0D"C"
       "ombat Points should be off the main waypoint network. They must have a"
       " clear path to at least one waypoint. "$22"Shooter"$22" type NPCs use "
       "these as places to stand or crouch and shoot at the enemy. Their prima"
       "ry purpose is to give the NPC someplace interesting to stand and shoot"
       " without blocking the traffic flow through the main waypoint network. "
       "They are also used as hiding places for NPCs that are fleeing."
      bbox = '-16 -16 -24 16 16 32'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "DUCK"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "FLEE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "INVESTIGATE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "SQUAD"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "LEAN"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X32"
        cap = "SNIPE"
      }
    }
    target_interest:form =
    {
      help = "===========DESCRIPTION============================"$0D"A point t"
       "hat a squadmate will look at if standing still."$0D"===========KEYS&VA"
       "LUES============================"$0D"'target' - Thing to fire when som"
       "eone looks at this thing."
      bbox = '-4 -4 -4 4 4 4'
    }
    NPC_spawner:form =
    {
      help = "===========DESCRIPTION============================"$0D"Point a s"
       "pecific NPC will spawn from."$0D"===========SPAWNFLAGS================"
       "============="$0D"DROPTOFLOOR - NPC can be in air, but will spawn on t"
       "he closest floor surface below it"$0D"CINEMATIC - Will spawn with no d"
       "efault AI (BS_CINEMATIC)"$0D"NOTSOLID - Starts not solid"$0D"STARTINSO"
       "LID - Don't try to fix if spawn in solid"$0D"SHY - Spawner is shy"$0D"="
       "==========KEYS&VALUES============================"$0D"'NPC_type' - Nam"
       "e of NPC (in npcs.cfg) to spawn in."$0D"'targetname' - Name this NPC g"
       "oes by for targeting."$0D"'target' - NPC will fire this when it spawns"
       " it's last NPC (should this be when the last NPC it spawned dies?)."$0D
       "'target2' - Fired by stasis spawners when they try to spawn while thei"
       "r spawner model is broken."$0D"'target3' - Fired by spawner if they tr"
       "y to spawn and are blocked and have a wait < 0 (removes them)."$0D"'co"
       "unt' - How many NPCs to spawn (only if targeted) default = 1."$0D"'wai"
       "t' - If trying to spawn and blocked, how many seconds to wait before t"
       "rying again (default = 0.5, < 0 = never try again and fire target2)."$0D
       "'delay' - After spawned or triggered, how many seconds to wait to spaw"
       "n the NPC."$0D"'showhealth' - Set to 1 to show health bar on this enti"
       "ty when crosshair is over it."$0D"'teamowner' - Crosshair shows green "
       "for this team, red for opposite team."$0D"0 - none"$0D"1 - red"$0D"2 -"
       " blue"$0D"'teamuser' - Only this team can use this NPC."$0D"0 - none"$0D
       "1 - red"$0D"2 - blue"$0D"'teamnodmg' - Team that NPC does not take dam"
       "age from (turrets and other auto-defenses that have 'alliedTeam' set t"
       "o this team won't target this NPC)."$0D"0 - none"$0D"1 - red"$0D"2 - b"
       "lue"$0D"'noBasicSounds' - Set to 1 to prevent loading and usage of bas"
       "ic sounds (pain, death, etc)."$0D"'noCombatSounds' - Set to 1 to preve"
       "nt loading and usage of combat sounds (anger, victory, etc.)."$0D"'noE"
       "xtraSounds' - Set to 1 to prevent loading and usage of 'extra' sounds "
       "(chasing the enemy - detecting them, flanking them... also Jedi combat"
       " sounds)."$0D"'NPC_targetname' - NPC's targetname AND script_targetnam"
       "e."$0D"'NPC_target' - NPC's target to fire when killed."$0D"'NPC_targe"
       "t2' - NPC's target to fire when knocked out."$0D"'NPC_target4' - NPC's"
       " target to fire when killed by friendly fire."$0D"'health' - Starting "
       "health (default = 100)."$0D"'helpiconindex' (MOVIE BATTLES II SPECIFIC"
       ") - Index in .siege file of a dynamic HelpIconX block, or default -1 t"
       "o not have a help icon. ICON ONLY VISIBLE IF NPC WITHIN PVS"$0D"======"
       "============================================"$0D"These are scripts tha"
       "t are called into use under these circumstances."$0D"'spawnscript' - D"
       "efault script to run once spawned (none by default)."$0D"'usescript' -"
       " Default script to run when used (none by default)."$0D"'awakescript' "
       "- Default script to run once awoken (none by default)."$0D"'angerscrip"
       "t' - Default script to run once angered (none by default)."$0D"'painsc"
       "ript' - Default script to run when hit (none by default)."$0D"'fleescr"
       "ipt' - Default script to run when hit and below 50% health (none by de"
       "fault)."$0D"'deathscript' - Default script to run when killed (none by"
       " default)."$0D"==============NOTES==============================="$0D"I"
       "f targeted, will only spawn a NPC when triggered."
      bbox = '-16 -16 -24 16 16 40'
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "DROPTOFLOOR"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X32"
        cap = "CINEMATIC"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "NOTSOLID"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "STARTINSOLID"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X256"
        cap = "SHY"
      }
    }
    NPC_Vehicle:form =
    {
      help = "===========DESCRIPTION============================"$0D"This is t"
       "he entity that allows you to add any vehicle ground or flying that can"
       " be used by player."$0D"===========SPAWNFLAGS========================="
       "===="$0D"NO_PILOT_DIE - Die after certain amount of time of not having"
       " a pilot."$0D"SUSPENDED - Fighters: Don't drop until someone gets in i"
       "t (this only works as long as no-nw has *ever* ridden the vehicle, to "
       "simulate ships that are suspended-docked) - note: ships inside trigger"
       "_spaces do not drop when unoccupied."$0D"CINEMATIC - Will spawn with n"
       "o default AI (BS_CINEMATIC)."$0D"NOTSOLID - Starts not solid."$0D"STAR"
       "TINSOLID - Don't try to fix if spawn in solid."$0D"SHY - Spawner is sh"
       "y."$0D"===========KEYS&VALUES============================"$0D"Set NPC_"
       "type to vehicle name in vehicles.dat files."$0D"'dropTime' - Use with "
       "SUSPENDED - if set, the vehicle will drop straight down for this numbe"
       "r of seconds before flying forward."$0D"'dmg' - Use with NO_PILOT_DIE "
       "- delay in milliseconds for ship to explode if no pilot (default 10000"
       ")."$0D"'speed' - Use with NO_PILOT_DIE - distance for pilot to get awa"
       "y from ship after dismounting before it starts counting down the death"
       " timer."$0D"'model2' - If the vehicle can have a droid (has '*droiduni"
       "t' tag), this NPC will be spawned and placed there - note: game will a"
       "utomatically use the one specified in the .veh file (if any) or, absen"
       "t that, it will use an R2D2 or R5D2 NPC)."$0D"'showhealth' - Set to 1 "
       "to show health bar on this entity when crosshair is over it."$0D"'team"
       "owner' - Crosshair shows green for this team, red for opposite team."$0D
       "0 - none"$0D"1 - red"$0D"2 - blue"$0D"'teamuser' - Only this team can "
       "use this NPC."$0D"0 - none"$0D"1 - red"$0D"2 - blue"$0D"'teamnodmg' - "
       "Team that NPC does not take damage from (turrets and other auto-defens"
       "es that have 'alliedTeam' set to this team won't target this NPC)."$0D
       "0 - none"$0D"1 - red"$0D"2 - blue"$0D"==============NOTES============="
       "=================="$0D"If you want to add a custom vehicle don't forge"
       "t to include the pk3 or its files to your pk3 into your DL."
      bbox = '-16 -16 -24 16 16 32'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "NO_PILOT_DIE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "SUSPENDED"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "DROPTOFLOOR"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X32"
        cap = "CINEMATIC"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "NOTSOLID"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "STARTINSOLID"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X256"
        cap = "SHY"
      }
    }
    NPC_Kyle:form =
    {
      help = "===========DESCRIPTION============================"$0D"Spawns NP"
       "C Kyle"$0D"===========SPAWNFLAGS============================="$0D"RIFL"
       "EMAN - Do Not Use!"$0D"PHASER - Do Not Use!"$0D"TRICORDER - Do Not Use"
       "!"$0D"DROPTOFLOOR - NPC can be in air, but will spawn on the closest f"
       "loor surface below it."$0D"CINEMATIC - Will spawn with no default AI ("
       "BS_CINEMATIC)."$0D"NOTSOLID - Starts not solid."$0D"STARTINSOLID - Don"
       "'t try to fix if spawn in solid."$0D"SHY - Spawner is shy."$0D"======="
       "====KEYS&VALUES============================"$0D"'targetname' - Name th"
       "is NPC goes by for targeting."$0D"'target' - NPC will fire this when i"
       "t spawns it's last NPC (should this be when the last NPC it spawned di"
       "es?)."$0D"'target2' - Fired by stasis spawners when they try to spawn "
       "while their spawner model is broken."$0D"'target3' - Fired by spawner "
       "if they try to spawn and are blocked and have a wait < 0 (removes them"
       ")."$0D"'count' - How many NPCs to spawn (only if targeted) default = 1"
       "."$0D"'wait' - If trying to spawn and blocked, how many seconds to wai"
       "t before trying again (default = 0.5, < 0 = never try again and fire t"
       "arget2)."$0D"'delay' - After spawned or triggered, how many seconds to"
       " wait to spawn the NPC."$0D"'showhealth' - Set to 1 to show health bar"
