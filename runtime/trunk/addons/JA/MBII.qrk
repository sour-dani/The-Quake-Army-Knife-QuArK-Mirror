       "(none by default)."$0D"'angerscript' - Default script to run once ange"
       "red (none by default)."$0D"'painscript' - Default script to run when h"
       "it (none by default)."$0D"'fleescript' - Default script to run when hi"
       "t and below 50% health (none by default)."$0D"'deathscript' - Default "
       "script to run when killed (none by default)."$0D"==============NOTES=="
       "============================="$0D"30 health, blaster."
      bbox = '-16 -16 -24 16 16 40'
