    info_player_siegeteam1:form =
    {
      help = "===========DESCRIPTION============================"$0D"Siege sta"
       "rt point - team1"$0D"Name and behavior of team1 depends on what is def"
       "ined in the .siege file for this level."$0D"===========KEYS&VALUES===="
       "========================"$0D"'startoff' - If non-0 spawn point will be"
       " disabled until used."$0D"'idealclass' - If specified, this spawn poin"
       "t will be considered 'ideal' for players of this class name. Correspon"
       "ds to the name entry in the .scl (siege class) file."$0D"'target' - Ta"
       "rgets will be fired when someone spawns in on them."$0D"'nobots' - Wil"
       "l prevent bots from using this spot."$0D"'nohumans' - Will prevent non"
       "-bots from using this spot."$0D"'notfree' - When set to 1, entity will"
       " not spawn in 'Free for all' and 'Tournament' modes."$0D"'notteam' - W"
       "hen set to 1, entity will not spawn in 'Teamplay' and 'CTF' modes."$0D
       "'notsingle' - When set to 1, entity will not spawn in Single Player mo"
       "de (bot play mode)."$0D"'angle' - Direction in which player will look "
       "when spawning in the game. Does not apply to bots. 1 - 359 and -1 and "
       "-2 can be used for momentum purposes."$0D"===========MOVIE BATTLES II "
       "SPECIFIC KEYS&VALUES==========="$0D"'min_players' - Minimum player cou"
       "nt required in-round for this spawn to be active."$0D"'max_players' - "
       "Maximum player count in-round for this spawn to be active."$0D"======="
       "=======NOTES==============================="$0D"This can point at a ta"
       "rget_give entity for respawn freebies."$0D"This represents a spawn poi"
       "nt for team1 on the map. You can target these points in order to enabl"
       "e/disable them. This allows you to trigger new sets of spawn points up"
       "on different events occurring on the map. There is also a "$22"startof"
       "f"$22" key, if you set it non-0 the spawn point will be disabled at th"
       "e start until activated. 'Idealclass' key will specify the ideal class"
       " to spawn on this point, and the value should correspond to the name f"
       "ield in a .scl file. Classes will first check for points that match th"
       "eir ideal class when spawning, and if they cannot find any, they will "
       "fall back to normal team spawn points."
      bbox = '-16 -16 -24 16 16 32'
    }
    info_player_siegeteam2:form =
    {
      help = "===========DESCRIPTION============================"$0D"Siege sta"
       "rt point - team2"$0D"Name and behavior of team2 depends on what is def"
       "ined in the .siege file for this level."$0D"===========KEYS&VALUES===="
       "========================"$0D"'startoff' - If non-0 spawn point will be"
       " disabled until used."$0D"'idealclass' - If specified, this spawn poin"
       "t will be considered 'ideal' for players of this class name. Correspon"
       "ds to the name entry in the .scl (siege class) file."$0D"'target' - Ta"
       "rgets will be fired when someone spawns in on them."$0D"'nobots' - Wil"
       "l prevent bots from using this spot."$0D"'nohumans' - Will prevent non"
       "-bots from using this spot."$0D"'notfree' - When set to 1, entity will"
       " not spawn in 'Free for all' and 'Tournament' modes."$0D"'notteam' - W"
       "hen set to 1, entity will not spawn in 'Teamplay' and 'CTF' modes."$0D
       "'notsingle' - When set to 1, entity will not spawn in Single Player mo"
       "de (bot play mode)."$0D"'angle' - Direction in which player will look "
       "when spawning in the game. Does not apply to bots. 1 - 359 and -1 and "
       "-2 can be used for momentum purposes."$0D"===========MOVIE BATTLES II "
       "SPECIFIC KEYS&VALUES==========="$0D"'min_players' - Minimum player cou"
       "nt required in-round for this spawn to be active."$0D"'max_players' - "
       "Maximum player count in-round for this spawn to be active."$0D"======="
       "=======NOTES==============================="$0D"This can point at a ta"
       "rget_give entity for respawn freebies."$0D"This represents a spawn poi"
       "nt for team2 on the map. You can target these points in order to enabl"
       "e/disable them. This allows you to trigger new sets of spawn points up"
       "on different events occuring on the map. There is also a "$22"startoff"
       $22" key, if you set it non-0 the spawn point will be disabled at the s"
       "tart until activated. 'Idealclass' key will specify the ideal class to"
       " spawn on this point, and the value should correspond to the name fiel"
       "d in a .scl file. Classes will first check for points that match their"
       " ideal class when spawning, and if they cannot find any, they will fal"
       "l back to normal team spawn points."
      bbox = '-16 -16 -24 16 16 32'
    }
    info_player_siegeteam1_authentic:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"Siege start point - "
       "team1 - only works in Full Authentic mode!"$0D"Name and behavior of te"
       "am1 depends on what is defined in the .siege file for this level."$0D"="
       "==========KEYS&VALUES============================"$0D"'startoff' - If "
       "non-0 spawn point will be disabled until used."$0D"'idealclass' - If s"
       "pecified, this spawn point will be considered 'ideal' for players of t"
       "his class name. Corresponds to the name entry in the .mbch (Movie Batt"
       "les character) file."$0D"'target' - Targets will be fired when someone"
       " spawns in on them."$0D"'angle' - Direction in which player will look "
       "when spawning in the game. Does not apply to bots. 1 - 359 and -1 and "
       "-2 can be used for momentum purposes."$0D"'min_players' - Minimum play"
       "er count required in-round for this spawn to be active."$0D"'max_playe"
       "rs' - Maximum player count in-round for this spawn to be active."$0D"="
       "=============NOTES==============================="$0D"This can point a"
       "t a target_give entity for respawn freebies."$0D"This represents a spa"
       "wn point for team1 on the map. You can target these points in order to"
       " enable/disable them. This allows you to trigger new sets of spawn poi"
       "nts upon different events occurring on the map. There is also a "$22"s"
       "tartoff"$22" key, if you set it non-0 the spawn point will be disabled"
       " at the start until activated. 'Idealclass' key will specify the ideal"
       " class to spawn on this point, and the value should correspond to the "
       "name field in a .scl file. Classes will first check for points that ma"
       "tch their ideal class when spawning, and if they cannot find any, they"
       " will fall back to normal team spawn points."
      bbox = '-16 -16 -24 16 16 32'
    }
