    shooter_blaster:form =
    {
      help = "===========DESCRIPTION============================"$0D"Fires at "
       "either the target or the current direction."$0D"===========KEYS&VALUES"
       "============================"$0D"'random' - Is the number of degrees o"
       "f deviance from the target. (1.0 default)."$0D"==============NOTES===="
       "==========================="$0D"Useless - instead use misc_weapon_shoo"
       "ter."
      bbox = '-16 -16 -16 16 16 16'
    }
    misc_ammo_floor_unit:form =
    {
      help = "===========DESCRIPTION============================"$0D"Gives gen"
       "eric ammo when used."$0D"===========KEYS&VALUES======================="
       "====="$0D"'count' - max charge value (default 200)."$0D"'chargerate' -"
       " recharge 1 point every this many milliseconds (default 2000 (= 2 seco"
       "nds))."$0D"'nodrain' - don't drain power from station if 1."$0D"======"
       "========NOTES==============================="$0D"Do NOT cover with phy"
       "sclip or clip."$0D"=====MODEL FOR MAPPING VISUAL ONLY================"$0D
       "model='/models/items/a_pwr_converter.md3"$220D"======DO NOT SET AS KEY"
       " OR VALUE=================="
      bbox = '-16 -16 0 16 16 40'
    }
    misc_shield_floor_unit:form =
    {
      help = "===========DESCRIPTION============================"$0D"Gives shi"
       "eld energy when used."$0D"===========KEYS&VALUES======================"
       "======"$0D"'count' - Max charge value (default 50)."$0D"'chargerate' -"
       " Recharge 1 point every this many milliseconds (default 3000(= 3 secon"
       "ds))."$0D"'nodrain' - Don't drain power from me."$0D"=====MODEL FOR MA"
       "PPING VISUAL ONLY================"$0D"model='/models/items/a_shield_co"
       "nverter.md3"$220D"======DO NOT SET AS KEY OR VALUE=================="
      bbox = '-16 -16 0 16 16 40'
    }
    misc_model_shield_power_converter:form =
    {
      help = "===========DESCRIPTION============================"$0D"Gives shi"
       "eld energy when used."$0D"===========KEYS&VALUES======================"
       "======"$0D"'count' - The amount of ammo given when used (default 200)."
      bbox = '-16 -16 -16 16 16 16'
    }
    misc_model_ammo_power_converter:form =
    {
      help = "===========DESCRIPTION============================"$0D"Gives amm"
       "o energy when used."$0D"===========KEYS&VALUES========================"
       "===="$0D"'count' - The amount of ammo given when used (default 200)."$0D
       "'nodrain' - Don't drain power from me."
      bbox = '-16 -16 -16 16 16 16'
    }
    misc_model_health_power_converter:form =
    {
      help = "===========DESCRIPTION============================"$0D"Gives hea"
       "lth energy when used."$0D"===========KEYS&VALUES======================"
       "======"$0D"'count' - The amount of ammo given when used (default 200)."
      bbox = '-16 -16 -16 16 16 16'
    }
    fx_runner:form =
    {
      help = "===========DESCRIPTION============================"$0D"Runs the "
       "specified effect, can also be targeted at an info_null to orient the e"
       "ffect."$0D"===========SPAWNFLAGS============================="$0D"STAR"
       "TOFF - Effect starts off, toggles on/off when used."$0D"ONESHOT - Effe"
       "ct fires only when used."$0D"DAMAGE - Does radius damage around effect"
       " every 'delay' milliseconds."$0D"===========KEYS&VALUES==============="
       "============="$0D"'fxFile' - Name of the effect file to play."$0D"'tar"
       "get' - Direction to aim the effect in, otherwise defaults to up."$0D"'"
       "target2' - Uses its target2 when the fx gets triggered."$0D"'delay'  -"
       " How often to call the effect, don't over-do this ( default 200)."$0D"'"
       "random' - Random amount of time to add to delay, ( default 0, 200 = 0m"
       "s to 200ms)."$0D"'splashRadius' - Only works when damage is checked ( "
       "default 16)."$0D"'splashDamage' - Only works when damage is checked ( "
       "default 5)."$0D"'soundset'    - Bmodel set to use, plays start sound w"
       "hen toggled on, loop sound while on ( doesn't play on a oneshot), and "
       "a stop sound when turned off."$0D"===========MOVIE BATTLES II SPECIFIC"
       " KEYS&VALUES==========="$0D"fxFileEnhanced1 - For use for those who wo"
       "uld like to use Enhanced EFX (This is Medium Quality) Point this at an"
       " EFX file just like fxFile."$0D"fxFileEnhanced2 - or use for those who"
       " would like to use Enhanced EFX (This is High Quality) Point this at a"
       "n EFX file just like fxFile."
      bbox = '-8 -8 -8 8 8 8'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "STARTOFF"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "ONESHOT"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "DAMAGE"
      }
    }
    fx_spacedust:form =
    {
      help = "===========DESCRIPTION============================"$0D"This worl"
       "d effect will spawn space dust globally into the level."$0D"=========="
       "=KEYS&VALUES============================"$0D"'count' - The number of s"
       "now particles (default of 1000)."$0D"==============NOTES=============="
       "================="$0D"Use misc_weather_zone and inside, outside brushe"
       "s to control where Fx_spacedust plays."
      bbox = '-16 -16 -16 16 16 16'
    }
    fx_snow:form =
    {
      help = "===========DESCRIPTION============================"$0D"This worl"
       "d effect will spawn snow globally into the level."$0D"===========KEYS&"
       "VALUES============================"$0D"'count' - The number of snow pa"
       "rticles (default of 1000)."$0D"==============NOTES===================="
       "==========="$0D"Use misc_weather_zone and inside, outside brushes to c"
       "ontrol where Fx_snow plays."
      bbox = '-16 -16 -16 16 16 16'
    }
    fx_rain:form =
    {
      help = "===========DESCRIPTION============================"$0D"This worl"
       "d effect will spawn rain globally into the level."$0D"===========KEYS&"
       "VALUES============================"$0D"'count' The number of rain part"
       "icles (default of 500)."$0D"==============NOTES======================="
       "========"$0D"Use misc_weather_zone and inside, outside brushes to cont"
       "rol where Fx_rain plays."
      bbox = '-16 -16 -16 16 16 16'
    }
    fx_weather:form =
    {
      help = "===========MOVIE BATTLES II SPECIFIC ENTITY==========="$0D"====="
       "======DESCRIPTION============================"$0D"Responds to misc_wea"
       "ther_zone and inside/outside brushes in the same way fx_rain, fx_snow,"
       " and fx_spacedust do."$0D"Be sure to check out the outsideBias worldsp"
       "awn keyword if you're using weather effects in your map, or they may n"
       "ot behave properly in MBII RC2 and up!"$0D"===========SPAWNFLAGS======"
       "======================="$0D"DIE (0)- Stop all currently playing weathe"
       "r and shut down the weather system."$0D"This may be able to boost FPS "
       "on your map if you're done with weather until the map is restarted."$0D
       "Don't shut down weather and restart it in the same map, as this can ha"
       "ve a performance hit."$0D"Use WFX_CLEAR if you have any intention of t"
       "urning the weather back on again later in your map, or if you simply w"
       "ant to change the weather."$0D"Note: WFX_DIE is an absolute value and "
       "cannot be used with any other weatherFX value."$0D"CLEAR (1)- Stop all"
       " currently playing weather, but leaves the weather system running. Use"
       " this to stop all currently playing weather effects."$0D"FREEZE (2)- T"
       "his appears to freeze the currently playing weatherFX in position(it'l"
       "l no longer follow the player around, and no longer animate)."$0D"ZONE"
       " (4)- Unknown and Disabled"$0D"WIND (8)- Randomly blows weather around"
       " in different directions at different speeds."$0D"CONSTANTWIND (16)- A"
       "dds constantly-on wind to some weather effects. Seems slightly unstabl"
       "e and prone to crashes."$0D"GUSTINGWIND (32)- Randomly blows weather a"
       "round in different directions at different speeds. It seems slightly m"
       "ore energetic than WIND."$0D"WINDZONE (64)- Unknown and Disabled"$0D"L"
       "IGHTRAIN (128)- Rain. More repeats = more rain."$0D"RAIN (256)- Rain. "
       "More repeats = more rain."$0D"ACIDRAIN (512)- Green rain. Is purely vi"
       "sual; you'll need to hurt people who're out in it, on your own. OUTSID"
       "EPAIN is used for that."$0D"More repeats = more rain."$0D"HEAVYRAIN (1"
       "024)- More repeats = more rain."$0D"SNOW (2048)- now. More repeats = m"
       "ore snow."$0D"SPACEDUST (4096)- Spacedust. count controls the number o"
       "f particles. Default appears to be 0. Typical values tend to be over 1"
       "000."$0D"Repeats don't seem to do anything."$0D"SAND (8192)- Brownish "
       "clouds/fog. More repeats = thicker clouds."$0D"FOG (16384)- White clou"
       "ds/fog. More repeats = thicker clouds."$0D"HEAVYRAINFOG (32768)- White"
       " clouds/fog. More repeats = thicker clouds."$0D"LIGHT FOG (65536)- Whi"
       "te clouds/fog. More repeats = thicker clouds."$0D"OUTSIDESHAKE  (13107"
       "2)- Unknown. Possibly camera shaking?"$0D"OUTSIDEPAIN (262144)- Enable"
       "s "$22"outside"$22" damage, using MOD_SLIME as the death method. It's "
       "meant for use with ACIDRAIN."$0D"COLD (524288)- Makes an outside area "
       "cold. This is useful for snow and other low-temperature environments. "
       "It activates supportive visual effects, like breath fogging."$0D"If yo"
       "u want to make all areas of a map cold, see the coldWorld key of world"
       "spawn."$0D"===========KEYS&VALUES============================"$0D"'wea"
       "therFX' - The type(s) of weather effects in use. Put the bitflag numbe"
       "rs here (Add them together if there are multiples)"$0D"'count' - Contr"
       "ols the number of particles that are used in spacedust. Defualt: 0"$0D
       "'repeatFX ' - Controls the number of times this effect will be repeate"
       "d. Default: 0 (Or, play it once.)"$0D"Maximum: 4 (More than this doesn"
       "'t seem to do anything.)"$0D"'dmg' - Controls how much damage OUTSIDEP"
       "AIN deals."
      bbox = '-24 -24 -24 24 24 24'
    }
    misc_maglock:form =
    {
      help = "===========DESCRIPTION============================"$0D"Places a "
       "maglock seal on a func_door. Must be damaged by a lightsaber."$0D"===="
       "=======KEYS&VALUES============================"$0D"'target' - Thing to"
       " use when destroyed (not doors - it automatically unlocks the door it "
       "was angled at)."$0D"'health' - Default is 10."$0D"==============NOTES="
       "=============================="$0D"NOTE: Place these half-way in the d"
       "oor to make it flush with the door's surface. Place facing a door (usi"
       "ng the angle, not a targetname) and it will lock that door.  Can only "
       "be destroyed by lightsaber and will automatically unlock the door it's"
       " attached to."
      bbox = '-8 -8 -8 8 8 8'
    }
    misc_faller:form =
    {
      help = "===========DESCRIPTION============================"$0D"Falling s"
       "tormtrooper."$0D"===========KEYS&VALUES============================"$0D
       "'targetname' - If specified, will only spawn when used."$0D"'interval'"
       " - Spawn every so often (milliseconds)."$0D"'fudgefactor' - Millisecon"
       "ds between 0 and this number randomly added to interval (1000 millisec"
       "onds = 1 second)."$0D"==============NOTES============================="
       "=="$0D"Spawned every interval + random fudgefactor, or if specified, w"
       "hen used."
      bbox = '-8 -8 -8 8 8 8'
    }
    ref_tag_huge:form =
    {
      help = "===========DESCRIPTION============================"$0D"SAME AS r"
       "ef_tag, JUST BIGGER SO YOU CAN SEE THEM IN EDITOR ON HUGE MAPS!"$0D"Re"
       "ference tags which can be positioned throughout the level. These tags "
       "can later be referred to by the scripting system so that their origins"
       " and angles can be referred to."$0D"===========KEYS&VALUES============"
       "================"$0D"'targetname' - The name of this tag."$0D"'ownerna"
       "me' - The owner of this tag. Set this key and value identical on the o"
       "wning entity."$0D"'target' - Use to point the tag at something for ang"
       "les."$0D"==============NOTES==============================="$0D"If you"
       " set angles on the tag, these will be retained."$0D"If you target a re"
       "f_tag at an entity, that will set the ref_tag's angles toward that ent"
       "ity."$0D"If you set the ref_tag's ownername to the ownername of an ent"
       "ity, it makes that entity is the owner of the ref_tag.  This means tha"
       "t the owner, and only the owner, may refer to that tag."$0D"Tags may n"
       "ot have the same name as another tag with the same owner.  However, ta"
       "gs with different owners may have the same name as one another.  In th"
       "is way, scripts can generically refer to tags by name, and their owner"
       "s will automatically specify which tag is being referred to."
      bbox = '-128 -128 -128 128 128 128'
    }
    ref_tag:form =
    {
      help = "===========DESCRIPTION============================"$0D"Reference"
       " tags which can be positioned throughout the level."$0D"These tags can"
       " later be referred to by the scripting system so that their origins an"
       "d angles can be referred to."$0D"===========KEYS&VALUES==============="
       "============="$0D"'targetname' - The name of this tag."$0D"'ownername'"
       " - The owner of this tag. Set this key and value identical on the owni"
       "ng entity."$0D"'target' - Use to point the tag at something for angles"
       "."$0D"==============NOTES==============================="$0D"If you se"
       "t angles on the tag, these will be retained."$0D"If you target a ref_t"
       "ag at an entity, that will set the ref_tag's angles toward that entity"
       "."$0D"If you set the ref_tag's ownername to the ownername of an entity"
       ", it makes that entity is the owner of the ref_tag.  This means that t"
       "he owner, and only the owner, may refer to that tag."$0D"Tags may not "
       "have the same name as another tag with the same owner.  However, tags "
       "with different owners may have the same name as one another.  In this "
       "way, scripts can generically refer to tags by name, and their owners w"
       "ill automatically specify which tag is being referred to."
      bbox = '-8 -8 -8 8 8 8'
    }
    misc_weapon_shooter:form =
    {
      help = "===========DESCRIPTION============================"$0D"Fires spe"
       "cific weapons fire from this point."$0D"===========SPAWNFLAGS========="
       "===================="$0D"ALTFIRE - Fire the alt-fire of the chosen wea"
       "pon."$0D"TOGGLE - Keep firing until used again (fires at intervals of "
       "'wait')."$0D"===========KEYS&VALUES============================"$0D"'w"
       "ait' - Debounce time between refires (defaults to 500)."$0D"'target' -"
       " What to aim at (will update aim every frame if it's a moving target)."
       $0D"'random' - Is the number of degrees of deviance from the target. (1"
       ".0 default)."$0D"'weapon' - Specify the weapon to use (default is WP_B"
       "LASTER)."$0D"WP_BRYAR_PISTOL"$0D"WP_BLASTER"$0D"WP_DISRUPTOR"$0D"WP_BO"
       "WCASTER"$0D"WP_REPEATER"$0D"WP_DEMP2"$0D"WP_FLECHETTE"$0D"WP_ROCKET_LA"
       "UNCHER"$0D"WP_THERMAL"$0D"WP_TRIP_MINE"$0D"WP_DET_PACK"$0D"WP_STUN_BAT"
       "ON"$0D"WP_EMPLACED_GUN"$0D"WP_BOT_LASER"$0D"WP_TURRET"$0D"WP_ATST_MAIN"
       $0D"WP_ATST_SIDE"$0D"WP_TIE_FIGHTER"$0D"WP_RAPID_FIRE_CONC"$0D"WP_BLAST"
       "ER_PISTOL"$0D"==============NOTES==============================="$0D"G"
       "uessing here but 'count' would probably set the ammo or times to shoot"
       "."
      bbox = '-8 -8 -8 8 8 8'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "ALTFIRE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "TOGGLE"
      }
    }
    misc_weather_zone:form =
    {
      help = "===========DESCRIPTION============================"$0D"Determine"
       "s a region to check for weather contents - will significantly reduce l"
       "oad time"$0D"==============NOTES==============================="$0D"Mu"
       "st be snapped to or made in grid 16."$0D"Weatherzones are used to redu"
       "ce the amount of entities that have to be loaded during the level load"
       " process by encapsulating a larger number of Inside/Outside brushes wi"
       "th a smaller number of Weatherzone brushes."$0D"The designer cannot us"
       "e both Inside and Outside brushes in the same level!!! Only one can be"
       " used throughout the level."
    }
    func_door:form =
    {
      help = "===========DESCRIPTION============================"$0D"Door enti"
       "ty used as either a door or any basic mover like a crushing wall or a "
       "lift."$0D"===========SPAWNFLAGS============================="$0D"START"
       "_OPEN - The door to moves to its destination when spawned, and operate"
       " in reverse.  It is used to temporarily or permanently close off an ar"
       "ea when triggered (not useful for touch or take damage doors)."$0D"FOR"
       "CE_ACTIVATE - Can only be activated by a force push or pull."$0D"CRUSH"
       "ER - Does continuous damage to anything blocking the door between the "
       "open and closed positions."$0D"TOGGLE - Wait in both the start and end"
       " states for a trigger event - does NOT work on Trek doors."$0D"LOCKED "
       "- Starts locked, with the shader animmap at the first frame and inacti"
       "ve.  Once used, the animmap changes to the second frame and the door o"
       "perates normally.  Note that you cannot use the door again after this."
       $0D"PLAYER_USE - Player can use it with the use button."$0D"INACTIVE - "
       "Must be used by a target_activate before it can be used."$0D"========="
       "==KEYS&VALUES============================"$0D"'team' - All func_door t"
       "hat share the same team name fire when any one of them is fired."$0D"'"
       "target' - Door fires this when it starts moving from it's closed posit"
       "ion to its open position."$0D"'opentarget' - Door fires this after rea"
       "ching its 'open' position."$0D"'target2' - Door fires this when it sta"
       "rts moving from it's open position to its closed position."$0D"'closet"
       "arget' - Door fires this after reaching its 'closed' position."$0D"'mo"
       "del2' - .md3 model to also draw."$0D"'angle' - Determines the opening "
       "direction (on Z axis). If -1 is used it opens the door vertically up. "
       "If -2 is used it opens the door vertically down."$0D"'targetname' - If"
       " set, no touch field will be spawned and a remote button or trigger fi"
       "eld activates the door."$0D"'speed' - Movement speed (100 default)."$0D
       "'wait' - Wait before returning (3 default, -1 = never return)."$0D"'de"
       "lay' - When used, how many seconds to wait before moving - default is "
       "none."$0D"'lip' - Lip remaining at end of move (8 default)."$0D"'dmg' "
       "- Damage to inflict when blocked (2 default, set to negative for no da"
       "mage)."$0D"'color' - ConstantLight color. (Default setup with light en"
       "tity selected press K to bring up color picker.)"$0D"'light' - Constan"
       "tLight radius."$0D"'health' - If set, the door must be shot open."$0D"'"
       "linear' - Set to 1 and it will move linearly rather than with accelera"
       "tion (default is 0)."$0D"'teamallow' - Even if locked, this team can a"
       "lways open and close it just by walking up to it."$0D"0 - none (locked"
       " to everyone)"$0D"1 - red"$0D"2 - blue"$0D"'vehopen' - If non-0, vehic"
       "les/players riding vehicles can open."$0D"============================"
       "======================"$0D"'_lightmapscale' - Floating point value sca"
       "ling the resolution of lightmaps on brushes/patches in this entity (de"
       "fault 1.0)."$0D"'_cs' OR '_castshadows' - Allows per-entity control ov"
       "er shadow casting. Defaults to 0 on entities, 1 on world. 0 = no shado"
       "w casting. 1 = cast shadows on world. > 1 = cast shadows on entities w"
       "ith _rs (or _receiveshadows) with the corresponding value, AND world. "
       "Negative values imply same, but DO NOT cast shadows on world."$0D"'_rs"
       "' OR '_receiveshadows' - Allows per-entity control over shadow recepti"
       "on. Defaults to 1 on everything (world shadows). 0 = receives NO shado"
       "ws. > 1 = receive shadows only from corresponding keyed entities (see "
       "above) and world. < 1 = receive shadows ONLY from corresponding keyed "
       "entities."$0D"'_celshader' - Sets the cel shader used for this geometr"
       "y. Note: omit the 'textures/' prefix."$0D"'_indexmap' OR 'alphamap' - "
       "Path/name for the art file used to guide the mapping of textures on th"
       "e terrain surface."$0D"'_layer' OR 'layers' - Integer value is the num"
       "ber of unique root shaders that will be use on the terrain."$0D"'_shad"
       "er' OR 'shader' - Path to the metashader used to assign textures to th"
       "e terrain entity. Note: Omit the 'textures/' prefix."$0D"'script_targe"
       "tname' - Referred to by script as the recipient of set of instructions"
       ". Most entities can use this key."$0D"==============NOTES============="
       "=================="$0D"If model2 key is used you need to add an origin"
       " brush to reference the point of origin of the model."$0D"If an origin"
       " brush is used the you must select the origin brush first then all oth"
       "er brushes that make up this entity. Then create this entity."
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "START_OPEN"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "FORCE_ACTIVATE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "CRUSHER"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "TOGGLE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "LOCKED"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "PLAYER_USE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
    }
    func_plat:form =
    {
      help = "===========DESCRIPTION============================"$0D"This is a"
       " simple vertical mover. Similar to func_door but up and down."$0D"===="
       "=======SPAWNFLAGS============================="$0D"PLAYER_USE - Player"
       " can use it with the use button."$0D"INACTIVE - Must be used by a targ"
       "et_activate before it can be used."$0D"===========KEYS&VALUES========="
       "==================="$0D"'lip' - Default 8, protrusion above rest posit"
       "ion."$0D"'height' - Total height of movement, defaults to model height"
       "."$0D"'speed' - Overrides default 200."$0D"'dmg' - Overrides default 2"
       "."$0D"'model2' - .md3 model to also draw."$0D"'color' - ConstantLight "
       "color. (Default setup with light entity selected press K to bring up c"
       "olor picker.)"$0D"'light' - ConstantLight radius."$0D"================"
       "=================================="$0D"'_lightmapscale' - Floating poi"
       "nt value scaling the resolution of lightmaps on brushes/patches in thi"
       "s entity (default 1.0)."$0D"'_cs' OR '_castshadows' - Allows per-entit"
       "y control over shadow casting. Defaults to 0 on entities, 1 on world. "
       "0 = no shadow casting. 1 = cast shadows on world. > 1 = cast shadows o"
       "n entities with _rs (or _receiveshadows) with the corresponding value,"
       " AND world. Negative values imply same, but DO NOT cast shadows on wor"
       "ld."$0D"'_rs' OR '_receiveshadows' - Allows per-entity control over sh"
       "adow reception. Defaults to 1 on everything (world shadows). 0 = recei"
       "ves NO shadows. > 1 = receive shadows only from corresponding keyed en"
       "tities (see above) and world. < 1 = receive shadows ONLY from correspo"
       "nding keyed entities."$0D"'_celshader' - Sets the cel shader used for "
       "this geometry. Note: omit the 'textures/' prefix."$0D"'_indexmap' OR '"
       "alphamap' - Path/name for the art file used to guide the mapping of te"
       "xtures on the terrain surface."$0D"'_layer' OR 'layers' - Integer valu"
       "e is the number of unique root shaders that will be use on the terrain"
       "."$0D"'_shader' OR 'shader' - Path to the metashader used to assign te"
       "xtures to the terrain entity. Note: Omit the 'textures/' prefix."$0D"'"
       "script_targetname' - Referred to by script as the recipient of set of "
       "instructions. Most entities can use this key."$0D"==============NOTES="
       "=============================="$0D"Plats are always drawn in the exten"
       "ded position so they will light correctly."$0D"If model2 key is used y"
       "ou need to add an origin brush to reference the point of origin of the"
       " model."$0D"If an origin brush is used the you must select the origin "
       "brush first then all other brushes that make up this entity. Then crea"
       "te this entity."
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "PLAYER_USE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
    }
    func_button:form =
    {
      help = "===========DESCRIPTION============================"$0D"This is a"
       " entity that is turned into a usable entity or 'switch' that can be us"
       "ed or influenced by player to effect another."$0D"===========SPAWNFLAG"
       "S============================="$0D"PLAYER_USE - Player can use it with"
       " the use button."$0D"INACTIVE - Must be used by a target_activate befo"
       "re it can be used."$0D"===========KEYS&VALUES========================="
       "==="$0D"'model2' - .md3 model to also draw."$0D"'angle' - Determines t"
       "he opening direction."$0D"'target' - All entities with a matching targ"
       "etname will be used."$0D"'speed' - override the default 40 speed."$0D"'"
       "wait' - Override the default 1 second wait (-1 = never return)."$0D"'l"
       "ip' - Override the default 4 pixel lip remaining at end of move."$0D"'"
       "health' - If set, the button must be killed instead of touched."$0D"'c"
       "olor' - ConstantLight color. (Default setup with light entity selected"
       " press K to bring up color picker.)"$0D"'light' - ConstantLight radius"
       "."$0D"=================================================="$0D"'_lightma"
       "pscale' - Floating point value scaling the resolution of lightmaps on "
       "brushes/patches in this entity (default 1.0)."$0D"'_cs' OR '_castshado"
       "ws' - Allows per-entity control over shadow casting. Defaults to 0 on "
       "entities, 1 on world. 0 = no shadow casting. 1 = cast shadows on world"
       ". > 1 = cast shadows on entities with _rs (or _receiveshadows) with th"
       "e corresponding value, AND world. Negative values imply same, but DO N"
       "OT cast shadows on world."$0D"'_rs' OR '_receiveshadows' - Allows per-"
       "entity control over shadow reception. Defaults to 1 on everything (wor"
       "ld shadows). 0 = receives NO shadows. > 1 = receive shadows only from "
       "corresponding keyed entities (see above) and world. < 1 = receive shad"
       "ows ONLY from corresponding keyed entities."$0D"'_celshader' - Sets th"
       "e cel shader used for this geometry. Note: omit the 'textures/' prefix"
       "."$0D"'_indexmap' OR 'alphamap' - Path/name for the art file used to g"
       "uide the mapping of textures on the terrain surface."$0D"'_layer' OR '"
       "layers' - Integer value is the number of unique root shaders that will"
       " be use on the terrain."$0D"'_shader' OR 'shader' - Path to the metash"
       "ader used to assign textures to the terrain entity. Note: Omit the 'te"
       "xtures/' prefix."$0D"==============NOTES=============================="
       "="$0D"When a button is touched, it moves some distance in the directio"
       "n of it's angle, triggers all of it's targets, waits some time, then r"
       "eturns to it's original position where it can be triggered again."$0D"I"
       "f model2 key is used you need to add an origin brush to reference the "
       "point of origin of the model."$0D"If an origin brush is used the you m"
       "ust select the origin brush first then all other brushes that make up "
       "this entity. Then create this entity."
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "PLAYER_USE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
    }
    path_corner:form =
    {
      help = "===========DESCRIPTION============================"$0D"Train pat"
       "h corners."$0D"===========KEYS&VALUES============================"$0D"'"
       "target' - Next path corner and other targets to fire."$0D"'targetname'"
       " - the name of this particular path_corner, pointed at by the previous"
       " path_corner or the func_train."$0D"'speed' - Speed to move to the nex"
       "t corner. This overrides the Speed set in func_train."$0D"'wait' - Sec"
       "onds to wait before beginning to move to next corner."$0D"============"
       "==NOTES==============================="$0D"path_corner entities MUST N"
       "OT be in a structural brush!"
      bbox = '-8 -8 -8 8 8 8'
    }
    func_train:form =
    {
      help = "===========DESCRIPTION============================"$0D"A train i"
       "s a mover that moves between path_corner target points."$0D"=========="
       "=SPAWNFLAGS============================="$0D"START_ON - Default to sta"
       "rt not running and must be triggered, this starts it running in world "
       "start."$0D"TOGGLE - Keep firing until used again (fires at intervals o"
       "f 'wait')"$0D"BLOCK_STOPS - anything in the func_train path will stop "
       "the train. The opposite of CRUSH_THROUGH."$0D"CRUSH_THROUGH - spawnfla"
       "g combined with a dmg value will make the train pass through entities "
       "and damage them on contact as well."$0D"PLAYER_USE - Player can use it"
       " with the use button."$0D"INACTIVE - Starts ready to be triggered, thi"
       "s sets it in need of activation first by means of a target_activate."$0D
       "===========KEYS&VALUES============================"$0D"'model2' - .md3"
       " model to also draw."$0D"'speed' - Default 100."$0D"'dmg' - Default   "
       " 2"$0D"'target' - Next path corner."$0D"'color' - ConstantLight color."
       " (Default setup with light entity selected press K to bring up color p"
       "icker.)"$0D"'light' - ConstantLight radius."$0D"======================"
       "============================"$0D"'_lightmapscale' - Floating point val"
       "ue scaling the resolution of lightmaps on brushes/patches in this enti"
       "ty (default 1.0)."$0D"'_cs' OR '_castshadows' - Allows per-entity cont"
       "rol over shadow casting. Defaults to 0 on entities, 1 on world. 0 = no"
       " shadow casting. 1 = cast shadows on world. > 1 = cast shadows on enti"
       "ties with _rs (or _receiveshadows) with the corresponding value, AND w"
       "orld. Negative values imply same, but DO NOT cast shadows on world."$0D
       "'_rs' OR '_receiveshadows' - Allows per-entity control over shadow rec"
       "eption. Defaults to 1 on everything (world shadows). 0 = receives NO s"
       "hadows. > 1 = receive shadows only from corresponding keyed entities ("
       "see above) and world. < 1 = receive shadows ONLY from corresponding ke"
       "yed entities."$0D"'_celshader' - Sets the cel shader used for this geo"
       "metry. Note: omit the 'textures/' prefix."$0D"'_indexmap' OR 'alphamap"
       "' - Path/name for the art file used to guide the mapping of textures o"
       "n the terrain surface."$0D"'_layer' OR 'layers' - Integer value is the"
       " number of unique root shaders that will be use on the terrain."$0D"'_"
       "shader' OR 'shader' - Path to the metashader used to assign textures t"
       "o the terrain entity. Note: Omit the 'textures/' prefix."$0D"'script_t"
       "argetname' - Referred to by script as the recipient of set of instruct"
       "ions. Most entities can use this key."$0D"==============NOTES========="
       "======================"$0D"Trains MUST HAVE AN ORIGIN BRUSH."$0D"The t"
       "rain spawns at the first target it is pointing at."$0D"If model2 key i"
       "s used you need to add an origin brush to reference the point of origi"
       "n of the model."$0D"If an origin brush is used the you must select the"
       " origin brush first then all other brushes that make up this entity. T"
       "hen create this entity."
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "START_ON"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "TOGGLE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "BLOCK_STOPS"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X32"
        cap = "CRUSH_THROUGH"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "PLAYER_USE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
    }
    func_static:form =
    {
      help = "===========DESCRIPTION============================"$0D"A bmodel "
       "that just sits there, doing nothing.  Can be used for conditional wall"
       "s and models."$0D"===========SPAWNFLAGS============================="$0D
       "F_PUSH - Will be used when you Force-Push it."$0D"F_PULL - Will be use"
       "d when you Force-Pull it."$0D"SWITCH_SHADER - Toggle the shader anim f"
       "rame between 1 and 2 when used."$0D"CRUSHER - Make it do damage when i"
       "t's blocked."$0D"IMPACT - Make it do damage when it hits any entity."$0D
       "PLAYER_USE - Player can use it with the use button."$0D"INACTIVE - Mus"
       "t be used by a target_activate before it can be used."$0D"BROADCAST - "
       "Dangerous to use, makes entity visible across the entire map regardles"
       "s of VIS."$0D"===========KEYS&VALUES============================"$0D"'"
       "model2' - .md3 model to also draw."$0D"'model2scale' - Percent of norm"
       "al scale (on all x y and z axis) to scale the model2 if there is one. "
       "100 is normal scale, min is 1 (100 times smaller than normal), max is "
       "1000 (ten times normal)."$0D"'color' - ConstantLight color. (Default s"
       "etup with light entity selected press K to bring up color picker.)"$0D
       "'light' - ConstantLight radius."$0D"'dmg' - How much damage to do when"
       " it crushes (use with CRUSHER spawnflag)."$0D"'linear' - Set to 1 and "
       "it will move linearly rather than with acceleration (default is 0)."$0D
       "=================================================="$0D"'_lightmapscale"
       "' - Floating point value scaling the resolution of lightmaps on brushe"
       "s/patches in this entity (default 1.0)."$0D"'_cs' OR '_castshadows' - "
       "Allows per-entity control over shadow casting. Defaults to 0 on entiti"
       "es, 1 on world. 0 = no shadow casting. 1 = cast shadows on world. > 1 "
       "= cast shadows on entities with _rs (or _receiveshadows) with the corr"
       "esponding value, AND world. Negative values imply same, but DO NOT cas"
       "t shadows on world."$0D"'_rs' OR '_receiveshadows' - Allows per-entity"
       " control over shadow reception. Defaults to 1 on everything (world sha"
       "dows). 0 = receives NO shadows. > 1 = receive shadows only from corres"
       "ponding keyed entities (see above) and world. < 1 = receive shadows ON"
       "LY from corresponding keyed entities."$0D"'_celshader' - Sets the cel "
       "shader used for this geometry. Note: omit the 'textures/' prefix."$0D"'"
       "_indexmap' OR 'alphamap' - Path/name for the art file used to guide th"
       "e mapping of textures on the terrain surface."$0D"'_layer' OR 'layers'"
       " - Integer value is the number of unique root shaders that will be use"
       " on the terrain."$0D"'_shader' OR 'shader' - Path to the metashader us"
       "ed to assign textures to the terrain entity. Note: Omit the 'textures/"
       "' prefix."$0D"'script_targetname' - Referred to by script as the recip"
       "ient of set of instructions. Most entities can use this key."$0D"====="
       "=========NOTES==============================="$0D"If non-visible brush"
       " is turned into a func_static and one of the force spawnflags are used"
       " the force influence (blue swirl force indicator thingy) doesn't show "
       "but is still force influence able."$0D"If model2 key is used you need "
       "to add an origin brush to reference the point of origin of the model."$0D
       "If an origin brush is used the you must select the origin brush first "
       "then all other brushes that make up this entity. Then create this enti"
       "ty."
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "F_PUSH"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "F_PULL"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "SWITCH_SHADER"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "CRUSHER"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "IMPACT"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "PLAYER_USE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X256"
        cap = "BROADCAST"
      }
    }
    func_rotating:form =
    {
      help = "===========DESCRIPTION============================"$0D"Bmodel th"
       "at rotates on Z axis by default."$0D"===========SPAWNFLAGS============"
       "================="$0D"START_ON - Defaults to start not running and mus"
       "t be triggered, this starts it running in world start."$0D"RADAR - Sho"
       "ws up on Radar in Siege mode (good for asteroids when you're in a ship"
       ")."$0D"X_AXIS - Causes its rotation on the X axis."$0D"Y_AXIS - Causes"
       " its rotation on the Y axis."$0D"IMPACT - Kills anything on impact whe"
       "n rotating (10000 points of damage, unless specified otherwise)."$0D"P"
       "LAYER_USE - Player can use it with the use button."$0D"INACTIVE - Must"
       " be used by a target_activate before it can be used."$0D"===========KE"
       "YS&VALUES============================"$0D"'model2' - .md3 model to als"
       "o draw."$0D"'model2scale' - Percent of normal scale (on all x y and z "
       "axis) to scale the model2 if there is one. 100 is normal scale, min is"
       " 1 (100 times smaller than normal), max is 1000 (ten times normal)."$0D
       "'speed' - Determines how fast it moves; default value is 100."$0D"'dmg"
       "' - Damage to inflict when blocked (2 default)."$0D"'color' - Constant"
       "Light color. (Default setup with light entity selected press K to brin"
       "g up color picker.)"$0D"'light' - ConstantLight radius."$0D"'spinangle"
       "s' - Instead of using 'speed', you can set use this to set rotation on"
       " all 3 axes (pitch yaw and roll)."$0D"================================"
       "=================="$0D"'_lightmapscale' - Floating point value scaling"
       " the resolution of lightmaps on brushes/patches in this entity (defaul"
       "t 1.0)."$0D"'_cs' OR '_castshadows' - Allows per-entity control over s"
       "hadow casting. Defaults to 0 on entities, 1 on world. 0 = no shadow ca"
       "sting. 1 = cast shadows on world. > 1 = cast shadows on entities with "
       "_rs (or _receiveshadows) with the corresponding value, AND world. Nega"
       "tive values imply same, but DO NOT cast shadows on world."$0D"'_rs' OR"
       " '_receiveshadows' - Allows per-entity control over shadow reception. "
       "Defaults to 1 on everything (world shadows). 0 = receives NO shadows. "
       "> 1 = receive shadows only from corresponding keyed entities (see abov"
       "e) and world. < 1 = receive shadows ONLY from corresponding keyed enti"
       "ties."$0D"'_celshader' - Sets the cel shader used for this geometry. N"
       "ote: omit the 'textures/' prefix."$0D"'_indexmap' OR 'alphamap' - Path"
       "/name for the art file used to guide the mapping of textures on the te"
       "rrain surface."$0D"'_layer' OR 'layers' - Integer value is the number "
       "of unique root shaders that will be use on the terrain."$0D"'_shader' "
       "OR 'shader' - Path to the metashader used to assign textures to the te"
       "rrain entity. Note: Omit the 'textures/' prefix."$0D"'script_targetnam"
       "e' - Referred to by script as the recipient of set of instructions. Mo"
       "st entities can use this key."$0D"===================================="
       "=============="$0D"'health' - Default is 0"$0D"If health is set, the f"
       "ollowing key/values are available:"$0D"'numchunks' - Multiplies the nu"
       "mber of chunks spawned.  Chunk code tries to pick a good volume of chu"
       "nks, but you can alter this to scale the number of spawned chunks. (de"
       "fault 1)  (.5) is half as many chunks, (2) is twice as many chunks."$0D
       "'chunksize' - Scales up/down the chunk size by this number (default is"
       " 1)."$0D"'showhealth' - If non-0, will display the health bar on the h"
       "ud when the crosshair is over this entity (in siege)."$0D"'teamowner' "
       "- In siege this will specify which team this thing is 'owned' by. To t"
       "hat team the crosshair will highlight green, to the other team it will"
       " highlight red."$0D"Damage: Default is none."$0D"'splashDamage' - Dama"
       "ge to do."$0D"'splashRadius' - Radius for above damage."$0D"'team' - I"
       "f set, only this team can trip this trigger."$0D"0 - any"$0D"1 - red"$0D
       "2 - blue"$0D"Don't know if these work:"$0D"'color' - ConstantLight col"
       "or. (Default setup with light entity selected press K to bring up colo"
       "r picker.)"$0D"'light' - ConstantLight radius."$0D"'material' - Defaul"
       "t is '0 - MAT_METAL' - choose from this list:"$0D"0 = MAT_METAL       "
       " (basic blue-grey scorched-DEFAULT)"$0D"1 = MAT_GLASS        (glass li"
       "ke shards)"$0D"2 = MAT_ELECTRICAL    (sparks only)"$0D"3 = MAT_ELEC_ME"
       "TAL    (METAL2 chunks and sparks)"$0D"4 = MAT_DRK_STONE        (brown "
       "stone chunks)"$0D"5 = MAT_LT_STONE        (tan stone chunks)"$0D"6 = M"
       "AT_GLASS_METAL     (glass and METAL2 chunks)"$0D"7 = MAT_METAL2       "
       " (electronic type of metal)"$0D"8 = MAT_NONE        (no chunks)"$0D"9 "
       "= MAT_GREY_STONE    (grey colored stone)"$0D"10 = MAT_METAL3        (M"
       "ETAL and METAL2 chunk combo)"$0D"11 = MAT_CRATE1        (yellow multi-"
       "colored crate chunks)"$0D"12 = MAT_GRATE1        (grate chunks--looks "
       "horrible right now)"$0D"13 = MAT_ROPE        (for yavin_trial, no chun"
       "ks, just wispy bits )"$0D"14 = MAT_CRATE2        (red multi-colored cr"
       "ate chunks)"$0D"15 = MAT_WHITE_METAL     (white angular chunks for Stu"
       ", NS_hideout )"$0D"16 = MAT_SNOWY_ROCK    (mix of gray and brown rocks"
       ")"$0D"Applicable only during Siege gametype:"$0D"'teamnodmg' - If 1, t"
       "eam 1 can't damage this. If 2, team 2 can't damage this."$0D"========="
       "=====NOTES==============================="$0D"You need to have an orig"
       "in brush as part of this entity.  The center of that brush will be the"
       " point around which it is rotated. It will rotate around the Z axis by"
       " default.  You can check either the X_AXIS or Y_AXIS box to change tha"
       "t."$0D"If model2 key is used you need to add an origin brush to refere"
       "nce the point of origin of the model."$0D"If an origin brush is used t"
       "he you must select the origin brush first then all other brushes that "
       "make up this entity. Then create this entity."
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "START_ON"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "RADAR"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "X_AXIS"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "Y_AXIS"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "IMPACT"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "PLAYER_USE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
    }
    func_bobbing:form =
    {
      help = "===========DESCRIPTION============================"$0D"Entity th"
       "at waves like its on water or hovering. Normally bobs on the Z axis."$0D
       "===========SPAWNFLAGS============================="$0D"X_AXIS - Prefor"
       "m movement on X axis."$0D"Y_AXIS - Preform movement on Y axis."$0D"PLA"
       "YER_USE - Player can use it with the use button."$0D"INACTIVE - Must b"
       "e used by a target_activate before it can be used."$0D"===========KEYS"
       "&VALUES============================"$0D"'model2' - .md3 model to also "
       "draw."$0D"'height' - Amplitude of bob (32 default)."$0D"'speed' - Seco"
       "nds to complete a bob cycle (4 default)."$0D"'phase' - The 0.0 to 1.0 "
       "offset in the cycle to start at."$0D"'dmg' - Damage to inflict when bl"
       "ocked (2 default)."$0D"'color' - ConstantLight color. (Default setup w"
       "ith light entity selected press K to bring up color picker.)"$0D"'ligh"
       "t' - ConstantLight radius."$0D"======================================="
       "==========="$0D"'_lightmapscale' - Floating point value scaling the re"
       "solution of lightmaps on brushes/patches in this entity (default 1.0)."
       $0D"'_cs' OR '_castshadows' - Allows per-entity control over shadow cas"
       "ting. Defaults to 0 on entities, 1 on world. 0 = no shadow casting. 1 "
       "= cast shadows on world. > 1 = cast shadows on entities with _rs (or _"
       "receiveshadows) with the corresponding value, AND world. Negative valu"
       "es imply same, but DO NOT cast shadows on world."$0D"'_rs' OR '_receiv"
       "eshadows' - Allows per-entity control over shadow reception. Defaults "
       "to 1 on everything (world shadows). 0 = receives NO shadows. > 1 = rec"
       "eive shadows only from corresponding keyed entities (see above) and wo"
       "rld. < 1 = receive shadows ONLY from corresponding keyed entities."$0D
       "'_celshader' - Sets the cel shader used for this geometry. Note: omit "
       "the 'textures/' prefix."$0D"'_indexmap' OR 'alphamap' - Path/name for "
       "the art file used to guide the mapping of textures on the terrain surf"
       "ace."$0D"'_layer' OR 'layers' - Integer value is the number of unique "
       "root shaders that will be use on the terrain."$0D"'_shader' OR 'shader"
       "' - Path to the metashader used to assign textures to the terrain enti"
       "ty. Note: Omit the 'textures/' prefix."$0D"'script_targetname' - Refer"
       "red to by script as the recipient of set of instructions. Most entitie"
       "s can use this key."$0D"==============NOTES==========================="
       "===="$0D"If model2 key is used you need to add an origin brush to refe"
       "rence the point of origin of the model."$0D"If an origin brush is used"
       " the you must select the origin brush first then all other brushes tha"
       "t make up this entity. Then create this entity."
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "X_AXIS"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "Y_AXIS"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "PLAYER_USE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
    }
    func_pendulum:form =
    {
      help = "===========DESCRIPTION============================"$0D"An almost"
       " incomplete entity. This entity causes a swinging back and forth from "
       "the point of origin."$0D"===========SPAWNFLAGS========================"
       "====="$0D"X_AXIS - Performs movement on X axis. (This is a test to see"
       " if this works.)"$0D"Y_AXIS - Performs movement on Y axis. (This is a "
       "test to see if this works.)"$0D"PLAYER_USE - Player can use it with th"
       "e use button."$0D"INACTIVE - Must be used by a target_activate before "
       "it can be used."$0D"===========KEYS&VALUES============================"
       $0D"'model2' - .md3 model to also draw."$0D"'speed' - The number of deg"
       "rees each way the pendulum swings, (30 default)."$0D"'phase' - The 0.0"
       " to 1.0 offset in the cycle to start at."$0D"'dmg' - Damage to inflict"
       " when blocked (2 default)."$0D"'color' - ConstantLight color. (Default"
       " setup with light entity selected press K to bring up color picker.)"$0D
       "'light' - ConstantLight radius."$0D"=================================="
       "================"$0D"'_lightmapscale' - Floating point value scaling t"
       "he resolution of lightmaps on brushes/patches in this entity (default "
       "1.0)."$0D"'_cs' OR '_castshadows' - Allows per-entity control over sha"
       "dow casting. Defaults to 0 on entities, 1 on world. 0 = no shadow cast"
       "ing. 1 = cast shadows on world. > 1 = cast shadows on entities with _r"
       "s (or _receiveshadows) with the corresponding value, AND world. Negati"
       "ve values imply same, but DO NOT cast shadows on world."$0D"'_rs' OR '"
       "_receiveshadows' - Allows per-entity control over shadow reception. De"
       "faults to 1 on everything (world shadows). 0 = receives NO shadows. > "
       "1 = receive shadows only from corresponding keyed entities (see above)"
       " and world. < 1 = receive shadows ONLY from corresponding keyed entiti"
       "es."$0D"'_celshader' - Sets the cel shader used for this geometry. Not"
       "e: omit the 'textures/' prefix."$0D"'_indexmap' OR 'alphamap' - Path/n"
       "ame for the art file used to guide the mapping of textures on the terr"
       "ain surface."$0D"'_layer' OR 'layers' - Integer value is the number of"
       " unique root shaders that will be use on the terrain."$0D"'_shader' OR"
       " 'shader' - Path to the metashader used to assign textures to the terr"
       "ain entity. Note: Omit the 'textures/' prefix."$0D"'script_targetname'"
       " - Referred to by script as the recipient of set of instructions. Most"
       " entities can use this key."$0D"==============NOTES==================="
       "============"$0D"You need to have an origin brush as part of this enti"
       "ty."$0D"Pendulums always swing north / south on un-rotated models.  Ad"
       "d an angles field to the model to allow rotation in other directions."$0D
       "Pendulum frequency is a physical constant based on the length of the b"
       "eam and gravity."$0D"If model2 key is used you need to add an origin b"
       "rush to reference the point of origin of the model."$0D"If an origin b"
       "rush is used the you must select the origin brush first then all other"
       " brushes that make up this entity. Then create this entity."
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "X_AXIS"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "Y_AXIS"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "PLAYER_USE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
    }
    func_breakable:form =
    {
      help = "===========DESCRIPTION============================"$0D"Causes a "
       "bmodel to be breakable and project fx and pieces."$0D"===========SPAWN"
       "FLAGS============================="$0D"INVINCIBLE - Can only be broken"
       " by being used."$0D"IMPACT - Does damage on impact."$0D"CRUSHER - Won'"
       "t reverse movement when hit an obstacle."$0D"THIN - Can be broken by i"
       "mpact damage, like glass."$0D"SABERONLY - Only takes damage from saber"
       "s."$0D"HEAVY_WEAP - Only takes damage by a heavy weapon, like an empla"
       "ced gun or AT-ST gun."$0D"USE_NOT_BREAK - Using it doesn't make it bre"
       "ak, still can be destroyed by damage."$0D"PLAYER_USE - Player can use "
       "it with the use button."$0D"NO_EXPLOSION - Does not play an explosion "
       "effect, though will still create chunks if specified."$0D"===========M"
       "OVIE BATTLES II SPECIFIC SPAWNFLAGS==========="$0D"NO_SABERTHROW_DMG -"
       " Does not take damage from thrown lightsabers."$0D"SHOW_DAMAGE - Displ"
       "ays damage dealt to it in form of floating numbers."$0D"===========KEY"
       "S&VALUES============================"$0D"'targetname' - Entities with "
       "matching target will fire it."$0D"'paintarget' - Target to fire when h"
       "it (but not destroyed)."$0D"'wait' - How long minimum to wait between "
       "firing pain target each time hit."$0D"'delay' - When killed or used, h"
       "ow long (in seconds) to wait before blowing up (none by default)."$0D"'"
       "model2' - .md3 model to also draw."$0D"'target' - All entities with a "
       "matching targetname will be used when this is destroyed."$0D"'health' "
       "   - Default is 10."$0D"'numchunks' - Multiplies the number of chunks "
       "spawned.  Chunk code tries to pick a good volume of chunks, but you ca"
       "n alter this to scale the number of spawned chunks. (default 1)  (.5) "
       "is half as many chunks, (2) is twice as many chunks."$0D"'chunksize' -"
       " Scales up/down the chunk size by this number (default is 1)"$0D"'play"
       "fx' - Path of effect to play on death."$0D"===========MOVIE BATTLES II"
       " SPECIFIC KEYS&VALUES==========="$0D"'dmgcolor' - Color of floating nu"
       "mbers when it receives damage (ONLY IF SHOW_DAMAGE IS ENABLED)"$0D"'dm"
       "gsize' - Size of floating numers when it receives damage (ONLY IF SHOW"
       "_DAMAGE IS ENABLED)"$0D"'dmgduration' - Duration in milliseconds of fl"
       "oating numbers when it receives damage (ONLY IF SHOW_DAMAGE IS ENABLED"
       ")"$0D"=================================================="$0D"'_lightma"
       "pscale' - Floating point value scaling the resolution of lightmaps on "
       "brushes/patches in this entity (default 1.0)."$0D"'_cs' OR '_castshado"
       "ws' - Allows per-entity control over shadow casting. Defaults to 0 on "
       "entities, 1 on world. 0 = no shadow casting. 1 = cast shadows on world"
       ". > 1 = cast shadows on entities with _rs (or _receiveshadows) with th"
       "e corresponding value, AND world. Negative values imply same, but DO N"
       "OT cast shadows on world."$0D"'_rs' OR '_receiveshadows' - Allows per-"
       "entity control over shadow reception. Defaults to 1 on everything (wor"
       "ld shadows). 0 = receives NO shadows. > 1 = receive shadows only from "
       "corresponding keyed entities (see above) and world. < 1 = receive shad"
       "ows ONLY from corresponding keyed entities."$0D"'_celshader' - Sets th"
       "e cel shader used for this geometry. Note: omit the 'textures/' prefix"
       "."$0D"'_indexmap' OR 'alphamap' - Path/name for the art file used to g"
       "uide the mapping of textures on the terrain surface."$0D"'_layer' OR '"
       "layers' - Integer value is the number of unique root shaders that will"
       " be use on the terrain."$0D"'_shader' OR 'shader' - Path to the metash"
       "ader used to assign textures to the terrain entity. Note: Omit the 'te"
       "xtures/' prefix."$0D"'script_targetname' - Referred to by script as th"
       "e recipient of set of instructions. Most entities can use this key."$0D
       "=================================================="$0D"'showhealth' if"
       " non-0, will display the health bar on the hud when the crosshair is o"
       "ver this entity (in siege)"$0D"'teamowner' in siege this will specify "
       "which team this thing is 'owned' by. To that team the crosshair will h"
       "ighlight green, to the other team it will highlight red."$0D"Damage: D"
       "efault is none."$0D"'splashDamage' - Damage to do."$0D"'splashRadius' "
       "- Radius for above damage."$0D"'team' - If set, only this team can tri"
       "p this trigger."$0D"0 - any"$0D"1 - red"$0D"2 - blue"$0D"Don't know if"
       " these work:"$0D"'color' - ConstantLight color. (Default setup with li"
       "ght entity selected press K to bring up color picker.)"$0D"'light' - C"
       "onstantLight radius."$0D"'material' - default is '0 - MAT_METAL' - cho"
       "ose from this list:"$0D"0 =  MAT_METAL         (basic blue-grey scorch"
       "ed-DEFAULT)"$0D"1 =  MAT_GLASS"$0D"2 =  MAT_ELECTRICAL     (sparks onl"
       "y)"$0D"3 =  MAT_ELEC_METAL  (METAL2 chunks and sparks)"$0D"4 =  MAT_DR"
       "K_STONE      (brown stone chunks)"$0D"5 =  MAT_LT_STONE     (tan stone"
       " chunks)"$0D"6 =  MAT_GLASS_METAL (glass and METAL2 chunks)"$0D"7 =  M"
       "AT_METAL2         (electronic type of metal)"$0D"8 =  MAT_NONE        "
       " (no chunks)"$0D"9 =  MAT_GREY_STONE     (grey colored stone)"$0D"10 ="
       " MAT_METAL3         (METAL and METAL2 chunk combo)"$0D"11 = MAT_CRATE1"
       "         (yellow multi-colored crate chunks)"$0D"12 = MAT_GRATE1      "
       "   (grate chunks--looks horrible right now)"$0D"13 = MAT_ROPE         "
       "(for yavin_trial, no chunks, just wispy bits )"$0D"14 = MAT_CRATE2    "
       "     (red multi-colored crate chunks)"$0D"15 = MAT_WHITE_METAL (white "
       "angular chunks for Stu, NS_hideout )"$0D"16 = MAT_SNOWY_ROCK     (mix "
       "of gray and brown rocks)"$0D"Applicable only during Siege gametype:"$0D
       "'teamnodmg' - if 1, team 1 can't damage this. If 2, team 2 can't damag"
       "e this."$0D"==============NOTES==============================="$0D"Whe"
       "n destroyed, fires it's trigger and chunks and plays sound 'noise' or "
       "sound for type if no noise specified."$0D"If model2 key is used you ne"
       "ed to add an origin brush to reference the point of origin of the mode"
       "l."$0D"If an origin brush is used the you must select the origin brush"
       " first then all other brushes that make up this entity. Then create th"
       "is entity."
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "INVINCIBLE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "IMPACT"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "CRUSHER"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "THIN"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "SABERONLY"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X32"
        cap = "HEAVY_WEAP"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "USE_NOT_BREAK"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "PLAYER_USE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X256"
        cap = "NO_EXPLOSION"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X512"
        cap = "NO_SABERTHROW_DMG"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X1024"
        cap = "SHOW_DAMAGE"
      }
    }
    func_glass:form =
    {
      help = "===========DESCRIPTION============================"$0D"Breakable"
       " glass. Causes a bmodel to break like glass."$0D"===========SPAWNFLAGS"
       "============================="$0D"PLAYER_USE - Player can use it with "
       "the use button."$0D"INACTIVE - Must be used by a target_activate befor"
       "e it can be used."$0D"===========KEYS&VALUES=========================="
       "=="$0D"'model2' - .md3 model to also draw."$0D"'color' - ConstantLight"
       " color. (Default setup with light entity selected press K to bring up "
       "color picker.)"$0D"'light' - ConstantLight radius."$0D"'maxshards' - M"
       "ax number of shards to spawn on glass break."$0D"====================="
       "============================="$0D"'_lightmapscale' - Floating point va"
       "lue scaling the resolution of lightmaps on brushes/patches in this ent"
       "ity (default 1.0)."$0D"'_cs' OR '_castshadows' - Allows per-entity con"
       "trol over shadow casting. Defaults to 0 on entities, 1 on world. 0 = n"
       "o shadow casting. 1 = cast shadows on world. > 1 = cast shadows on ent"
       "ities with _rs (or _receiveshadows) with the corresponding value, AND "
       "world. Negative values imply same, but DO NOT cast shadows on world."$0D
       "'_rs' OR '_receiveshadows' - Allows per-entity control over shadow rec"
       "eption. Defaults to 1 on everything (world shadows). 0 = receives NO s"
       "hadows. > 1 = receive shadows only from corresponding keyed entities ("
       "see above) and world. < 1 = receive shadows ONLY from corresponding ke"
       "yed entities."$0D"'_celshader' - Sets the cel shader used for this geo"
       "metry. Note: omit the 'textures/' prefix."$0D"'_indexmap' OR 'alphamap"
       "' - Path/name for the art file used to guide the mapping of textures o"
       "n the terrain surface."$0D"'_layer' OR 'layers' - Integer value is the"
       " number of unique root shaders that will be use on the terrain."$0D"'_"
       "shader' OR 'shader' - Path to the metashader used to assign textures t"
       "o the terrain entity. Note: Omit the 'textures/' prefix."$0D"'script_t"
       "argetname' - Referred to by script as the recipient of set of instruct"
       "ions. Most entities can use this key."$0D"==============NOTES========="
       "======================"$0D"If model2 key is used you need to add an or"
       "igin brush to reference the point of origin of the model."$0D"If an or"
       "igin brush is used the you must select the origin brush first then all"
       " other brushes that make up this entity. Then create this entity."
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "PLAYER_USE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
    }
    func_usable:form =
    {
      help = "===========DESCRIPTION============================"$0D"A bmodel "
       "that just sits there, doing nothing.  Can be used for conditional wall"
       "s and models."$0D"===========SPAWNFLAGS============================="$0D
       "START_OFF - The wall will not be there."$0D"ALWAYS_ON - Doesn't toggle"
       " on and off when used, just runs usescript and fires target."$0D"PLAYE"
       "R_USE - Player can use it with the use button."$0D"INACTIVE - Must be "
       "used by a target_activate before it can be used."$0D"DONOTTRAP - When "
       "toggled on, wait until space is clear of players before appearing"$0D"M"
       "OVER_RGB (MOVIE BATTLES II SPECIFIC) - Allows the brushes to be dynami"
       "cally vertex colored when switching team ownership."$0D"===========KEY"
       "S&VALUES============================"$0D"'targetname' - When used, wil"
       "l toggle on and off"$0D"'target' - Will fire this target every time it"
       " is toggled OFF"$0D"'model2' - .md3 model to also draw"$0D"'color' - C"
       "onstantLight color. (Default setup with light entity selected press K "
       "to bring up color picker.)"$0D"'light' - ConstantLight radius"$0D"'use"
       "script' - Script to run when turned on"$0D"'deathscript' - Script to r"
       "un when turned off"$0D"'wait' - Amount of time before the object is us"
       "able again (only valid with ALWAYS_ON flag)"$0D"'health' - If it has h"
       "ealth, it will be used whenever shot at/killed - if you want it to onl"
       "y be used once this way, set health to 1"$0D"'endframe' - Will make it"
       " animate to next shader frame when used, not turn on/off... set this t"
       "o number of frames in the shader, minus 1."$0D"teamuser - If 1, team 2"
       " can't use this. If 2, team 1 can't use this. (Applicable only during "
       "Siege gametype)"$0D"=================================================="
       $0D"'_lightmapscale' - Floating point value scaling the resolution of l"
       "ightmaps on brushes/patches in this entity (default 1.0)."$0D"'_cs' OR"
       " '_castshadows' - Allows per-entity control over shadow casting. Defau"
       "lts to 0 on entities, 1 on world. 0 = no shadow casting. 1 = cast shad"
       "ows on world. > 1 = cast shadows on entities with _rs (or _receiveshad"
       "ows) with the corresponding value, AND world. Negative values imply sa"
       "me, but DO NOT cast shadows on world."$0D"'_rs' OR '_receiveshadows' -"
       " Allows per-entity control over shadow reception. Defaults to 1 on eve"
       "rything (world shadows). 0 = receives NO shadows. > 1 = receive shadow"
       "s only from corresponding keyed entities (see above) and world. < 1 = "
       "receive shadows ONLY from corresponding keyed entities."$0D"'_celshade"
       "r' - Sets the cel shader used for this geometry. Note: omit the 'textu"
       "res/' prefix."$0D"'_indexmap' OR 'alphamap' - Path/name for the art fi"
       "le used to guide the mapping of textures on the terrain surface."$0D"'"
       "_layer' OR 'layers' - Integer value is the number unique root shaders "
       "that will be use on the terrain."$0D"'_shader' OR 'shader' - Path to t"
       "he metashader used to assign textures to the terrain entity. Note: Omi"
       "t the 'textures/' prefix."$0D"'script_targetname' - Referred to by scr"
       "ipt as the recipient of set of instructions. Most entities can use thi"
       "s key."$0D"==============NOTES==============================="$0D"Make"
       "s a bmodel simply appear and disappear from world. Good to use for swi"
       "tches. (I.e. one brush with red or off texture and another with a gree"
       "n or on texture.) Alternating between them for which is visible."$0D"U"
       "se also as a force field or energy field on and off."$0D"If model2 key"
       " is used you need to add an origin brush to reference the point of ori"
       "gin of the model."$0D"An origin brush will not work with this entity. "
       "You will need to manually add the origin key and value directly to thi"
       "s entity in the entity window to allow scropted movement."
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "STARTOFF"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "ALWAYS_ON"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "DONOTTRAP"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "PLAYER_USE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X256"
        cap = "MOVER_RGB"
      }
    }
    func_wall:form =
    {
      help = "===========DESCRIPTION============================"$0D"A bmodel "
       "that just sits there, doing nothing.  Can be used for conditional wall"
       "s and models."$0D"===========SPAWNFLAGS============================="$0D
       "START_OFF - The wall will not be there."$0D"PLAYER_USE - Player can us"
       "e it with the use button."$0D"INACTIVE - Must be used by a target_acti"
       "vate before it can be used."$0D"===========KEYS&VALUES================"
       "============"$0D"'model2' - .md3 model to also draw."$0D"'color' - Con"
       "stantLight color (Default setup with light entity selected press K to "
       "bring up color picker.)"$0D"'light' - ConstantLight radius."$0D"======"
       "============================================"$0D"'_lightmapscale' - Fl"
       "oating point value scaling the resolution of lightmaps on brushes/patc"
       "hes in this entity (default 1.0)."$0D"'_cs' OR '_castshadows' - Allows"
       " per-entity control over shadow casting. Defaults to 0 on entities, 1 "
       "on world. 0 = no shadow casting. 1 = cast shadows on world. > 1 = cast"
       " shadows on entities with _rs (or _receiveshadows) with the correspond"
       "ing value, AND world. Negative values imply same, but DO NOT cast shad"
       "ows on world."$0D"'_rs' OR '_receiveshadows' - Allows per-entity contr"
       "ol over shadow reception. Defaults to 1 on everything (world shadows)."
       " 0 = receives NO shadows. > 1 = receive shadows only from correspondin"
       "g keyed entities (see above) and world. < 1 = receive shadows ONLY fro"
       "m corresponding keyed entities."$0D"'_celshader' - Sets the cel shader"
       " used for this geometry. Note: omit the 'textures/' prefix."$0D"'_inde"
       "xmap' OR 'alphamap' - Path/name for the art file used to guide the map"
       "ping of textures on the terrain surface."$0D"'_layer' OR 'layers' - In"
       "teger value is the number of unique root shaders that will be use on t"
       "he terrain."$0D"'_shader' OR 'shader' - Path to the metashader used to"
       " assign textures to the terrain entity. Note: Omit the 'textures/' pre"
       "fix."$0D"'script_targetname' - Referred to by script as the recipient "
       "of set of instructions. Most entities can use this key."$0D"=========="
       "====NOTES==============================="$0D"If model2 key is used you"
       " need to add an origin brush to reference the point of origin of the m"
       "odel."$0D"If an origin brush is used the you must select the origin br"
       "ush first then all other brushes that make up this entity. Then create"
       " this entity."
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "START_OFF"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X64"
        cap = "PLAYER_USE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X128"
        cap = "INACTIVE"
      }
    }
    waypoint:form =
    {
      help = "===========DESCRIPTION============================"$0D"A place t"
       "o go. A point of reference to send NPCs."$0D"===========SPAWNFLAGS===="
       "========================="$0D"SOLID_OK - only use if placing inside so"
       "lid is unavoidable in map, but may be clear in-game (i.e.: at the bott"
       "om of a tall, solid lift that starts at the top position)."$0D"======="
       "=======NOTES==============================="$0D"Radius is automaticall"
       "y calculated in-world."$0D"Waypoint: Are used to set the main routes o"
       "f navigation. They should be placed at intersections and in rooms. Any"
       " place where the player or an NPC can reach should be in view of a way"
       "point (with some certain exceptions, see below). Each one should be pl"
       "aced on the ground and with a direct clear path ("$22"clear path"$22" "
       "means a full player-size "$22"trace"$22") to at least one other waypoi"
       "nt. You may, however, place a waypoint by itself, if that is desirable"
       ". You connect waypoints to each other using the fields "$22"target"$22
       ", "$22"target2"$22", "$22"target3"$22", and "$22"target4"$22" (Radiant"
       " auto-manages these well and draws each of these connections). Waypoin"
       "ts are also auto-linked by the game at load time. These automatically "
       "generated connections are in addition to your manual connections. Alth"
       "ough waypoints don't need to be manually connected, connections you mi"
       "ght expect the game to generate may not occur and connections you did "
       "not anticipate may occur. So it is recommended that waypoints be manua"
       "lly connected to reflect a desired navigation flow. The basic rule is "
       "link where you definitely want a connection. Also bear in mind that al"
       "l of your manual connections will be verified (a trace will be done to"
       " assure that there is a full body-size clear trace between two connect"
       "ed waypoints). If a manual (or "$22"hard"$22") connection fails this t"
       "est, a warning is issued and the connection will not be used."
      bbox = '-16 -16 -24 16 16 32'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "SOLID_OK"
      }
    }
    waypoint_small:form =
    {
      help = "===========DESCRIPTION============================"$0D"A place t"
       "o go. A point of reference to send NPCs. (Same as waypoint only smalle"
       "r.)"$0D"===========SPAWNFLAGS============================="$0D"SOLID_O"
       "K - only use if placing inside solid is unavoidable in map, but may be"
       " clear in-game (i.e.: at the bottom of a tall, solid lift that starts "
       "at the top position)."$0D"==============NOTES========================="
       "======"$0D"Waypoint: Are used to set the main routes of navigation. Th"
       "ey should be placed at intersections and in rooms. Any place where the"
       " player or an NPC can reach should be in view of a waypoint (with some"
       " certain exceptions, see below). Each one should be placed on the grou"
       "nd and with a direct clear path ("$22"clear path"$22" means a full pla"
       "yer-size "$22"trace"$22") to at least one other waypoint. You may, how"
       "ever, place a waypoint by itself, if that is desirable. You connect wa"
       "ypoints to each other using the fields "$22"target"$22", "$22"target2"$22
       ", "$22"target3"$22", and "$22"target4"$22" (Radiant auto-manages these"
       " well and draws each of these connections). Waypoints are also auto-li"
       "nked by the game at load time. These automatically generated connectio"
       "ns are in addition to your manual connections. Although waypoints don'"
       "t need to be manually connected, connections you might expect the game"
       " to generate may not occur and connections you did not anticipate may "
       "occur. So it is recommended that waypoints be manually connected to re"
       "flect a desired navigation flow. The basic rule is link where you defi"
       "nitely want a connection. Also bear in mind that all of your manual co"
       "nnections will be verified (a trace will be done to assure that there "
       "is a full body-size clear trace between two connected waypoints). If a"
       " manual (or "$22"hard"$22") connection fails this test, a warning is i"
       "ssued and the connection will not be used."
      bbox = '-2 -2 -24 2 2 32'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "SOLID_OK"
      }
    }
    waypoint_navgoal:form =
    {
      help = "===========DESCRIPTION============================"$0D"A waypoin"
       "t for script navgoals. Not included in navigation data."$0D"=========="
       "=SPAWNFLAGS============================="$0D"SOLID_OK - only use if pl"
       "acing inside solid is unavoidable in map, but may be clear in-game (i."
       "e.: at the bottom of a tall, solid lift that starts at the top positio"
       "n)."$0D"===========KEYS&VALUES============================"$0D"'target"
       "name' - Name you would use in script when setting a navgoal. (See note"
       "s.)"$0D"'radius' - How far from the navgoal an entity can be before it"
       " thinks it reached it. Default is '0' which means no radius check, jus"
       "t have to touch it."$0D"==============NOTES==========================="
       "===="$0D"For example: if you give this waypoint a targetname of 'conso"
       "le', make an NPC go to it in a script like so:"$0D"set ('navgoal', 'co"
       "nsole');"$0D"Navigation Goals should be off the main waypoint network."
       $0D"They must have a clear path to at least one waypoint. These are spe"
       "cific destinations off of the main path and are used exclusively for s"
       "cripting (with the SET_NAVGOAL command). Basically an NPC will try to "
       "follow the waypoint network to reach this goal. You don't need waypoin"
       "ts exactly near a navgoal as long as there is a clear path between a n"
       "avgoal and any waypoint. A navgoal's radius may be used to decide when"
       " an NPC has reached the navgoal (so if the origin of an NPC, their cen"
       "ter, is within the radius of the navgoal, it will think it has reached"
       " it). Default radius is 12. A normal character's bounding box width is"
       " 32x32. So, obviously, you do not want to place a navgoal closer than "
       "16 to a wall. Placing it right up against the wall (so that its side i"
       "s coplanar with the wall) is too close. Always leave at least 1 unit b"
       "etween a navgoal's box and a wall. NOTE: there are no more variations "
       "of navgoals (such as "$22"waypoint_navgoal_2"$22", etc), only "$22"way"
       "point_navgoal"$22"."
      bbox = '-16 -16 -24 16 16 32'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "SOLID_OK"
      }
    }
    waypoint_navgoal_8:form =
    {
      help = "===========DESCRIPTION============================"$0D"A waypoin"
       "t for script navgoals, 8 x 8 size. Not included in navigation data."$0D
       "===========SPAWNFLAGS============================="$0D"SOLID_OK - only"
       " use if placing inside solid is unavoidable in map, but may be clear i"
       "n-game (i.e.: at the bottom of a tall, solid lift that starts at the t"
       "op position)."$0D"==============NOTES==============================="$0D
       "For example: if you give this waypoint a targetname of 'console', make"
       " an NPC go to it in a script like so:"$0D"set ('navgoal', 'console');"$0D
       "Navigation Goals should be off the main waypoint network. They must ha"
       "ve a clear path to at least one waypoint. These are specific destinati"
       "ons off of the main path and are used exclusively for scripting (with "
       "the SET_NAVGOAL command). Basically an NPC will try to follow the wayp"
       "oint network to reach this goal. You don't need waypoints exactly near"
       " a navgoal as long as there is a clear path between a navgoal and any "
       "waypoint. A navgoal's radius may be used to decide when an NPC has rea"
       "ched the navgoal (so if the origin of an NPC, their center, is within "
       "the radius of the navgoal, it will think it has reached it). Default r"
       "adius is 12. A normal character's bounding box width is 32x32. So, obv"
       "iously, you do not want to place a navgoal closer than 16 to a wall. P"
       "lacing it right up against the wall (so that its side is coplanar with"
       " the wall) is too close. Always leave at least 1 unit between a navgoa"
       "l's box and a wall. NOTE: there are no more variations of navgoals (su"
       "ch as "$22"waypoint_navgoal_2"$22", etc), only "$22"waypoint_navgoal"$22
       "."
      bbox = '-8 -8 -24 8 8 32'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "SOLID_OK"
      }
    }
    waypoint_navgoal_4:form =
    {
      help = "===========DESCRIPTION============================"$0D"A waypoin"
       "t for script navgoals, 4 x 4 size. Not included in navigation data."$0D
       "===========SPAWNFLAGS============================="$0D"SOLID_OK - only"
       " use if placing inside solid is unavoidable in map, but may be clear i"
       "n-game (i.e.: at the bottom of a tall, solid lift that starts at the t"
       "op position)."$0D"===========KEYS&VALUES============================"$0D
       "'targetname' - Name you would use in script when setting a navgoal. (S"
       "ee notes.)"$0D"==============NOTES==============================="$0D"F"
       "or example: if you give this waypoint a targetname of 'console', make "
       "an NPC go to it in a script like so:"$0D"set ('navgoal', 'console');"$0D
       "You CANNOT set a radius on these navgoals, they are touch-reach ONLY."$0D
       "Navigation Goals should be off the main waypoint network. They must ha"
       "ve a clear path to at least one waypoint. These are specific destinati"
       "ons off of the main path and are used exclusively for scripting (with "
       "the SET_NAVGOAL command). Basically an NPC will try to follow the wayp"
       "oint network to reach this goal. You don't need waypoints exactly near"
       " a navgoal as long as there is a clear path between a navgoal and any "
       "waypoint. A navgoal's radius may be used to decide when an NPC has rea"
       "ched the navgoal (so if the origin of an NPC, their center, is within "
       "the radius of the navgoal, it will think it has reached it). Default r"
       "adius is 12. A normal character's bounding box width is 32x32. So, obv"
       "iously, you do not want to place a navgoal closer than 16 to a wall. P"
       "lacing it right up against the wall (so that its side is coplanar with"
       " the wall) is too close. Always leave at least 1 unit between a navgoa"
       "l's box and a wall. NOTE: there are no more variations of navgoals (su"
       "ch as "$22"waypoint_navgoal_2"$22", etc), only "$22"waypoint_navgoal"$22
       "."
      bbox = '-4 -4 -24 4 4 32'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "SOLID_OK"
      }
    }
    waypoint_navgoal_2:form =
    {
      help = "===========DESCRIPTION============================"$0D"A waypoin"
