    NPC_Jedi:form =
    {
      help = "===========DESCRIPTION============================"$0D"Ally Jedi"
       " NPC Buddy - tags along with player."$0D"===========SPAWNFLAGS========"
       "====================="$0D"TRAINER - Special Jedi- instructor."$0D"CEIL"
       "ING - Sticks to the ceiling until he sees an enemy or takes pain."$0D"C"
       "INEMATIC - Will spawn with no default AI (BS_CINEMATIC)."$0D"NOTSOLID "
       "- Starts not solid."$0D"STARTINSOLID - Don't try to fix if spawn in so"
       "lid."$0D"SHY - Spawner is shy."$0D"===========KEYS&VALUES============="
       "==============="$0D"'targetname' - Name this NPC goes by for targeting"
       "."$0D"'target' - NPC will fire this when it spawns it's last NPC (shou"
       "ld this be when the last NPC it spawned dies?)."$0D"'target2' - Fired "
       "by stasis spawners when they try to spawn while their spawner model is"
       " broken."$0D"'target3' - Fired by spawner if they try to spawn and are"
       " blocked and have a wait < 0 (removes them)."$0D"'count' - How many NP"
       "Cs to spawn (only if targeted) default = 1."$0D"'wait' - If trying to "
       "spawn and blocked, how many seconds to wait before trying again (defau"
       "lt = 0.5, < 0 = never try again and fire target2)."$0D"'delay' - After"
       " spawned or triggered, how many seconds to wait to spawn the NPC."$0D"'"
       "showhealth' - Set to 1 to show health bar on this entity when crosshai"
       "r is over it."$0D"'teamowner' - Crosshair shows green for this team, r"
       "ed for opposite team."$0D"0 - none"$0D"1 - red"$0D"2 - blue"$0D"'teamu"
       "ser' - Only this team can use this NPC."$0D"0 - none"$0D"1 - red"$0D"2"
       " - blue"$0D"'teamnodmg' - Team that NPC does not take damage from (tur"
       "rets and other auto-defenses that have 'alliedTeam' set to this team w"
       "on't target this NPC)."$0D"0 - none"$0D"1 - red"$0D"2 - blue"$0D"'noBa"
       "sicSounds' - Set to 1 to prevent loading and usage of basic sounds (pa"
       "in, death, etc)."$0D"'noCombatSounds' - Set to 1 to prevent loading an"
       "d usage of combat sounds (anger, victory, etc.)."$0D"'noExtraSounds' -"
       " Set to 1 to prevent loading and usage of 'extra' sounds (chasing the "
       "enemy - detecting them, flanking them... also Jedi combat sounds)."$0D
       "'NPC_targetname' - NPC's targetname AND script_targetname."$0D"'NPC_ta"
       "rget' - NPC's target to fire when killed."$0D"'NPC_target2' - NPC's ta"
       "rget to fire when knocked out."$0D"'NPC_target4' - NPC's target to fir"
       "e when killed by friendly fire."$0D"'health' - Starting health (defaul"
       "t = 100)."$0D"=================================================="$0D"T"
       "hese are scripts that are called into use under these circumstances."$0D
       "'spawnscript' - Default script to run once spawned (none by default)."$0D
       "'usescript' - Default script to run when used (none by default)."$0D"'"
       "awakescript' - Default script to run once awoken (none by default)."$0D
       "'angerscript' - Default script to run once angered (none by default)."$0D
       "'painscript' - Default script to run when hit (none by default)."$0D"'"
       "fleescript' - Default script to run when hit and below 50% health (non"
       "e by default)."$0D"'deathscript' - Default script to run when killed ("
       "none by default)."
      bbox = '-16 -16 -24 16 16 40'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "TRAINER"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "CEILING"
      }
      spawnflags: =
