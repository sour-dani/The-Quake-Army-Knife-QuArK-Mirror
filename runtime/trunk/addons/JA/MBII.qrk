       "=================================================="$0D"These are scrip"
       "ts that are called into use under these circumstances."$0D"'spawnscrip"
       "t' - Default script to run once spawned (none by default)."$0D"'usescr"
       "ipt' - Default script to run when used (none by default)."$0D"'awakesc"
       "ript' - Default script to run once awoken (none by default)."$0D"'ange"
       "rscript' - Default script to run once angered (none by default)."$0D"'"
       "painscript' - Default script to run when hit (none by default)."$0D"'f"
       "leescript' - Default script to run when hit and below 50% health (none"
       " by default)."$0D"'deathscript' - Default script to run when killed (n"
       "one by default)."$0D"==============NOTES=============================="
       "="$0D"30 health, blaster."
      bbox = '-16 -16 -24 16 16 40'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "OFFICER"
      }
      spawnflags: =
