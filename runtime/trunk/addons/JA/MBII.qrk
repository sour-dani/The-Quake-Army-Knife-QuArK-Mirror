    info_jedimaster_start:form =
    {
      help = "===========DESCRIPTION============================"$0D"'jedi mas"
       "ter' saber spawn point"$0D"===========KEYS&VALUES====================="
       "======="$0D"'target' - Targets will be fired when someone spawns in on"
       " them."$0D"'nobots' - Will prevent bots from using this spot."$0D"'noh"
       "umans' - Will prevent non-bots from using this spot."$0D"'notfree' - W"
       "hen set to 1, entity will not spawn in 'Free for all' and 'Tournament'"
       " modes."$0D"'notteam' - When set to 1, entity will not spawn in 'Teamp"
       "lay' and 'CTF' modes."$0D"'notsingle' - When set to 1, entity will not"
       " spawn in Single Player mode (bot play mode)."$0D"'angle' - Direction "
       "in which player will look when spawning in the game. Does not apply to"
       " bots. 1 - 359 and -1 and -2 can be used for momentum purposes."
      bbox = '-16 -16 -24 16 16 32'
    }
    func_group:form =
    {
      help = "===========DESCRIPTION============================"$0D"Used to g"
       "roup brushes together just for editor convenience.  They are turned in"
       "to normal brushes by the utilities."$0D"===========KEYS&VALUES========"
       "===================="$0D"'_lightmapscale' - Floating point value scali"
       "ng the resolution of lightmaps on brushes/patches in this entity (defa"
       "ult 1.0)."$0D"'_cs' OR '_castshadows' - Allows per-entity control over"
       " shadow casting. Defaults to 0 on entities, 1 on world. 0 = no shadow "
       "casting. 1 = cast shadows on world. > 1 = cast shadows on entities wit"
       "h _rs (or _receiveshadows) with the corresponding value, AND world. Ne"
       "gative values imply same, but DO NOT cast shadows on world."$0D"'_rs' "
       "OR '_receiveshadows' - Allows per-entity control over shadow reception"
       ". Defaults to 1 on everything (world shadows). 0 = receives NO shadows"
       ". > 1 = receive shadows only from corresponding keyed entities (see ab"
       "ove) and world. < 1 = receive shadows ONLY from corresponding keyed en"
       "tities."$0D"'_celshader' - Sets the cel shader used for this geometry."
       " Note: omit the 'textures/' prefix."$0D"'_indexmap' OR 'alphamap' - Pa"
       "th/name for the art file used to guide the mapping of textures on the "
       "terrain surface."$0D"'_layer' OR 'layers' - Integer value is the numbe"
       "r of unique root shaders that will be use on the terrain."$0D"'_shader"
       "' OR 'shader' - Path to the metashader used to assign textures to the "
       "terrain entity. Note: Omit the 'textures/' prefix."
    }
    info_camp:form =
    {
      help = "===========DESCRIPTION============================"$0D"Used as a"
       " positional target for calculations in the utilities (spotlights, etc)"
       ", but removed during game play."$0D"===========KEYS&VALUES============"
       "================"$0D"'targetname' - must match the target key of entit"
       "y that uses this for pointing."
      bbox = '-4 -4 -4 4 4 4'
    }
    info_null:form =
    {
      help = "===========DESCRIPTION============================"$0D"Used as a"
       " positional target for calculations in the utilities (spotlights, etc)"
       ", but removed during game play."$0D"===========KEYS&VALUES============"
       "================"$0D"'targetname' - must match the target key of entit"
       "y that uses this for pointing."
      bbox = '-4 -4 -4 4 4 4'
    }
    info_notnull:form =
    {
      help = "===========DESCRIPTION============================"$0D"Used as a"
       " positional target for in-game calculation, like jumppad targets."$0D"t"
       "arget_position does the same thing"$0D"===========KEYS&VALUES========="
       "==================="$0D"'targetname' - must match the target key of en"
       "tity that uses this for pointing."
      bbox = '-4 -4 -4 4 4 4'
    }
    lightJunior:form =
    {
      help = "===========DESCRIPTION============================"$0D"Non-displ"
       "ayed point light source THAT ONLY AFFECTS ENTITIES (lightgrid). The -p"
       "ointscale and -scale arguments to Q3Map2 affect the brightness of thes"
       "e lights. The -skyscale argument affects brightness of entity sun ligh"
       "ts."$0D"===========SPAWNFLAGS============================="$0D"NONLINE"
       "AR - checkbox gives inverse square falloff instead of linear. (Linear)"
       " - Use a linear falloff. Default is inverse distance squared (more rea"
       "listic)."$0D"ANGLE - adds light surface angle calculations (only valid"
       " for 'Linear' lights) (wolf)."$0D"NEGATIVE_SPOT -"$0D"NEGATIVE_POINT -"
       $0D"NOGRIDLIGHT - Do not affect the lightgrid (dynamic entity lighting)"
       ". Setting this spawnflag will disable this light entirely."$0D"======="
       "====KEYS&VALUES============================"$0D"'light' overrides the "
       "default 300 intensity."$0D"'sun' Set this key to 1 on a spotlight to m"
       "ake an infinite sun light."$0D"'color' weighted RGB value of light col"
       "or (default white - 1.0 1.0 1.0). (Default setup with light entity sel"
       "ected press K to bring up color picker.)"$0D"'scale' Scales light atte"
       "nuation, from SOF2/JK2. Scales the 'light' value."$0D"'target' - Light"
       "s pointed at a target will be spotlights."$0D"'radius' - Overrides the"
       " default 64 unit radius of a spotlight at the target point."$0D"'fade'"
       " - Falloff/radius adjustment value. multiply the run of the slope by '"
       "fade' (1.0f default) (only valid for 'Linear' lights) (wolf)"
      bbox = '-8 -8 -8 8 8 8'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "NONLINEAR"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "ANGLE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "NEGATIVE_SPOT"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X8"
        cap = "NEGATIVE_POINT"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X16"
        cap = "NOGRIDLIGHT"
      }
    }
    light:form =
    {
      help = "===========DESCRIPTION============================"$0D"Non-displ"
       "ayed light."$0D"===========SPAWNFLAGS============================="$0D
       "LINEAR checkbox gives linear falloff instead of inverse square"$0D"NOI"
       "NCIDENCE - checkbox makes lighting smoother"$0D"START_OFF - Starts off"
       ". Does not cast light until triggered."$0D"===========KEYS&VALUES====="
       "======================="$0D"'light' - Overrides the default 300 intens"
       "ity. - affects size. A negative 'light' will subtract the light's colo"
       "r."$0D"'target' - Lights pointed at a target will be spotlights."$0D"'"
       "radius' - Overrides the default 64 unit radius of a spotlight at the t"
       "arget point."$0D"'scale' - Multiplier for the light intensity - does n"
       "ot affect size (default 1) greater than 1 is brighter, between 0 and 1"
       " is dimmer."$0D"'color' - Weighted RGB value of light color (default w"
       "hite - 1.0 1.0 1.0). (Default setup with light entity selected press K"
       " to bring up color picker.)"$0D"'_sun' - Set this key to 1 on a spotli"
       "ght to make an infinite sun light."$0D"'targetname' - To indicate a sw"
       "itchable light - NOTE that all lights with the same targetname will be"
       " grouped together and act as one light."$0D"'_flareshader' - Textures/"
       "flares/ (set Flare path)"$0D"'style' - To specify a specify light styl"
       "e, even for switchable lights!"$0D"'style_off' - Light style to use wh"
       "en switched off (Only for switchable lights)"$0D"1 FLICKER (first vari"
       "ety)"$0D"2 SLOW STRONG PULSE"$0D"3 CANDLE (first variety)"$0D"4 FAST S"
       "TROBE"$0D"5 GENTLE PULSE 1"$0D"6 FLICKER (second variety)"$0D"7 CANDLE"
       " (second variety)"$0D"8 CANDLE (third variety)"$0D"9 SLOW STROBE (four"
       "th variety)"$0D"10 FLUORESCENT FLICKER"$0D"11 SLOW PULSE NOT FADE TO B"
       "LACK"$0D"12 FAST PULSE FOR JEREMY"$0D"13 Test Blending"$0D"==========="
       "===NOTES==============================="$0D"Don't mix colors, styles, "
       "or start_off flag."
      bbox = '-8 -8 -8 8 8 8'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "LINEAR"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "NOINCIDENCE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "START_OFF"
      }
    }
    misc_teleporter_dest:form =
    {
      help = "===========DESCRIPTION============================"$0D"Point tel"
       "eporters at these. Now that we don't have teleport destination pads, t"
       "his is just an info_notnull"$0D"===========KEYS&VALUES================"
       "============"$0D"'angle' Direction in which player will look when spaw"
       "ning in the game. Does not apply to bots. 1 - 359 and -1 and -2 can be"
       " used for momentum purposes."$0D"'target' Targets will be fired when s"
       "omeone spawns in on them."$0D"==============NOTES====================="
       "=========="$0D"Best to use this with target_teleporter because you can"
       " specify a direction to face when destination is reached."
      bbox = '-32 -32 -24 32 32 -16'
    }
    misc_model:form =
    {
      help = "===========DESCRIPTION============================"$0D"Arbitrary"
       " .md3 or .ase model to add to map and turns into map triangles and is "
       "stored in the .bsp file."$0D"===========SPAWNFLAGS===================="
       "========="$0D"SOLID - Sets the auto clipping spawnflag, automatically "
       "assigning q3map_clipmodel to any shaders used by the model. Use of Q3M"
       "ap2 auto clipping for models is only recommended for large models with"
       " relatively few triangles in their mesh (i.e. terrain). The Q3Map2 aut"
       "o clipping algorithm is a bit of a hack, and can hurt in-game performa"
       "nce (as well as produce erroneous clipping results) when used on small"
       ", dense models."$0D"LIGHTED - Sets the forcemeta spawnflag, automatica"
       "lly adding q3map_forcemeta to any shaders used by the model (which, in"
       " turn, allows the model to become lightmapped). This, effectively, is "
       "the 'lightmapped model' spawnflag."$0D"===========KEYS&VALUES========="
       "==================="$0D"'model' - Path of arbitrary .md3 file to displ"
       "ay."$0D"'angle' - (1 - 359) - Rotates model on Z axis."$0D"'angles' - "
       "0 0 0 (X Y Z) - This is different than angle. This allows you to rotat"
       "e a model on all axis."$0D"'modelscale' - Scale on all axis. 1 is defa"
       "ult, 2 is double size, .5 is half size."$0D"'modelscale_vec' - 1 1 1 ("
       "X Y Z) - Scale axis independently."$0D"'_rs' (or _receiveshadows) - Al"
       "lows per-entity control over shadow reception. Defaults to 1 on everyt"
       "hing. 0 = receives no shadows, 1 = receives world shadows. Can be used"
       " in conjunction with _cs (or _castshadows) for tighter control of wher"
       "e, exactly, certain shadows fall. A _rs value greater than 1 (say, '7'"
       ") would receive world shadows, as well as shadows from any entity with"
       " a corresponding _cs value ('7' again). A _rs value less than 1 (say, "
       "'-7') would receive shadows only from entities with a corresponding _c"
       "s value ('-7') and not receive world shadows. _rs is used on any entit"
       "y."$0D"'_cs' (or _castshadows) Allows per-entity control over shadow c"
       "asting. Defaults to 0 on entities, 1 on world. 0 = no shadow casting, "
       "1 = casts shadows on world. Can be used in conjunction with _rs (or _r"
       "eceiveshadows) for tighter control of where, exactly, certain shadows "
       "fall. A _cs value greater than 1 (say, '7') would cast shadows on the "
       "world, and on any entity with a corresponding _rs value ('7' again, in"
       " our case) as well. A _cs value less than 1 (say, '-7') would cast sha"
       "dows only on entities with a corresponding _rs value ('-7') and not ca"
       "st shadows on the world. _cs is used on any entity. misc_model entitie"
       "s, which are static, belongs to world."$0D"'_remap' - Remap the shader"
       " of a model (*See notes.)"$0D"==============NOTES====================="
       "=========="$0D"You can change the shaders of models."$0D"To replace al"
       "l model shaders use these keys:"$0D"key: _remap"$0D"value: *;models/ma"
       "pobjects/torchy/rock01"$0D"To replace individual shaders from an md3 u"
       "se these keys:"$0D"key: _remap01"$0D"value: models/mapobjects/oldshade"
       "r01;models/mapobjects/newshader01"$0D"key: _remap02"$0D"value: models/"
       "mapobjects/oldshader02;models/mapobjects/newshader02"$0D"The second me"
       "thod can be handy for replacing the crystal rift shaders so you can ha"
       "ve red ones too. because you are only changing the crystal the other p"
       "arts of the models remain the same.... handy for ctf maps ;) notice in"
       " the first example * means all model shaders make sure you seperate sh"
       "aders with ; Changes you make to your models can be seen in realtime i"
       "n gtk radiant, so if the skin doesnt change you havent specified a cor"
       "rect shader to replace."
      bbox = '-16 -16 -16 16 16 16'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "X"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "SOLID"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "LIGHTED"
      }
    }
    misc_model_static:form =
    {
      help = "===========DESCRIPTION============================"$0D"Arbitrary"
       " .md3 or .ase model to add to map and is not stored in the .bsp file. "
       "Loaded as a model in the renderer - does not take up precious bsp spac"
       "e!"$0D"===========KEYS&VALUES============================"$0D"'model' "
       "- Path of arbitrary .md3 file to display."$0D"'angle' - (1 - 359) - Ro"
       "tates model on Z axis."$0D"'angles' - 0 0 0 (X Y Z) - This is differen"
       "t than angle. This allows you to rotate a model on all axis."$0D"'mode"
       "lscale' - Scale on all axis. 1 is default, 2 is double size, .5 is hal"
       "f size."$0D"'modelscale_vec' - 1 1 1 (X Y Z) - Scale axis independentl"
       "y."$0D"'zoffset' - Units to offset vertical culling position by, can b"
       "e negative or positive. This does not affect the actual position of th"
       "e model, only the culling position. Use it for models with stupid orig"
       "ins that go below the ground and whatnot."$0D"========================"
       "=========================="$0D"'_lightmapscale' - Floating point value"
       " scaling the resolution of lightmaps on brushes/patches in this entity"
       " (default 1.0)."$0D"'_cs' OR '_castshadows' - Allows per-entity contro"
       "l over shadow casting. Defaults to 0 on entities, 1 on world. 0 = no s"
       "hadow casting. 1 = cast shadows on world. > 1 = cast shadows on entiti"
       "es with _rs (or _receiveshadows) with the corresponding value, AND wor"
       "ld. Negative values imply same, but DO NOT cast shadows on world."$0D"'"
       "_rs' OR '_receiveshadows' - Allows per-entity control over shadow rece"
       "ption. Defaults to 1 on everything (world shadows). 0 = receives NO sh"
       "adows. > 1 = receive shadows only from corresponding keyed entities (s"
       "ee above) and world. < 1 = receive shadows ONLY from corresponding key"
       "ed entities."$0D"'_celshader' - Sets the cel shader used for this geom"
       "etry. Note: omit the 'textures/' prefix."$0D"'_indexmap' OR 'alphamap'"
       " - Path/name for the art file used to guide the mapping of textures on"
       " the terrain surface."$0D"'_layer' OR 'layers' - Integer value is the "
       "number unique root shaders that will be use on the terrain."$0D"'_shad"
       "er' OR 'shader' - Path to the metashader used to assign textures to th"
       "e terrain entity. Note: Omit the 'textures/' prefix."$0D"'_remap' - Re"
       "map the shader of a model (*See notes.)"$0D"==============NOTES======="
       "========================"$0D"You can change the shaders of models."$0D
       "To replace all model shaders use these keys:"$0D"key: _remap"$0D"value"
       ": *;models/mapobjects/torchy/rock01"$0D"To replace individual shaders "
       "from an md3 use these keys:"$0D"key: _remap01"$0D"value: models/mapobj"
       "ects/oldshader01;models/mapobjects/newshader01"$0D"key: _remap02"$0D"v"
       "alue: models/mapobjects/oldshader02;models/mapobjects/newshader02"$0D"T"
       "he second method can be handy for replacing the crystal rift shaders s"
       "o you can have red ones too. because you are only changing the crystal"
       " the other parts of the models remain the same.... handy for ctf maps "
       ";) notice in the first example * means all model shaders make sure you"
       " seperate shaders with ; Changes you make to your models can be seen i"
       "n realtime in gtk radiant, so if the skin doesnt change you havent spe"
       "cified a correct shader to replace."
      bbox = '-16 -16 0 16 16 16'
    }
    misc_G2model:form =
    {
      help = "===========DESCRIPTION============================"$0D"'model' -"
       " arbitrary .glm file to display."$0D"================================="
       "================="$0D"'_lightmapscale' - Floating point value scaling "
       "the resolution of lightmaps on brushes/patches in this entity (default"
       " 1.0)."$0D"'_cs' OR '_castshadows' - Allows per-entity control over sh"
       "adow casting. Defaults to 0 on entities, 1 on world. 0 = no shadow cas"
       "ting. 1 = cast shadows on world. > 1 = cast shadows on entities with _"
       "rs (or _receiveshadows) with the corresponding value, AND world. Negat"
       "ive values imply same, but DO NOT cast shadows on world."$0D"'_rs' OR "
       "'_receiveshadows' - Allows per-entity control over shadow reception. D"
       "efaults to 1 on everything (world shadows). 0 = receives NO shadows. >"
       " 1 = receive shadows only from corresponding keyed entities (see above"
       ") and world. < 1 = receive shadows ONLY from corresponding keyed entit"
       "ies."$0D"'_celshader' - Sets the cel shader used for this geometry. No"
       "te: omit the 'textures/' prefix."$0D"'_indexmap' OR 'alphamap' - Path/"
       "name for the art file used to guide the mapping of textures on the ter"
       "rain surface."$0D"'_layer' OR 'layers' - Integer value is the number o"
       "f unique root shaders that will be use on the terrain."$0D"'_shader' O"
       "R 'shader' - Path to the metashader used to assign textures to the ter"
       "rain entity. Note: Omit the 'textures/' prefix."
      bbox = '-16 -16 -16 16 16 16'
    }
    misc_portal_surface:form =
    {
      help = "===========DESCRIPTION============================"$0D"Portal su"
       "rface indicator. This will 'lock on' the brush face closest to it and "
       "identify as a portal. The view displayed on the portal surface is the "
       "view of the misc_portal_camera that this entity targets. Also used for"
       " mirrors (see Notes)."$0D"===========KEYS&VALUES======================"
       "======"$0D"'target' - Point this to a misc_portal_camera that 'sees' t"
       "he view you want to display on the portal."$0D"'notfree' - When set to"
       " 1, entity will not spawn in 'Free for all' and 'Tournament' modes."$0D
       "'notteam' - When set to 1, entity will not spawn in 'Teamplay' and 'CT"
       "F' modes."$0D"'notsingle' - When set to 1, entity will not spawn in Si"
       "ngle Player mode (bot play mode)."$0D"==============NOTES============="
       "=================="$0D"The entity must be no farther than 64 units awa"
       "y from the portal surface to lock onto it. To make a mirror, apply the"
       " common/mirror shader to the surface, place this entity near it but do"
       "n't target a misc_portal_camera."
      bbox = '-8 -8 -8 8 8 8'
    }
    misc_portal_camera:form =
    {
      help = "===========DESCRIPTION============================"$0D"Portal ca"
       "mera. This camera is used to project its view onto a portal surface in"
       " the level through the intermediary of a misc_portal_surface entity."$0D
       "The target for a misc_portal_director. You can set either angles or ta"
       "rget another entity to determine the direction of view."$0D"Use the 'a"
       "ngles' key or target a target_position or info_notnull entity to set t"
       "he camera's pointing direction."$0D"===========SPAWNFLAGS============="
       "================"$0D"SLOWROTATE - Makes the portal camera rotate slowl"
       "y along the roll axis."$0D"FASTROTATE - Makes the portal camera rotate"
       " faster along the roll axis."$0D"NOSWING - Portal camera will be locke"
       "d in one position."$0D"===========KEYS&VALUES========================="
       "==="$0D"'angles' - This sets the pitch and yaw aiming angles of the po"
       "rtal camera (default 0 0 0). Use 'roll' key to set roll angle."$0D"'ta"
       "rget' - Point this to a target_position entity to set the camera's poi"
       "nting direction."$0D"'targetname' - A misc_portal_surface portal surfa"
       "ce indicator must point to this."$0D"'roll' - Roll angle of camera. A "
       "value of 0 is upside down and 180 is the same as the player's view."$0D
       "'notfree' - When set to 1, entity will not spawn in 'Free for all' and"
       " 'Tournament' modes."$0D"'notteam' - When set to 1, entity will not sp"
       "awn in 'Teamplay' and 'CTF' modes."$0D"'notsingle' - When set to 1, en"
       "tity will not spawn in Single Player mode (bot play mode)."$0D"======="
       "=======NOTES==============================="$0D"Either the setting 'an"
       "gles' key or 'targeting a target_position' methods can be used to aim "
       "the camera. However, the target_position method is simpler. In both ca"
       "ses, the 'roll' key must be used to set the roll angle. If either the "
       "SLOWROTATE or FASTROTATE spawnflag is set, then the 'roll' value is ir"
       "relevant."
      bbox = '-8 -8 -8 8 8 8'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "SLOWROTATE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X2"
        cap = "FASTROTATE"
      }
      spawnflags: =
      {
        txt = "&"
        typ = "X4"
        cap = "NOSWING"
      }
    }
    misc_bsp:form =
    {
      help = "===========DESCRIPTION============================"$0D"'bspmodel"
       "' - path of arbitrary .bsp file to display."$0D"======================"
       "============================"$0D"'_lightmapscale' - Floating point val"
       "ue scaling the resolution of lightmaps on brushes/patches in this enti"
       "ty (default 1.0)."$0D"'_cs' OR '_castshadows' - Allows per-entity cont"
       "rol over shadow casting. Defaults to 0 on entities, 1 on world. 0 = no"
       " shadow casting. 1 = cast shadows on world. > 1 = cast shadows on enti"
       "ties with _rs (or _receiveshadows) with the corresponding value, AND w"
       "orld. Negative values imply same, but DO NOT cast shadows on world."$0D
       "'_rs' OR '_receiveshadows' - Allows per-entity control over shadow rec"
       "eption. Defaults to 1 on everything (world shadows). 0 = receives NO s"
       "hadows. > 1 = receive shadows only from corresponding keyed entities ("
       "see above) and world. < 1 = receive shadows ONLY from corresponding ke"
       "yed entities."$0D"'_celshader' - Sets the cel shader used for this geo"
       "metry. Note: omit the 'textures/' prefix."$0D"'_indexmap' OR 'alphamap"
       "' - Path/name for the art file used to guide the mapping of textures o"
       "n the terrain surface."$0D"'_layer' OR 'layers' - Integer value is the"
       " number of unique root shaders that will be use on the terrain."$0D"'_"
       "shader' OR 'shader' - Path to the metashader used to assign textures t"
       "o the terrain entity. Note: Omit the 'textures/' prefix."
      bbox = '-16 -16 -16 16 16 16'
    }
    terrain:form =
    {
      help = "===========DESCRIPTION============================"$0D"Terrain e"
       "ntity"$0D"It will stretch to the full height of the brush."$0D"======="
       "====SPAWNFLAGS============================="$0D"NOVEHDMG - don't damag"
       "e vehicles upon impact with this terrain"$0D"===========KEYS&VALUES==="
       "========================="$0D"'numPatches' - Integer number of patches"
       " to split the terrain brush into (default 200)."$0D"'terxels' - Intege"
       "r number of terxels on a patch side (default 4) (2 <= count <= 8)."$0D
       "'seed' - Integer seed for random terrain generation (default 0)."$0D"'"
       "textureScale' - Float scale of texture (default 0.005)."$0D"'heightmap"
       "' - Name of heightmap data image to use, located in heightmaps/*.png. "
       "(must be PNG format)."$0D"'terrainDef' - Defines how the game textures"
       " the terrain (file is base/ext_data/rmg/*.terrain - default is grassyh"
       "ills)."$0D"'instanceDef' - Defines which bsp instances appear."$0D"'mi"
       "scentDef' - Defines which client models spawn on the terrain (file is "
       "base/ext_data/rmg/*.miscents)."$0D"'densityMap' - How dense the client"
       " models are packed."$0D"=============================================="
       "===="$0D"'_lightmapscale' - Floating point value scaling the resolutio"
       "n of lightmaps on brushes/patches in this entity (default 1.0)."$0D"'_"
       "cs' OR '_castshadows' - Allows per-entity control over shadow casting."
       " Defaults to 0 on entities, 1 on world. 0 = no shadow casting. 1 = cas"
       "t shadows on world. > 1 = cast shadows on entities with _rs (or _recei"
       "veshadows) with the corresponding value, AND world. Negative values im"
       "ply same, but DO NOT cast shadows on world."$0D"'_rs' OR '_receiveshad"
       "ows' - Allows per-entity control over shadow reception. Defaults to 1 "
       "on everything (world shadows). 0 = receives NO shadows. > 1 = receive "
       "shadows only from corresponding keyed entities (see above) and world. "
       "< 1 = receive shadows ONLY from corresponding keyed entities."$0D"'_ce"
       "lshader' - Sets the cel shader used for this geometry. Note: omit the "
       "'textures/' prefix."$0D"'_indexmap' OR 'alphamap' - Path/name for the "
       "art file used to guide the mapping of textures on the terrain surface."
       $0D"'_layer' OR 'layers' - Integer value is the number of unique root s"
       "haders that will be use on the terrain."$0D"'_shader' OR 'shader' - Pa"
       "th to the metashader used to assign textures to the terrain entity. No"
       "te: Omit the 'textures/' prefix."
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "NOVEHDMG"
      }
    }
    misc_skyportal_orient:form =
    {
      help = "===========DESCRIPTION============================"$0D"Point fro"
       "m which to orient the sky portal cam in relation to the regular view p"
       "osition."$0D"===========KEYS&VALUES============================"$0D"'m"
       "odelscale' - The scale at which to scale positions"
      bbox = '-8 -8 0 8 8 16'
    }
    misc_skyportal:form =
    {
      help = "===========DESCRIPTION============================"$0D"Portal sk"
       "y. This is used to project its view origin from a miniature map room o"
       "nto all nodraw sky in the level. This includes caulk. It's best advise"
       "d not to have any hall of mirror effects within field of view of this "
       "entity. Bad Things can happen."$0D"===========KEYS&VALUES============="
       "==============="$0D"'targetname' - Will link this rendered origin to t"
       "he scene wherever the misc_skyportal_surface is located."$0D"'fov' - F"
       "or the skybox default is 80."$0D"To have the portal sky fogged, enter "
       "any of the following values:"$0D"'onlyfoghere' if non-0 allows you to "
       "set a global fog, but will only use that fog within this sky portal."$0D
       "==============NOTES==============================="$0D"Also note that "
       "entities in the same PVS and visible (via point trace) from this objec"
       "t will be flagged as portal entities. This means they will be sent and"
       " updated from the server for every client every update regardless of w"
       "here they are, and they will essentially be added to the scene twice i"
       "f the client is in the same PVS as them (only once otherwise, but stil"
       "l once no matter where the client is). In other words, don't go overbo"
       "ard with it or everything will explode."
      bbox = '-8 -8 0 8 8 16'
    }
    misc_holocron:form =
    {
      help = "===========DESCRIPTION============================"$0D"Creates a"
       " holocron to give player specific force power."$0D"===========KEYS&VAL"
       "UES============================"$0D"'count' - Set to type of holocron "
       "(based on force power value)."$0D"HEAL = 0"$0D"JUMP = 1"$0D"SPEED = 2"$0D
       "PUSH = 3"$0D"PULL = 4"$0D"TELEPATHY = 5"$0D"GRIP = 6"$0D"LIGHTNING = 7"
       $0D"RAGE = 8"$0D"PROTECT = 9"$0D"ABSORB = 10"$0D"TEAM HEAL = 11"$0D"TEA"
       "M FORCE = 12"$0D"DRAIN = 13"$0D"SEE = 14"$0D"SABERATTACK = 15"$0D"SABE"
       "RDEFEND = 16"$0D"SABERTHROW = 17"
      bbox = '-8 -8 -8 8 8 8'
    }
    misc_hologram:form =
    {
      help = $3D3D3D3D3D3D3D3D3D3D3D4D4F56494520424154544C45532049492053504543
       $4946494320454E544954593D3D3D3D3D3D3D3D3D3D3D0D3D3D3D3D3D3D3D3D3D3D3D44
