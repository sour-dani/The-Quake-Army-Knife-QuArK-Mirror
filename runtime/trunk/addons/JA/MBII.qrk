    weapon_stun_baton:form =
    {
      help = "===========DESCRIPTION============================"$0D"Stun Bato"
       "n. No ammo used."$0D"===========SPAWNFLAGS============================"
       "="$0D"SUSPENDED - Item will spawn where it was placed in map and won't"
       " drop to the floor."$0D"===========KEYS&VALUES========================"
       "===="$0D"'wait' - Time in seconds before item respawns after being pic"
       "ked up (default 5, -1 = never respawn)."$0D"'random' - Random time var"
       "iance in seconds added or subtracted from 'wait' delay (default 0 - se"
       "e Notes)."$0D"'team' - Set this to team items. Teamed items will respa"
       "wn randomly after team master is picked up (see Notes)."$0D"'target' -"
       " Picking up the item will trigger the entity this points to."$0D"'targ"
       "etname' - A target_give entity can point to this for respawn freebies."
       $0D"'notfree' - When set to 1, entity will not spawn in 'Free for all' "
       "and 'Tournament' modes."$0D"'notteam' - When set to 1, entity will not"
       " spawn in 'Teamplay' and 'CTF' modes."$0D"'notsingle' - When set to 1,"
       " entity will not spawn in Single Player mode (bot play mode)."$0D"'not"
       "bot' - When set to 1, bots will not be able to see or use this entity."
       $0D"==============NOTES==============================="$0D"The amount o"
       "f time it takes for an item in the team to respawn is determined by th"
       "e 'wait' value of the item that was picked up previously. So if one of"
       " the items in the team has it's 'wait' key set to -1 (never respawn), "
       "the random respawning cycle of the teamed items will stop after that i"
       "tem is picked up."$0D"When the random key is set, it's value is used t"
       "o calculate a minimum and a maximum delay. The final time delay will b"
       "e a random value anywhere between the minimum and maximum values: (min"
       " delay = wait - random) (max delay = wait + random)."$0D"=====MODEL FO"
       "R MAPPING VISUAL ONLY================"$0D"Model not complete enough to"
       " be worth the having."$0D"======DO NOT SET AS KEY OR VALUE============"
       "======"
      bbox = '-16 -16 -16 16 16 16'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "SUSPENDED"
      }
    }
