  Entity Forms.fctx =
  {
    item_*****:form =
    {
      help = "===========DESCRIPTION============================"$0D"DO NOT US"
       "E THIS CLASS, IT JUST HOLDS GENERAL INFORMATION."$0D"===========SPAWNF"
       "LAGS============================"$0D"The suspended flag will allow ite"
       "ms to hang in the air; otherwise they are dropped to the next surface."
       $0D"===========KEYS&VALUES============================"$0D"'targetname'"
       " - If an item is the target of another entity, it will not spawn in un"
       "til fired."$0D"'target' - An item fires all of its targets when it is "
       "picked up. If the player that touches it can't carry it, the targets w"
       "on't be fired."$0D"'notfree' - If set to 1, don't spawn in free for al"
       "l games."$0D"'notteam' - If set to 1, don't spawn in team games."$0D"'"
       "notsingle' - If set to 1, don't spawn in single player games."$0D"'wai"
       "t' - Time in seconds before item respawns after being picked up (defau"
       "lt 40, -1 = never respawn automatically). Can be used with targeted sp"
       "awning."$0D"'random' - Random number of plus or minus seconds varied f"
       "rom the respawn time."$0D"'count' - Override quantity or duration on m"
       "ost items."
      bbox = '-16 -16 -16 16 16 16'
      spawnflags: =
      {
        txt = "&"
        typ = "X1"
        cap = "suspended"
      }
    }
    item_shield_sm_instant:form =
    {
      help = "===========DESCRIPTION============================"$0D"Instant s"
       "hield pickup, restores 25."$0D"===========SPAWNFLAGS=================="
